    if distance > ALT_MAX_DISTANCE then return false end
    local lookDir = myRoot.CFrame.LookVector
    local toTarget = (targetRoot.Position - myRoot.Position).Unit
    return lookDir:Dot(toTarget) > 0.5
end

function AutoLegitTackle.PressTackle()
