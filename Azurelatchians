function UIUpgrade.Corner(amm, parent)
    if parent:FindFirstChildOfClass("UICorner") then return nil end
    local con = Instance.new("UICorner")
    con.CornerRadius = UDim.new(amm, 0)
    con.Parent = parent
    table.insert(UIUpgrade.CreatedCorners, con)
    return con
end

function UIUpgrade.SaveOriginal(obj, property)
    local key = tostring(obj:GetFullName()) .. "_" .. property
    if UIUpgrade.OriginalValues[key] == nil then
        UIUpgrade.OriginalValues[key] = {obj = obj, property = property, value = obj[property]}
    end
end

function UIUpgrade.Sfx(id, volume, duration, startTime)
    local sound = Instance.new("Sound")
    sound.SoundId = id
    sound.Volume = volume
    sound.Parent = Services.Workspace
    if startTime then sound.TimePosition = startTime end
    sound:Play()
    if duration then
        task.delay(duration, function() sound:Stop() sound:Destroy() end)
    else
        game.Debris:AddItem(sound, 10)
    end
    return sound
end

