                if targetHRP and animator then
                    local distance = (targetHRP.Position - myPos).Magnitude
                    if distance <= 87 and ASH_IsEnemyFacingPlayer(targetHRP, myPos) then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            local animId = track.Animation and track.Animation.AnimationId
                            if animId and track.IsPlaying and AutoSerpentHeader.AnimationSet[animId] then
                                local animationDelay = AutoSerpentHeader.Animations[animId]
                                local targetPlayer = Services.Players:FindFirstChild(targetChar.Name)
                                if targetPlayer then
                                    local trackingKey = targetPlayer.UserId.."_"..animId
                                    if not AutoSerpentHeader.AnimationTracking[trackingKey] then
                                        AutoSerpentHeader.AnimationTracking[trackingKey] = {
                                            detectedTime = currentTime, hasTriggered = false, delay = animationDelay
                                        }
                                    end
                                    local animData = AutoSerpentHeader.AnimationTracking[trackingKey]
                                    if not animData.hasTriggered and (currentTime - animData.detectedTime) >= animData.delay then
                                        if currentTime - AutoSerpentHeader.LastDefenseTime > 6 then
                                            AutoSerpentHeader.LastDefenseTime = currentTime
                                            AutoSerpentHeader.PerformSkill1()
                                            animData.hasTriggered = true
                                        end
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    for trackingKey, data in pairs(AutoSerpentHeader.AnimationTracking) do
        if currentTime - data.detectedTime > 5 then AutoSerpentHeader.AnimationTracking[trackingKey] = nil end
    end
end

