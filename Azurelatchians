function StyleIndicator.CreateIndicator(player, character)
    if not character or not character:FindFirstChild("Head") then return end
    StyleIndicator.RemoveIndicator(player)
    local styleAttribute = player:GetAttribute("style") or "unknown"
    local displayName = StyleIndicator.StyleDisplayNames[styleAttribute] or "Unknown"
    local styleColor = StyleIndicator.StyleColors[displayName] or StyleIndicator.StyleColors.Unknown
    local styleTag = Drawing.new("Text")
    styleTag.Text = displayName
    styleTag.Size = 18
    styleTag.Center = true
    styleTag.Outline = true
    styleTag.Font = 0
    styleTag.Color = styleColor
    styleTag.Visible = false
    StyleIndicator.DrawingCache[player.UserId] = {styleTag = styleTag, character = character, player = player}
end

function StyleIndicator.UpdateIndicator(player)
    local cache = StyleIndicator.DrawingCache[player.UserId]
    if not cache or not cache.character or not cache.character.Parent then StyleIndicator.RemoveIndicator(player) return end
    if StyleIndicator.TeamCheck and IsSameTeam(player) then cache.styleTag.Visible = false return end
    local character = cache.character
    local head = character:FindFirstChild("Head") if not head then return end
    local camera = workspace.CurrentCamera
    local distance = (camera.CFrame.Position - head.Position).Magnitude
    if distance > IndicatorsMaxDistance then cache.styleTag.Visible = false return end
    local stylePosition = head.Position + Vector3.new(0, 3.5, 0)
    local styleVector, styleOnScreen = camera:WorldToViewportPoint(stylePosition)
    if styleOnScreen then
        cache.styleTag.Position = Vector2.new(styleVector.X, styleVector.Y)
        cache.styleTag.Visible = true
        local styleAttribute = player:GetAttribute("style") or "unknown"
        local displayName = StyleIndicator.StyleDisplayNames[styleAttribute] or "Unknown"
        local color = StyleIndicator.StyleColors[displayName] or StyleIndicator.StyleColors.Unknown
        if cache.styleTag.Text ~= displayName then cache.styleTag.Text = displayName cache.styleTag.Color = color end
    else
        cache.styleTag.Visible = false
    end
end

function StyleIndicator.RemoveIndicator(player)
    local cache = StyleIndicator.DrawingCache[player.UserId]
    if cache then
        if cache.styleTag then cache.styleTag.Visible = false cache.styleTag:Remove() end
        StyleIndicator.DrawingCache[player.UserId] = nil
    end
end

function StyleIndicator.SetupPlayerTracking(player)
    StyleIndicator.RemoveIndicator(player)
    
    task.spawn(function()
        for attempt = 1, 10 do
            if not StyleIndicator.Enabled then return end
            if player.Character and player.Character:FindFirstChild("Head") then
                StyleIndicator.CreateIndicator(player, player.Character)
                break
            end
            task.wait(0.5)
        end
    end)
    local charAddedConn = player.CharacterAdded:Connect(function(character)
        task.spawn(function()
            for attempt = 1, 10 do
                if not StyleIndicator.Enabled then return end
                if character and character:FindFirstChild("Head") then
                    StyleIndicator.CreateIndicator(player, character)
                    break
                end
                task.wait(0.3)
            end
        end)
    end)
    local attrChangedConn = player:GetAttributeChangedSignal("style"):Connect(function() if player.Character then StyleIndicator.CreateIndicator(player, player.Character) end end)
    table.insert(StyleIndicator.Connections, charAddedConn)
    table.insert(StyleIndicator.Connections, attrChangedConn)
end

function StyleIndicator.Initialize()
    for _, player in ipairs(Services.Players:GetPlayers()) do StyleIndicator.SetupPlayerTracking(player) end
    local playerAddedConn = Services.Players.PlayerAdded:Connect(function(player) StyleIndicator.SetupPlayerTracking(player) end)
    table.insert(StyleIndicator.Connections, playerAddedConn)
end

function StyleIndicator.RenderLoop()
    while StyleIndicator.Enabled do
        for userId, cache in pairs(StyleIndicator.DrawingCache) do
            if cache and cache.player and cache.character then StyleIndicator.UpdateIndicator(cache.player) end
        end
        task.wait()
    end
end

