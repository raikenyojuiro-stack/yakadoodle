function FindSkillButton(skillName)
    local playerGui = Player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    local hotbar = playerGui:FindFirstChild("Hotbar")
    if not hotbar then return nil end
    local backpack = hotbar:FindFirstChild("Backpack")
    if not backpack then return nil end
    local hotbarFrame = backpack:FindFirstChild("Hotbar")
    if not hotbarFrame then return nil end
    return hotbarFrame:FindFirstChild(skillName)
end

function IsSkillOnCooldown(skillName)
    local skillButton = FindSkillButton(skillName)
    if not skillButton then return true end
    local cooldownFrame = skillButton:FindFirstChild("Cooldown")
    if not cooldownFrame then return false end
    local cooldownSizeY = cooldownFrame.AbsoluteSize.Y
    return cooldownSizeY > 1 or (cooldownFrame.Visible and cooldownFrame.BackgroundTransparency < 0.9)
end

function GetPlayerTeam(playerName)
    local characters = Services.Workspace:WaitForChild("characters")
    local playerChar = characters:FindFirstChild(playerName)
    if playerChar then
        local state = playerChar:FindFirstChild("state")
        if state then
            local team = state:FindFirstChild("team")
            if team then return team.Value end
        end
    end
    return nil
end

function HasBall(playerName)
    local chars = Services.Workspace:WaitForChild("characters")
    local char = chars:FindFirstChild(playerName or Player.Name)
    return char and char:FindFirstChild("Ball")
end

function CheckStyle(style)
    local currentStyle = Player:GetAttribute("style")
    if type(style) == "table" then
        for _, s in ipairs(style) do
            if currentStyle == s then return true end
        end
        return false
    end
    return currentStyle == style
end


