function AutoOffBallAwk.IsSupportedStyle() return AutoOffBallAwk.SupportedStyles[Player:GetAttribute("style")] or false end
function AutoOffBallAwk.GetFlow()
    if not Player.Character then return 0 end
    local state = Player.Character:FindFirstChild("state")
    return state and state:FindFirstChild("flow") and tonumber(state.flow.Value) or 0
end
function AutoOffBallAwk.HasBall() local chars = Services.Workspace:FindFirstChild("characters") local char = chars and chars:FindFirstChild(Player.Name) return char and char:FindFirstChild("Ball") end
function AutoOffBallAwk.GetPlayerTeam() if not Player.Character then return nil end local state = Player.Character:FindFirstChild("state") return state and state:FindFirstChild("team") and state.team.Value end
function AutoOffBallAwk.FindBallOwnerTeam()
    local chars = Services.Workspace:FindFirstChild("characters") if not chars then return nil end
    for _, pf in ipairs(chars:GetChildren()) do if pf:FindFirstChild("Ball") then local st = pf:FindFirstChild("state") if st and st:FindFirstChild("team") then return st.team.Value end end end
