function AutoLineUps.GetTeam()
    if not Player.Character then return nil end
    local state = Player.Character:FindFirstChild("state")
    if state then
        local team = state:FindFirstChild("team")
        if team then return team.Value end
    end
    return nil
end

function AutoLineUps.GetStyle()
    return Player:GetAttribute("style")
end

function AutoLineUps.GetFlow()
    local chars = Services.Workspace:FindFirstChild("characters")
    if not chars then return nil end
    local my = chars:FindFirstChild(Player.Name)
    if not my then return nil end
    local st = my:FindFirstChild("state")
    return st and st:FindFirstChild("flow")
end

function AutoLineUps.UpdateFlowState()
    local flowObj = AutoLineUps.GetFlow()
    if not flowObj then
        AutoLineUps.FlowState.HasFlow = false
        AutoLineUps.FlowState.WasAbove100 = false
        AutoLineUps.FlowState.LastFlowValue = 0
        AutoLineUps.ReoFlowUsedThisCycle = false
        return
    end
    local value = flowObj.Value
    if value >= 100 then
        AutoLineUps.FlowState.WasAbove100 = true
        AutoLineUps.FlowState.HasFlow = false
        AutoLineUps.ReoFlowUsedThisCycle = false 
    elseif value < 100 and AutoLineUps.FlowState.WasAbove100 then
        AutoLineUps.FlowState.HasFlow = true
    end
    if value <= 0 then
        AutoLineUps.FlowState.WasAbove100 = false
        AutoLineUps.FlowState.HasFlow = false
        AutoLineUps.ReoFlowUsedThisCycle = false 
    end
    AutoLineUps.FlowState.LastFlowValue = value
end

function AutoLineUps.HasEnemyNearby(radius)
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local myTeam = AutoLineUps.GetTeam()
    if not myTeam then return false end
    
    local chars = Services.Workspace:FindFirstChild("characters")
    if not chars then return false end
    
    for _, otherChar in pairs(chars:GetChildren()) do
        if otherChar.Name ~= Player.Name then
            local otherState = otherChar:FindFirstChild("state")
            if otherState then
                local otherTeam = otherState:FindFirstChild("team")
                if otherTeam and otherTeam.Value ~= "" and otherTeam.Value ~= myTeam then
                    
                    local otherHRP = otherChar:FindFirstChild("HumanoidRootPart")
                    if otherHRP then
                        local dist = (hrp.Position - otherHRP.Position).Magnitude
                        if dist <= radius then
                            return true 
                        end
                    end
                end
            end
        end
    end
    return false
end

function AutoLineUps.IsSkillOnCooldown(skillName)
    local gui = Player:FindFirstChild("PlayerGui")
    if not gui then return true end
    local hotbar = gui:FindFirstChild("Hotbar")
    if not hotbar then return true end
    local backpack = hotbar:FindFirstChild("Backpack")
    if not backpack then return true end
    local hotbarFrame = backpack:FindFirstChild("Hotbar")
    if not hotbarFrame then return true end
    local btn = hotbarFrame:FindFirstChild(skillName)
    if not btn then return true end
    local cd = btn:FindFirstChild("Cooldown")
    if not cd then return false end
    return cd.Visible and cd.BackgroundTransparency < 0.9
end

function AutoLineUps.CreateMarkers()
    for _, m in pairs(AutoLineUps.Markers) do if m and m.Parent then m:Destroy() end end
    AutoLineUps.Markers = {}
    local style = AutoLineUps.GetStyle()
    local team = AutoLineUps.GetTeam()
    if not style or not team then return end
    
    
    if LineUpCreator and LineUpCreator.CustomLineUps then
        for _, lineup in ipairs(LineUpCreator.CustomLineUps) do
            local styleName = lineup.style
            if lineup.isFlow and not string.find(styleName, "_flow$") then 
                styleName = styleName .. "_flow" 
            end
            local cfg = AutoLineUps.StylesConfig[styleName]
            if cfg and cfg.points[lineup.team] then
                
                local exists = false
                for _, point in ipairs(cfg.points[lineup.team]) do
                    if point.isCustom then
                        local posMatch = math.abs(point.targetPosition.X - lineup.targetPosition.X) < 1 and
                                         math.abs(point.targetPosition.Z - lineup.targetPosition.Z) < 1
                        if posMatch then exists = true break end
                    end
                end
                if not exists then
                    local point = {
                        targetPosition = Vector3.new(lineup.targetPosition.X, lineup.targetPosition.Y, lineup.targetPosition.Z),
                        mouseTargetPosition = Vector3.new(lineup.mouseTargetPosition.X, lineup.mouseTargetPosition.Y, lineup.mouseTargetPosition.Z),
                        lookAtHeight = lineup.mouseTargetPosition.Y,
                        isCustom = true
                    }
                    table.insert(cfg.points[lineup.team], point)
                end
            end
        end
    end
    
    
    local configsToUse = {}
    local isReo = style == "reo"
    local reoMarkerColor = AutoLineUps.ReoMarkerColor
    
    
    if isReo then
        local skill4Name = AutoLineUps.GetReoSkill4Name()
        AutoLineUps.CurrentReoSkill = skill4Name
        local mappedStyle = skill4Name and AutoLineUps.ReoSkillMapping[skill4Name]
        if mappedStyle then
            local cfg = AutoLineUps.StylesConfig[mappedStyle]
            if cfg and cfg.points[team] then
                
                local shouldShow = true
                if cfg.flow then
                    shouldShow = AutoLineUps.FlowState.HasFlow
                end
                if shouldShow then
                    table.insert(configsToUse, {config = cfg, name = mappedStyle, isReo = true})
                end
            end
        end
        
        
        
        if AutoLineUps.FlowState.HasFlow and not AutoLineUps.ReoFlowUsedThisCycle then
            local skill3Name = AutoLineUps.GetReoSkill3Name()
            if skill3Name == "Draconic Shot" then
                local reoFlowCfg = AutoLineUps.StylesConfig["reo_flow"]
                if reoFlowCfg and reoFlowCfg.points[team] then
                    table.insert(configsToUse, {config = reoFlowCfg, name = "reo_flow", isReo = true, isReoFlow = true})
                end
            end
        end
    else
        
        local cfg = AutoLineUps.StylesConfig[style]
        if cfg and cfg.points[team] and not cfg.flow then
            table.insert(configsToUse, {config = cfg, name = style, isReo = false})
        end
        
        
        local flowCfgName = style .. "_flow"
        local flowCfg = AutoLineUps.StylesConfig[flowCfgName]
        if flowCfg and flowCfg.points[team] and flowCfg.flow then
            
            if AutoLineUps.FlowState.HasFlow then
                table.insert(configsToUse, {config = flowCfg, name = flowCfgName, isReo = false})
            end
        end
        
        
        local flow2CfgName = style .. "_flow2"
        local flow2Cfg = AutoLineUps.StylesConfig[flow2CfgName]
        if flow2Cfg and flow2Cfg.points[team] and flow2Cfg.flow then
            
            if AutoLineUps.FlowState.HasFlow then
                table.insert(configsToUse, {config = flow2Cfg, name = flow2CfgName, isReo = false})
            end
        end
    end
    
    local markerIndex = 1
    for _, cfgData in ipairs(configsToUse) do
        local c = cfgData.config
        
        local markerColor = cfgData.isReo and reoMarkerColor or c.markerColor
        for _, pt in ipairs(c.points[team]) do
            local marker = Instance.new("Part")
            marker.Name = "LineUpMarker_" .. markerIndex
            marker.Size = AutoLineUps.Config.markerSize
            marker.Shape = Enum.PartType.Cylinder
            marker.Material = Enum.Material.Neon
            marker.BrickColor = BrickColor.new(markerColor)
            marker.Anchored = true
            marker.CanCollide = false
            marker.CFrame = CFrame.new(pt.targetPosition) * CFrame.Angles(0, 0, math.rad(90))
            marker.Transparency = AutoLineUps.Config.markerTransparency
            marker.Parent = workspace
            
            marker:SetAttribute("configName", cfgData.name)
            marker:SetAttribute("isFlow", c.flow or false)
            marker:SetAttribute("isReo", cfgData.isReo or false)
            AutoLineUps.Markers[markerIndex] = marker
            markerIndex = markerIndex + 1
        end
    end
end



function AutoLineUps.GetActivePoint()
    local char = Player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local style = AutoLineUps.GetStyle()
    local team = AutoLineUps.GetTeam()
    if not style or not team then return nil end
    
    
    local configsToCheck = {}
    local isReo = style == "reo"
    
    
    if isReo then
        local skill4Name = AutoLineUps.GetReoSkill4Name()
        local mappedStyle = skill4Name and AutoLineUps.ReoSkillMapping[skill4Name]
        if mappedStyle then
            local cfg = AutoLineUps.StylesConfig[mappedStyle]
            if cfg and cfg.points[team] then
                
                local reoCfg = {
                    skillName = "skill4",
                    markerColor = cfg.markerColor,
                    requiredKey = cfg.requiredKey,
                    points = cfg.points,
                    flow = cfg.flow,
                    isReo = true
                }
                table.insert(configsToCheck, reoCfg)
            end
        end
        
        
        if AutoLineUps.FlowState.HasFlow and not AutoLineUps.ReoFlowUsedThisCycle then
            local skill3Name = AutoLineUps.GetReoSkill3Name()
            if skill3Name == "Draconic Shot" then
                local reoFlowCfg = AutoLineUps.StylesConfig["reo_flow"]
                if reoFlowCfg and reoFlowCfg.points[team] then
                    local reoFlowCheck = {
                        skillName = "skill3",
                        markerColor = reoFlowCfg.markerColor,
                        requiredKey = reoFlowCfg.requiredKey,
                        points = reoFlowCfg.points,
                        flow = true,
                        isReo = true,
                        isReoFlow = true
                    }
                    table.insert(configsToCheck, reoFlowCheck)
                end
            end
        end
    else
        
        local cfg = AutoLineUps.StylesConfig[style]
        if cfg and cfg.points[team] and not cfg.flow then
            table.insert(configsToCheck, cfg)
        end
        
        
        local flowCfgName = style .. "_flow"
        local flowCfg = AutoLineUps.StylesConfig[flowCfgName]
        if flowCfg and flowCfg.points[team] and flowCfg.flow then
            
            if AutoLineUps.FlowState.HasFlow then
                
                if flowCfg.noEnemyRadius then
                    if not AutoLineUps.HasEnemyNearby(flowCfg.noEnemyRadius) then
                        table.insert(configsToCheck, flowCfg)
                    end
                
                elseif flowCfg.requireEnemyRadius then
                    if AutoLineUps.HasEnemyNearby(flowCfg.requireEnemyRadius) then
                        table.insert(configsToCheck, flowCfg)
                    end
                else
                    table.insert(configsToCheck, flowCfg)
                end
            end
        end
        
        
        local flow2CfgName = style .. "_flow2"
        local flow2Cfg = AutoLineUps.StylesConfig[flow2CfgName]
        if flow2Cfg and flow2Cfg.points[team] and flow2Cfg.flow then
            if AutoLineUps.FlowState.HasFlow then
                
                if flow2Cfg.requireEnemyRadius then
                    if AutoLineUps.HasEnemyNearby(flow2Cfg.requireEnemyRadius) then
                        table.insert(configsToCheck, flow2Cfg)
                    end
                
                elseif flow2Cfg.noEnemyRadius then
                    if not AutoLineUps.HasEnemyNearby(flow2Cfg.noEnemyRadius) then
                        table.insert(configsToCheck, flow2Cfg)
                    end
                else
                    table.insert(configsToCheck, flow2Cfg)
                end
            end
        end
    end
    
    
    for _, c in ipairs(configsToCheck) do
        for _, pt in ipairs(c.points[team]) do
            if (hrp.Position - pt.targetPosition).Magnitude <= AutoLineUps.Config.positionTolerance then
                return pt, c
            end
        end
    end
    return nil
end

function AutoLineUps.LockCharacter()
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hum then
        AutoLineUps.OriginalWalkSpeed = hum.WalkSpeed
        AutoLineUps.OriginalJumpPower = hum.JumpPower
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        hum.PlatformStand = true
    end
    if hrp then hrp.Anchored = true end
    AutoLineUps.Frozen = true
end

function AutoLineUps.UnlockCharacter()
    local char = Player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hum then
        hum.WalkSpeed = AutoLineUps.OriginalWalkSpeed or 16
        hum.JumpPower = AutoLineUps.OriginalJumpPower or 50
        hum.PlatformStand = false
    end
    if hrp then hrp.Anchored = false end
    AutoLineUps.Frozen = false
end

function AutoLineUps.LockMouse()
    if AutoLineUps.MouseLocked then return end
    AutoLineUps.MouseLocked = true
    AutoLineUps.OriginalMouseDelta = Services.UIS.MouseDeltaSensitivity
    Services.UIS.MouseDeltaSensitivity = 0
end

function AutoLineUps.UnlockMouse()
    if not AutoLineUps.MouseLocked then return end
    Services.UIS.MouseDeltaSensitivity = AutoLineUps.OriginalMouseDelta or 1
    AutoLineUps.MouseLocked = false
end

function AutoLineUps.AimCamera(pt)
    local cam = workspace.CurrentCamera
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    AutoLineUps.LockMouse()
    
    local targetLook = Vector3.new(pt.mouseTargetPosition.X, pt.lookAtHeight, pt.mouseTargetPosition.Z)
    local currentPos = hrp.Position
    
    
    local lookDir = (targetLook - currentPos).Unit
    local horizontalDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
    if horizontalDir.Magnitude > 0 then
        hrp.CFrame = CFrame.new(currentPos, currentPos + horizontalDir)
    end
    
    
    for _ = 1, 6 do
        local camPos = cam.CFrame.Position
        local direction = (targetLook - camPos).Unit
        cam.CFrame = CFrame.lookAt(camPos, camPos + direction)
        task.wait(AutoLineUps.Config.aimTime / 6)
    end
    
    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, targetLook)
end

function AutoLineUps.PerformAction(cfg)
    local byteNet = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not byteNet then return false end
    
    local startTime = tick()
    local cooldownDetected = false
    
    
    while tick() - startTime < 1.0 do
        pcall(function()
            byteNet:FireServer(BN_UseBuffer(), {{cfg.skillName}})
        end)
        
        if AutoLineUps.IsSkillOnCooldown(cfg.skillName) then
            cooldownDetected = true
            break
        end
        task.wait(0.03)
    end
    
    return cooldownDetected
end

function AutoLineUps.SafeRestore()
    AutoLineUps.UnlockMouse()
    AutoLineUps.UnlockCharacter()
    AutoLineUps.IsExecuting = false
end

function AutoLineUps.Execute()
    if AutoLineUps.IsExecuting then return end
    local pt, cfg = AutoLineUps.GetActivePoint()
    if not pt or not cfg then return end
    if not HasBall() then return end
    if AutoLineUps.IsSkillOnCooldown(cfg.skillName) then return end
    if tick() - AutoLineUps.LastExecutionTime < 0.3 then return end
    
    AutoLineUps.IsExecuting = true
    AutoLineUps.ExecutionStartTime = tick()
    
    
    local isReoFlowLineup = cfg.isReoFlow
    
    local success = pcall(function()
        local char = Player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        
        AutoLineUps.LockCharacter()
        if hrp then
            hrp.CFrame = CFrame.new(pt.targetPosition)
        end
        task.wait(0.01)
        
        
        AutoLineUps.AimCamera(pt)
        task.wait(0.02)
        
        
        local cooldownDetected = AutoLineUps.PerformAction(cfg)
        
        if cooldownDetected then
            task.wait(AutoLineUps.Config.postSuccessFreeze)
        end
        
        AutoLineUps.LastExecutionTime = tick()
        
        
        if isReoFlowLineup then
            AutoLineUps.ReoFlowUsedThisCycle = true
            AutoLineUps.CreateMarkers()
        end
    end)
    
    AutoLineUps.SafeRestore()
    
    if not success then
        AutoLineUps.SafeRestore()
    end
end

function AutoLineUps.Start()
    if AutoLineUps.Connection then AutoLineUps.Connection:Disconnect() end
    AutoLineUps.Enabled = true
    AutoLineUps.LastFlowState = AutoLineUps.FlowState.HasFlow
    AutoLineUps.CurrentReoSkill = nil
    AutoLineUps.CurrentReoSkill3 = nil
    AutoLineUps.ReoFlowUsedThisCycle = false
    AutoLineUps.CreateMarkers()
    AutoLineUps.Connection = Services.RunService.Heartbeat:Connect(function()
        if not AutoLineUps.Enabled then return end
        
        
        AutoLineUps.UpdateFlowState()
        
        local newTeam = AutoLineUps.GetTeam()
        local newStyle = AutoLineUps.GetStyle()
        local flowChanged = AutoLineUps.FlowState.HasFlow ~= AutoLineUps.LastFlowState
        
        
        local reoSkillChanged = false
        if newStyle == "reo" then
            local newReoSkill4 = AutoLineUps.GetReoSkill4Name()
            local newReoSkill3 = AutoLineUps.GetReoSkill3Name()
            if newReoSkill4 ~= AutoLineUps.CurrentReoSkill or newReoSkill3 ~= AutoLineUps.CurrentReoSkill3 then
                reoSkillChanged = true
                AutoLineUps.CurrentReoSkill = newReoSkill4
                AutoLineUps.CurrentReoSkill3 = newReoSkill3
            end
        end
        
        if newTeam ~= AutoLineUps.CurrentTeam or newStyle ~= AutoLineUps.CurrentStyle or flowChanged or reoSkillChanged then
            AutoLineUps.CurrentTeam = newTeam
            AutoLineUps.CurrentStyle = newStyle
            AutoLineUps.LastFlowState = AutoLineUps.FlowState.HasFlow
            AutoLineUps.CreateMarkers()
        end
        AutoLineUps.Execute()
    end)
    SafeNotify("<font color='#A6BAFF'>[ Auto Line Ups ]</font> Activated!", 2)
end

