function AutoDefense.ProcessAnimationPredict(myTeam, myPos)
    if not AutoDefense.AnimationPredict then return end
    local chars = AD_GetChars()
    if not chars then return end
    local shouldDefend = not AutoDefense.GoalboxOnly or AD_IsInGoalbox(myPos, myTeam)
    if not shouldDefend then return end
    local currentTime = tick()
    for _, targetChar in ipairs(chars:GetChildren()) do
        if targetChar.Name ~= Player.Name and targetChar:FindFirstChild("Ball") then
            local state = targetChar:FindFirstChild("state")
            local targetTeam = state and state:FindFirstChild("team")
            targetTeam = targetTeam and targetTeam.Value
            if targetTeam and targetTeam ~= "lobby" and targetTeam ~= myTeam then
                local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetChar:FindFirstChild("Humanoid")
                local animator = targetHumanoid and targetHumanoid:FindFirstChildOfClass("Animator")
                if targetHRP and animator then
                    local distance = (targetHRP.Position - myPos).Magnitude
                    if distance <= 87 and AD_IsEnemyFacingPlayer(targetHRP, myPos) then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            local animId = track.Animation and track.Animation.AnimationId
                            if animId and track.IsPlaying and AutoDefense.AnimationSet[animId] then
                                local animationDelay = AutoDefense.Animations[animId]
                                local targetPlayer = Services.Players:FindFirstChild(targetChar.Name)
                                if targetPlayer then
                                    local trackingKey = targetPlayer.UserId.."_"..animId
                                    if not AutoDefense.AnimationTracking[trackingKey] then
                                        AutoDefense.AnimationTracking[trackingKey] = {
                                            detectedTime = currentTime, hasTriggered = false, delay = animationDelay
                                        }
                                    end
                                    local animData = AutoDefense.AnimationTracking[trackingKey]
                                    if not animData.hasTriggered and (currentTime - animData.detectedTime) >= animData.delay then
                                        if currentTime - AutoDefense.LastDefenseTime > 6 then
                                            AutoDefense.LastDefenseTime = currentTime
                                            AutoDefense.PerformDefense()
                                            animData.hasTriggered = true
                                        end
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    for trackingKey, data in pairs(AutoDefense.AnimationTracking) do
        if currentTime - data.detectedTime > 5 then AutoDefense.AnimationTracking[trackingKey] = nil end
    end
end

function AutoDefense.ProcessDefense(myTeam, playerPos)
    local currentOwnerTeam = AD_FindBallOwnerTeam()
    if currentOwnerTeam then AutoDefense.lastBallOwnerTeam = currentOwnerTeam end
    if AD_HasBall(Player.Name) then return end
    local ball = Services.Workspace.Terrain:FindFirstChild("Ball") or Services.Workspace:FindFirstChild("Ball")
    if not ball then return end
    local cfBall = AD_GetCFBall()
    local velocity = cfBall and cfBall:FindFirstChild("velocity")
    if not velocity then return end
    local ballVelocity = velocity.Value
    local realSpeed = ballVelocity.Magnitude
    if realSpeed < 200 then return end
    local distanceToBall = (ball.Position - playerPos).Magnitude
    local timeToImpact = distanceToBall / realSpeed
    if timeToImpact > 0.3 then return end
    if not AD_IsBallComingTowardsPlayer(ball, ballVelocity, playerPos) then return end
    if not AD_CanReachBall(ball, playerPos) then return end
    if not AutoDefense.lastBallOwnerTeam or not myTeam then return end
    if AutoDefense.lastBallOwnerTeam == "lobby" or myTeam == "lobby" then return end
    if AutoDefense.lastBallOwnerTeam == myTeam then return end
    local shouldDefend = not AutoDefense.GoalboxOnly or AD_IsInGoalbox(playerPos, myTeam)
    local currentTime = tick()
    if shouldDefend and currentTime - AutoDefense.LastDefenseTime > 6 then
        AutoDefense.LastDefenseTime = currentTime
        AutoDefense.PerformDefense()
    end
end

function AD_Update()
    if not AutoDefense.Enabled or not Player.Character then return end
    if not AD_IsDonLorenzo() then return end
    local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local myTeam = AD_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    local myPos = hrp.Position
    AutoDefense.ProcessDefense(myTeam, myPos)
    AutoDefense.ProcessAnimationPredict(myTeam, myPos)
end

