function AutoCounter.ExtractNumericSoundId(sound)
    if not sound.SoundId then return nil end
    local sid = tostring(sound.SoundId)
    local num = string.match(sid, "rbxassetid://(%d+)") or string.match(sid, "://(%d+)") or string.match(sid, "^(%d+)$")
    return num
end

function AutoCounter.GetSoundWorldPosition(sound)
    local parent = sound.Parent
    if parent and parent:IsA("BasePart") then return parent.Position, parent end
    if parent and parent:IsA("Attachment") then
        local part = parent.Parent
        if part and part:IsA("BasePart") then return part.Position, part end
    end
    return nil, nil
end

function AutoCounter.GetCharacterFromDescendant(inst)
    if not inst then return nil end
    local model = inst:FindFirstAncestorOfClass("Model")
    return model and model:FindFirstChildOfClass("Humanoid") and model
end

function AutoCounter.AttemptCounterForSound(sound)
    if not AutoCounter.Enabled or not HasBall() then return end
    local now = tick()
    if AutoCounter.SoundCooldowns[sound] and now - AutoCounter.SoundCooldowns[sound] < AutoCounter.CounterCooldown then return end
    local soundId = AutoCounter.ExtractNumericSoundId(sound)
    if not soundId or not AutoCounter.CounterSoundIds[soundId] then return end
    local soundPos, soundPart = AutoCounter.GetSoundWorldPosition(sound)
    if not soundPos or not soundPart then return end
    local character = AutoCounter.GetCharacterFromDescendant(soundPart)
    local targetPlayer = character and Services.Players:GetPlayerFromCharacter(character)
    if not targetPlayer then return end
    if not AutoCounter.IsEnemy(targetPlayer) then return end
    local myCharacter = Player.Character
    if not myCharacter then return end
    local myHRP = myCharacter:FindFirstChild("HumanoidRootPart")
    local targetHRP = character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not targetHRP then return end
    local distance = (myHRP.Position - targetHRP.Position).Magnitude
    local isVeryClose = distance <= 11
    if not isVeryClose and distance > AutoCounter.CounterDistance then return end
    if not isVeryClose then
        local targetLookVector = targetHRP.CFrame.LookVector
        local toPlayerVector = (myHRP.Position - targetHRP.Position).Unit
        local dotProduct = targetLookVector:Dot(toPlayerVector)
        local angle = math.acos(math.clamp(dotProduct, -1, 1))
        if angle > math.rad(18) then return end
    end
    local last = AutoCounter.Cooldowns[targetPlayer] or 0
    if now - last < AutoCounter.CounterCooldown then return end
    AutoCounter.Cooldowns[targetPlayer] = now
    AutoCounter.SoundCooldowns[sound] = now
    AutoCounter.PerformCounter()
end

function AutoCounter.HookSound(sound)
    if not sound or not sound:IsA("Sound") or AutoCounter.SoundHooks[sound] then return end
    local playedConn = sound.Played:Connect(function() AutoCounter.AttemptCounterForSound(sound) end)
    local propConn = sound:GetPropertyChangedSignal("IsPlaying"):Connect(function()
        if sound.IsPlaying then AutoCounter.AttemptCounterForSound(sound) end
    end)
    local destroyConn = sound.Destroying:Connect(function()
        playedConn:Disconnect() propConn:Disconnect() destroyConn:Disconnect()
        AutoCounter.SoundHooks[sound] = nil AutoCounter.SoundCooldowns[sound] = nil
    end)
    AutoCounter.SoundHooks[sound] = {playedConn = playedConn, propConn = propConn, destroyConn = destroyConn}
    if sound.IsPlaying then AutoCounter.AttemptCounterForSound(sound) end
end

function AutoCounter.HookCharacterSounds(character)
    local targetPlayer = Services.Players:GetPlayerFromCharacter(character)
    if not targetPlayer or not AutoCounter.IsEnemy(targetPlayer) then return end
    for _, sound in ipairs(character:GetDescendants()) do
        if sound:IsA("Sound") then AutoCounter.HookSound(sound) end
    end
    character.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("Sound") then AutoCounter.HookSound(descendant) end
    end)
end

function AutoCounter.InitializeSoundHooks()
    for _, target in ipairs(Services.Players:GetPlayers()) do
        if AutoCounter.IsEnemy(target) and target.Character then
            AutoCounter.HookCharacterSounds(target.Character)
        end
    end
    Services.Players.PlayerAdded:Connect(function(newPlayer)
        newPlayer.CharacterAdded:Connect(function(character)
            if AutoCounter.Enabled and AutoCounter.IsEnemy(newPlayer) then AutoCounter.HookCharacterSounds(character) end
        end)
    end)
end

function AutoCounter.CleanupSoundHooks()
    for sound, hooks in pairs(AutoCounter.SoundHooks) do
        for _, conn in pairs(hooks) do pcall(function() conn:Disconnect() end) end
    end
    AutoCounter.SoundHooks = {} AutoCounter.SoundCooldowns = {}
end

function AutoCounter.IsEnemy(targetPlayer)
    if targetPlayer == Player then return false end
    local myTeam = GetPlayerTeam(Player.Name)
    if not myTeam or myTeam == "lobby" then return false end
    local targetTeam = GetPlayerTeam(targetPlayer.Name)
    if not targetTeam or targetTeam == "lobby" then return false end
    return myTeam ~= targetTeam
end

function AutoCounter.PerformCounter()
    if AutoCounter.Mode == 2 then
        pcall(function()
            Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
        end)
    else
        local style = Player:GetAttribute("style")
        local counterSkill = AutoCounter.CharacterCounterSkills[style]
        
        
        if style == "sae" then
            if AutoCounter.IsSaeReflexMode() then
                
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
                end)
            elseif not IsSkillOnCooldown("skill2") then
                
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"skill2"}})
                end)
            else
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
                end)
            end
        
        elseif style == "reo" then
            if AutoCounter.HasCrossElastico() and not IsSkillOnCooldown("skill2") then
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"skill2"}})
                end)
            else
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
                end)
            end
        
        elseif style == "masterylorenzo" then
            if AutoCounter.IsMasteryLorenzoAnimationPlaying() then
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"Tspecialer"}})
                end)
            else
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
                end)
            end
        
        elseif style == "hiori" then
            if AutoCounter.IsHioriAnimationPlaying() then
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"Tspecialer"}})
                end)
            else
                pcall(function()
                    Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
                end)
            end
        
        elseif style == "barou" and AutoCounter.IsBarouSpecialAnimationPlaying() then
            pcall(function()
                Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"Tspecialer"}})
            end)
        elseif counterSkill and not IsSkillOnCooldown(counterSkill) then
            pcall(function()
                Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{counterSkill}})
            end)
            
            if style == "kaiser" or style == "nelisagi" then
                AutoCounter.MarkSkillAsUsed(style, counterSkill)
            end
        else
            pcall(function()
                Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"dribble", false}})
            end)
        end
    end
end

function AutoCounter.UpdateEnemyCache()
    local currentTime = tick()
    if currentTime - AutoCounter.LastCacheUpdate < AutoCounter.CacheUpdateInterval then return end
    AutoCounter.LastCacheUpdate = currentTime
    local myTeam = GetPlayerTeam(Player.Name)
    if not myTeam or myTeam == "lobby" then return end
    
    for _, target in ipairs(Services.Players:GetPlayers()) do
        if target ~= Player then
            local targetTeam = GetPlayerTeam(target.Name)
            local isEnemy = targetTeam and targetTeam ~= "lobby" and targetTeam ~= myTeam
            if not AutoCounter.EnemyCache[target] then
                AutoCounter.EnemyCache[target] = {isEnemy = isEnemy, character = target.Character, hrp = nil, humanoid = nil, animator = nil, lastSeen = currentTime}
            else
                local cache = AutoCounter.EnemyCache[target]
                cache.isEnemy = isEnemy
                cache.character = target.Character
                if not cache.character then cache.hrp = nil cache.humanoid = nil cache.animator = nil end
                cache.lastSeen = currentTime
            end
        end
    end
end

function AutoCounter.GetOrUpdateAnimator(enemyData)
    if not enemyData.character then return nil end
    if enemyData.animator and enemyData.animator:IsDescendantOf(enemyData.character) then return enemyData.animator end
    if not enemyData.humanoid or not enemyData.humanoid:IsDescendantOf(enemyData.character) then
        enemyData.humanoid = enemyData.character:FindFirstChild("Humanoid")
    end
    if enemyData.humanoid then enemyData.animator = enemyData.humanoid:FindFirstChildOfClass("Animator") else enemyData.animator = nil end
    return enemyData.animator
end

function AutoCounter.ShouldCounter(target, targetHRP, playerPosition, track)
    if not targetHRP then return false end
    local distance = (playerPosition - targetHRP.Position).Magnitude
    local animationId = track.Animation.AnimationId
    if AutoCounter.CloseRangeAnimations[animationId] then 
        if distance > 39 then return false end
    else 
        local isVeryClose = distance <= 11
        if not isVeryClose and distance > AutoCounter.CounterDistance then return false end 
    end
    if distance > 11 then
        local targetLookVector = targetHRP.CFrame.LookVector
        local toPlayerVector = (playerPosition - targetHRP.Position).Unit
        local dotProduct = targetLookVector:Dot(toPlayerVector)
        local angle = math.acos(math.clamp(dotProduct, -1, 1))
        if angle > math.rad(18) then return false end
    end
    return true
end

function AutoCounter.ProcessAnimationCounter()
    if not AutoCounter.Enabled or not HasBall() then return end
    local character = Player.Character if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart") if not humanoidRootPart then return end
    local playerPosition = humanoidRootPart.Position
    local now = tick()
    AutoCounter.UpdateEnemyCache()
    
    
    if AutoCounter.CheckBarouTspecialer() then return end
    
    for target, enemyData in pairs(AutoCounter.EnemyCache) do
        if enemyData.isEnemy then
            local last = AutoCounter.Cooldowns[target]
            if not last or now - last >= AutoCounter.CounterCooldown then
                if enemyData.character and enemyData.character.Parent then
                    if not enemyData.hrp or not enemyData.hrp:IsDescendantOf(enemyData.character) then
                        enemyData.hrp = enemyData.character:FindFirstChild("HumanoidRootPart")
                    end
                    local targetHRP = enemyData.hrp
                    if targetHRP then
                        local distance = (playerPosition - targetHRP.Position).Magnitude
                        local isVeryClose = distance <= 11
                        if isVeryClose or distance <= AutoCounter.CounterDistance then
                            local animator = AutoCounter.GetOrUpdateAnimator(enemyData)
                            if animator then
                                local tracks = animator:GetPlayingAnimationTracks()
                                if #tracks > 0 then
                                    for _, track in ipairs(tracks) do
                                        if track.IsPlaying and AutoCounter.CounterAnimationIds[track.Animation.AnimationId] then
                                            if AutoCounter.ShouldCounter(target, targetHRP, playerPosition, track) then
                                                AutoCounter.Cooldowns[target] = now
                                                AutoCounter.PerformCounter()
                                                return
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                else
                    AutoCounter.EnemyCache[target] = nil
                end
            end
        end
    end
end

function AutoCounter.SwitchMode()
    AutoCounter.Mode = AutoCounter.Mode == 1 and 2 or 1
    local modeName = AutoCounter.Mode == 1 and "Auto-Counter" or "Auto-Dribble"
    
    if UIState and UIState.CounterModeComboBox and UIState.CounterModeComboBox.SetValue then
        UIState.CounterModeComboBox:SetValue(modeName)
        
        if Menu.Config and Menu.Config.saveConfig then
            pcall(function() Menu.Config.saveConfig("EvoHub") end)
        end
    end
    SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Mode: " .. modeName, 2)
end

function AutoCounter.Start()
    if AutoCounter.Connection then AutoCounter.Connection:Disconnect() end
    AutoCounter.Connection = Services.RunService.Heartbeat:Connect(AutoCounter.ProcessAnimationCounter)
    AutoCounter.UpdateEnemyCache()
    AutoCounter.InitializeSoundHooks()
    AutoCounter.StartFlowTracking()
    SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Activated!", 2)
end

function AutoCounter.Stop()
    if AutoCounter.Connection then AutoCounter.Connection:Disconnect() AutoCounter.Connection = nil end
    AutoCounter.CleanupSoundHooks()
    AutoCounter.StopFlowTracking()
    AutoCounter.EnemyCache = {}
    AutoCounter.AnimationStartData = {}
    AutoCounter.Cooldowns = {}
    SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Deactivated!", 2)
end



