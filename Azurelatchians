function CreateCameraDirectionBuff(name, style, animationIds, defaultDistance)
    local buff = {Enabled = false, Distance = defaultDistance or 2, Connections = {}, AnimationConnection = nil, TeleportThread = nil, IsTeleporting = false, Style = style, Name = name, Camera = workspace.CurrentCamera}
    local animIds = type(animationIds) == "table" and animationIds or {tostring(animationIds)}
    local function getCameraBasedDirection()
        if not Player.Character then return Vector3.new(0, 0, 1) end
        local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return Vector3.new(0, 0, 1) end
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude < 0.1 then return buff.Camera and buff.Camera.CFrame.LookVector or hrp.CFrame.LookVector end
        if buff.Camera then
            local camLook, camRight = buff.Camera.CFrame.LookVector, buff.Camera.CFrame.RightVector
            local fDot, rDot = moveDir:Dot(camLook), moveDir:Dot(camRight)
            if math.abs(fDot) > math.abs(rDot) then return fDot > 0 and camLook or -camLook else return rDot > 0 and camRight or -camRight end
        end
        return moveDir.Unit
    end
    local function teleport()
        if not buff.Enabled or not Player.Character then return end
        local hrp = Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
        local dir = getCameraBasedDirection()
        dir = Vector3.new(dir.X, 0, dir.Z).Unit
        local newPos = hrp.Position + (dir * buff.Distance)
        hrp.CFrame = CFrame.new(newPos, newPos + hrp.CFrame.LookVector)
    end
    local maxDuration = 3.5
    local function startTeleport()
        if buff.IsTeleporting then return end
        if buff.TeleportThread then task.cancel(buff.TeleportThread) end
        buff.IsTeleporting = true
        local startTime = tick()
        buff.TeleportThread = task.spawn(function()
            while buff.IsTeleporting and buff.Enabled do
                if tick() - startTime >= maxDuration then buff.IsTeleporting = false break end
                teleport()
                task.wait(0.05)
            end
            buff.IsTeleporting = false
        end)
    end
    local function stopTeleport() buff.IsTeleporting = false if buff.TeleportThread then task.cancel(buff.TeleportThread) buff.TeleportThread = nil end end
    local function isTargetAnim(animId) for _, id in ipairs(animIds) do if tostring(animId):find(tostring(id)) then return true end end return false end
    local function onAnimPlayed(track)
        if not buff.Enabled or not track.Animation then return end
        if style and Player:GetAttribute("style") ~= style then return end
        if isTargetAnim(track.Animation.AnimationId) then
            startTeleport()
            local conn conn = track.Stopped:Connect(function() stopTeleport() conn:Disconnect() end)
        end
    end
    local function setup()
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() end
        if not buff.Enabled or not Player.Character then return end
        local hum = Player.Character:FindFirstChild("Humanoid") if not hum then return end
        buff.AnimationConnection = hum.AnimationPlayed:Connect(onAnimPlayed)
    end
    function buff.Start()
        if buff.Enabled then return end buff.Enabled = true buff.Camera = workspace.CurrentCamera
        table.insert(buff.Connections, Player.CharacterAdded:Connect(function(c) c:WaitForChild("Humanoid") task.wait(0.5) if buff.Enabled then setup() end end))
        if Player.Character then setup() end
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Activated!", 2)
    end
    function buff.Stop()
        buff.Enabled = false stopTeleport()
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        for _, c in ipairs(buff.Connections) do pcall(function() c:Disconnect() end) end buff.Connections = {}
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Deactivated!", 2)
    end
    return buff
end



function CreateSideDirectionBuff(name, styles, rightAnimIds, leftAnimIds, defaultDistance, distanceMultiplier)
    local mult = distanceMultiplier or 4
    
    local styleList = type(styles) == "table" and styles or {styles}
    
    local rightAnims = type(rightAnimIds) == "table" and rightAnimIds or {rightAnimIds}
    local leftAnims = type(leftAnimIds) == "table" and leftAnimIds or {leftAnimIds}
    
    local buff = {Enabled = false, Distance = defaultDistance or 5, DistanceMultiplier = mult, Connections = {}, AnimationConnection = nil, TeleportConnection = nil, IsTeleporting = false, Styles = styleList, Name = name}
    
    local function isValidStyle()
        local currentStyle = Player:GetAttribute("style")
        for _, s in ipairs(styleList) do
            if currentStyle == s then return true end
        end
        return false
    end
    
    local function smoothTeleportSide(direction)
        if buff.IsTeleporting or not buff.Enabled or not Player.Character then return end
