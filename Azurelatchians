    local ball = AutoVariantSteal.GetBall()
    if ball and (root.Position - ball.Position).Magnitude <= radius then return true end
    for _, otherPlayer in ipairs(Services.Players:GetPlayers()) do
        if otherPlayer ~= Player then
            local otherChar = otherPlayer.Character
            if otherChar then
                local otherTeam = AutoVariantSteal.GetPlayerTeam(otherPlayer.Name)
                if otherTeam and otherTeam ~= myTeam then
                    local otherBall = otherChar:FindFirstChild("Ball")
                    if otherBall and (root.Position - otherBall.Position).Magnitude <= radius then return true end
                end
            end
        end
    end
    return false
end

