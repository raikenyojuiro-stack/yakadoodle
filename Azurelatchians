function ShotBeam.HasBall()
    local chars = Services.Workspace:WaitForChild("characters")
    local char = chars:FindFirstChild(Player.Name)
    return char and char:FindFirstChild("Ball")
end

function ShotBeam.GetPlayerPosition()
    local character = Player.Character
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    return hrp.Position
end

function ShotBeam.GetMyTeam()
    local chars = Services.Workspace:FindFirstChild("characters")
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return nil end
    local state = myChar:FindFirstChild("state")
    return state and state:FindFirstChild("team") and state.team.Value or nil
end

function ShotBeam.IsInEnemyGoalbox(position, myTeam)
    local enemyGoalbox = ShotBeam.Goalboxes[myTeam == "A" and "B" or "A"]
    if not enemyGoalbox then return false end
    return position.X >= enemyGoalbox.minX and position.X <= enemyGoalbox.maxX and
           position.Z >= enemyGoalbox.minZ and position.Z <= enemyGoalbox.maxZ
end

function ShotBeam.SimplifyTrajectory(positions, maxPoints)
    if #positions <= maxPoints then return positions end
    local simplified = {}
    local step = math.floor(#positions / maxPoints)
    for i = 1, #positions, step do
        table.insert(simplified, positions[i])
    end
    if simplified[#simplified] ~= positions[#positions] then
        table.insert(simplified, positions[#positions])
    end
    return simplified
end

function ShotBeam.CreateBeamSegment(startPos, endPos)
    local part = Instance.new("Part")
    part.Name = "ShotBeamPart"
    part.Material = Enum.Material.Neon
    part.Color = ShotBeam.BeamColor
    part.Transparency = ShotBeam.BeamTransparency
    part.Anchored = true
    part.CanCollide = false
    part.CastShadow = false
    local distance = (endPos - startPos).Magnitude
    part.Size = Vector3.new(ShotBeam.BeamWidth, ShotBeam.BeamWidth, distance)
    part.CFrame = CFrame.new((startPos + endPos) / 2, endPos)
    part.Parent = Services.Workspace.Terrain
    table.insert(ShotBeam.BeamParts, part)
    return part
end

function ShotBeam.ClearBeams()
    for _, part in ipairs(ShotBeam.BeamParts) do
        pcall(function() part:Destroy() end)
    end
    ShotBeam.BeamParts = {}
end

function ShotBeam.UpdateBeam()
    if not ShotBeam.Enabled then return end
    
    local currentStyle = Player:GetAttribute("style")
    if currentStyle ~= "kaiser" and currentStyle ~= "sae" and currentStyle ~= "yukimiya" and currentStyle ~= "rin" then
        ShotBeam.ClearBeams()
        return
    end
    if not ShotBeam.HasBall() then
        ShotBeam.ClearBeams()
        return
    end
    
    if ShotBeam.OnlyNearEnemyGoalBox then
        local myTeam = ShotBeam.GetMyTeam()
        if myTeam and myTeam ~= "lobby" then
            local character = Player.Character
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not ShotBeam.IsInEnemyGoalbox(hrp.Position, myTeam) then
                        ShotBeam.ClearBeams()
                        return
                    end
                end
            end
        end
    end
    
    if not ShotBeam.TrajectoryData or not ShotBeam.TrajectoryData.positions then
        return
    end
    local character = Player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    ShotBeam.ClearBeams()
    
    local positions = ShotBeam.TrajectoryData.positions
    local simplified = ShotBeam.SimplifyTrajectory(positions, ShotBeam.MaxPoints)
    if #simplified < 2 then return end
    
    local ballStartPos = ShotBeam.TrajectoryData.ballStartPos
    local originalPlayerPos = ShotBeam.TrajectoryData.playerStartPos
    local originalLookDirection = ShotBeam.TrajectoryData.playerStartLookDirection
    if not ballStartPos or not originalLookDirection then
        return
    end
    
    local playerPos = hrp.Position
    local currentLookVector = hrp.CFrame.LookVector
    local currentDirection = Vector3.new(currentLookVector.X, 0, currentLookVector.Z).Unit
    
    local originalAngle = math.atan2(originalLookDirection.Z, originalLookDirection.X)
    local currentAngle = math.atan2(currentDirection.Z, currentDirection.X)
    local rotationAngle = currentAngle - originalAngle
    
    local function rotatePointAround(point, angle, pivot)
        local cos = math.cos(angle)
        local sin = math.sin(angle)
        local relX = point.X - pivot.X
        local relZ = point.Z - pivot.Z
        local rotX = relX * cos - relZ * sin
        local rotZ = relX * sin + relZ * cos
        return Vector3.new(rotX + pivot.X, point.Y, rotZ + pivot.Z)
    end
    
    local transformedPoints = {}
    for _, pos in ipairs(simplified) do
        local rotated = rotatePointAround(pos, rotationAngle, ballStartPos)
        local offset = Vector3.new(playerPos.X - originalPlayerPos.X, 0, playerPos.Z - originalPlayerPos.Z)
        local finalPos = Vector3.new(rotated.X + offset.X, ShotBeam.BeamHeight, rotated.Z + offset.Z)
        table.insert(transformedPoints, finalPos)
    end
    
    if currentStyle == "kaiser" then
        ShotBeam.BeamColor = Color3.fromRGB(148, 242, 240)
    elseif currentStyle == "sae" then
        ShotBeam.BeamColor = Color3.fromRGB(181, 60, 102)
    elseif currentStyle == "yukimiya" then
        ShotBeam.BeamColor = Color3.fromRGB(255, 215, 0)
    elseif currentStyle == "rin" then
        ShotBeam.BeamColor = Color3.fromRGB(0, 255, 127)
    end
    
    for i = 1, #transformedPoints - 1 do
        ShotBeam.CreateBeamSegment(transformedPoints[i], transformedPoints[i + 1])
    end
end

function ShotBeam.LoadTrajectoryFromJSON(jsonString)
    local success, decoded = pcall(function()
        return Services.HttpService:JSONDecode(jsonString)
    end)
    if not success or not decoded then
        return false
    end
    
    local data = decoded
    if typeof(decoded) == "table" and decoded[1] then
        data = decoded[1]
    end
    
    if not data.positions then
        return false
    end
    
    local positions = {}
    for _, pos in ipairs(data.positions) do
        table.insert(positions, Vector3.new(pos.X, data.beamHeight or 2, pos.Z))
    end
    ShotBeam.TrajectoryData = {
        positions = positions,
        playerStartPos = data.playerStartPos and Vector3.new(data.playerStartPos.X, data.playerStartPos.Y, data.playerStartPos.Z) or Vector3.new(0, 0, 0),
        ballStartPos = data.ballStartPos and Vector3.new(data.ballStartPos.X, data.ballStartPos.Y, data.ballStartPos.Z) or nil,
        playerStartLookDirection = data.playerStartLookDirection and Vector3.new(data.playerStartLookDirection.X, 0, data.playerStartLookDirection.Z).Unit or nil,
        beamHeight = data.beamHeight or 2
    }
    return true
end

function ShotBeam.OnHeartbeat()
    ShotBeam.UpdateBeam()
end

function ShotBeam.Start()
    if ShotBeam.Connection then
        ShotBeam.Connection:Disconnect()
    end
    ShotBeam.Enabled = true
    ShotBeam.Connection = Services.RunService.Heartbeat:Connect(ShotBeam.OnHeartbeat)
    task.spawn(function()
        task.wait(0.5)
        local currentStyle = Player:GetAttribute("style")
        if currentStyle and TRAJECTORY_DATA[currentStyle] then
            ShotBeam.LoadTrajectoryFromJSON(TRAJECTORY_DATA[currentStyle])
            SafeNotify("<font color='#94F2F0'>[ Shot Predictor ]</font> Activated for " .. currentStyle:upper() .. "!", 2)
        else
            SafeNotify("<font color='#94F2F0'>[ Shot Predictor ]</font> Activated! (No trajectory for current style)", 2)
        end
        Player:GetAttributeChangedSignal("style"):Connect(function()
            local newStyle = Player:GetAttribute("style")
            if newStyle and TRAJECTORY_DATA[newStyle] then
                ShotBeam.LoadTrajectoryFromJSON(TRAJECTORY_DATA[newStyle])
            else
                ShotBeam.ClearBeams()
            end
        end)
    end)
end

function ShotBeam.Stop()
    ShotBeam.Enabled = false
    if ShotBeam.Connection then
        ShotBeam.Connection:Disconnect()
        ShotBeam.Connection = nil
    end
    ShotBeam.ClearBeams()
    SafeNotify("<font color='#94F2F0'>[ Shot Predictor ]</font> Deactivated!", 2)
end



