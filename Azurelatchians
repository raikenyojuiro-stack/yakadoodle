function OldLorenzoVoiceLines.GetSound(soundName)
    local success, sound = pcall(function()
        return Services.ReplicatedStorage.Resources.donlorenzo[soundName]
    end)
    if success and sound and sound:IsA("Sound") then
        return sound
    end
    return nil
end

function OldLorenzoVoiceLines.ReplaceSounds()
    for _, replacement in ipairs(OldLorenzoVoiceLines.SoundReplacements) do
        task.spawn(function()
            local sound = OldLorenzoVoiceLines.GetSound(replacement.path)
            if not sound then return end
            
            
            if not OldLorenzoVoiceLines.OriginalSoundIds[replacement.path] then
                OldLorenzoVoiceLines.OriginalSoundIds[replacement.path] = sound.SoundId
            end
            
            
            local success, err = pcall(function()
                local data = game:HttpGet(replacement.url, true)
                writefile(replacement.filename, data)
                
                local getasset = getcustomasset or getsynasset
                if not getasset then
                    warn("[Old Lorenzo VoiceLines] Executor missing getcustomasset/getsynasset")
                    return
                end
                
                sound.SoundId = getasset(replacement.filename)
            end)
            
            if not success then
                warn("[Old Lorenzo VoiceLines] Failed to replace " .. replacement.path .. ": " .. tostring(err))
            end
        end)
    end
end

function OldLorenzoVoiceLines.RestoreSounds()
    for soundName, originalId in pairs(OldLorenzoVoiceLines.OriginalSoundIds) do
        local sound = OldLorenzoVoiceLines.GetSound(soundName)
        if sound then
            sound.SoundId = originalId
        end
    end
    
    
    for _, replacement in ipairs(OldLorenzoVoiceLines.SoundReplacements) do
        pcall(function()
            if isfile and isfile(replacement.filename) then
                delfile(replacement.filename)
            end
        end)
    end
end

function OldLorenzoVoiceLines.Start()
    OldLorenzoVoiceLines.Enabled = true
    OldLorenzoVoiceLines.ReplaceSounds()
    SafeNotify("<font color='#A6BAFF'>[ Old Lorenzo VoiceLines ]</font> Activated!", 2)
end

function OldLorenzoVoiceLines.Stop()
    OldLorenzoVoiceLines.Enabled = false
    OldLorenzoVoiceLines.RestoreSounds()
    SafeNotify("<font color='#A6BAFF'>[ Old Lorenzo VoiceLines ]</font> Deactivated!", 2)
end


