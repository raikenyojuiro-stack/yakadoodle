    pcall(function() Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"tackle"}}) end)
    AutoLegitTackle.LastPressTime = now
end

function AutoLegitTackle.ProcessTackle()
    if not AutoLegitTackle.Enabled then return end
    local now = tick()
    local myTeam = AutoLegitTackle.GetPlayerTeam(Player.Name)
    if myTeam == "lobby" then return end
    local myChar = Player.Character
    if not myChar then return end
    local hum = myChar:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end
    local currentEnemies = {}
    for _, plr in ipairs(Services.Players:GetPlayers()) do
        if plr ~= Player then
            local otherTeam = AutoLegitTackle.GetPlayerTeam(plr.Name)
            if otherTeam ~= "lobby" and otherTeam ~= myTeam then
                if AutoLegitTackle.HasBall(plr.Name) and not AutoLegitTackle.HasIframe(plr.Name) then
                    local otherChar = Services.Workspace.characters:FindFirstChild(plr.Name)
                    if otherChar and AutoLegitTackle.ShouldPressSkill(otherChar) then
                        currentEnemies[plr.Name] = true
                        if not AutoLegitTackle.CheckNoQAnimation(otherChar) then
                            if AutoLegitTackle.CheckImmediateAnimation(otherChar) then
                                AutoLegitTackle.PressTackle()
                            else
                                local state = AutoLegitTackle.PlayerStates[plr.Name]
                                local isDribbling = AutoLegitTackle.CheckDribbleAnimation(otherChar)
                                if not state then
                                    state = {
                                        state = "waiting", startTime = now, lastDribbleTime = 0, hasDribbled = false,
                                        isCurrentlyDribbling = false, dribbleEnded = false, dribbleEndTime = 0
                                    }
                                    AutoLegitTackle.PlayerStates[plr.Name] = state
                                end
                                if isDribbling and not state.isCurrentlyDribbling then
                                    state.isCurrentlyDribbling = true
                                    state.hasDribbled = true
                                    state.lastDribbleTime = now
                                    state.state = "dribbling"
                                    state.dribbleEnded = false
                                elseif not isDribbling and state.isCurrentlyDribbling then
                                    state.isCurrentlyDribbling = false
                                    state.dribbleEnded = true
                                    state.dribbleEndTime = now
                                end
                                if state.hasDribbled and (now - state.lastDribbleTime) < ALT_DRIBBLE_COOLDOWN then
                                    state.state = "cooldown"
                                elseif state.hasDribbled and (now - state.lastDribbleTime) >= ALT_DRIBBLE_COOLDOWN then
                                    state.hasDribbled = false
                                    state.state = "waiting"
                                    state.startTime = now
                                    state.dribbleEnded = false
                                    state.dribbleEndTime = 0
                                end
                                if state.state == "dribbling" then
                                    if state.dribbleEnded and (now - state.dribbleEndTime) >= ALT_AFTER_DRIBBLE_DELAY then
                                        AutoLegitTackle.PressTackle()
                                        state.state = "cooldown"
                                        state.dribbleEnded = false
                                    end
                                elseif state.state == "cooldown" then
                                    AutoLegitTackle.PressTackle()
                                elseif state.state == "waiting" then
                                    if (now - state.startTime) >= ALT_WAIT_TIME_NO_DRIBBLE then
                                        AutoLegitTackle.PressTackle()
                                        state.startTime = now
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    for name in pairs(AutoLegitTackle.PlayerStates) do
        if not currentEnemies[name] then AutoLegitTackle.PlayerStates[name] = nil end
    end
end

function AutoLegitTackle.Start()
    AutoLegitTackle.Enabled = true
    AutoLegitTackle.Connection = Services.RunService.Heartbeat:Connect(AutoLegitTackle.ProcessTackle)
    SafeNotify("<font color='#A6BAFF'>[ Auto Legit Tackle ]</font> Activated!", 2)
