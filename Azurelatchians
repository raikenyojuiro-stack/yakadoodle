        if buff.TeleportConnection then buff.TeleportConnection:Disconnect() buff.TeleportConnection = nil end
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        for _, c in ipairs(buff.Connections) do pcall(function() c:Disconnect() end) end buff.Connections = {}
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Deactivated!", 2)
    end
    return buff
