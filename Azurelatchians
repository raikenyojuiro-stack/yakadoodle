function AD_FindByte() return Services.ReplicatedStorage:FindFirstChild("ByteNetReliable") end
function AD_HasBall()
    local chars = Services.Workspace:WaitForChild("characters")
    local char = chars:FindFirstChild(Player.Name)
    return char and char:FindFirstChild("Ball")
end

function AirDribble.PerformAutoJump()
    if not AirDribble.AutoJumpEnabled then return end
    
    local character = Player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    
    local waitStart = tick()
    local maxWait = 1
    while tick() - waitStart < maxWait do
        local humanoidState = humanoid:GetState()
        
        
        if humanoidState == Enum.HumanoidStateType.Landed or
           humanoidState == Enum.HumanoidStateType.Running or
           humanoidState == Enum.HumanoidStateType.RunningNoPhysics then
            
            task.wait(0.03)
            Services.VIM:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.025)
            Services.VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            return
        end
        
        task.wait(0.05)
    end
end

function AirDribble.PlayAnim()
    if AirDribble.CurrentTrack then AirDribble.CurrentTrack:Stop() end
    local char = Player.Character if not char then return end
    local humanoid = char:FindFirstChild("Humanoid") if not humanoid then return end
    local Anim = Instance.new("Animation")
    Anim.AnimationId = "rbxassetid://76587445975710"
    AirDribble.CurrentTrack = humanoid:LoadAnimation(Anim)
    AirDribble.CurrentTrack:Play()
    AirDribble.IsPlayingAnimation = true
    AirDribble.JumpAfterKick = true
    task.delay(AirDribble.AnimationDuration, function()
        if AirDribble.Enabled then AirDribble.IsPlayingAnimation = false end
    end)
end

function AirDribble.StopAnim()
    if AirDribble.CurrentTrack then AirDribble.CurrentTrack:Stop() AirDribble.CurrentTrack = nil end
    AirDribble.IsPlayingAnimation = false
    AirDribble.JumpAfterKick = false
end

function AirDribble.ExecuteDribble()
    if not AirDribble.Enabled then return end
    local currentTime = tick()
    if currentTime - AirDribble.LastExecution < AirDribble.ExecutionDelay then return end
    local character = Player.Character if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart") if not humanoidRootPart then return end
    if not AD_HasBall() then AirDribble.StopAnim() return end
    
    AirDribble.PlayAnim()
    local kickVec = humanoidRootPart.CFrame.LookVector + Vector3.new(0, 1, 0) * 50
    local byteNet = AD_FindByte()
    
    if byteNet then
        pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"kick", 29, false, kickVec}}) end)
        
        
        if AirDribble.AutoJumpEnabled then
            task.spawn(function()
                task.wait(0.25)
                AirDribble.PerformAutoJump()
            end)
        end
    end
    
    AirDribble.LastExecution = currentTime
end

function AirDribble.CheckKeyHold()
    while AirDribble.Enabled and AirDribble.IsKeyHeld do
        
        if AD_IsCutsceneActive() then
            task.wait(0.1)
        elseif AD_HasBall() and not AirDribble.IsPlayingAnimation then
            AirDribble.ExecuteDribble() 
        end
        task.wait(0.05)
    end
end

function AD_HandleInput(input, gameProcessed)
    if gameProcessed or not AirDribble.Enabled then return end
    
    if AD_IsCutsceneActive() then return end
    if input.KeyCode == AirDribble.CurrentKey then
        if input.UserInputState == Enum.UserInputState.Begin then
            AirDribble.IsKeyHeld = true
            AirDribble.IsActive = true
            task.spawn(AirDribble.CheckKeyHold)
        elseif input.UserInputState == Enum.UserInputState.End then
            AirDribble.IsKeyHeld = false
            AirDribble.IsActive = false
        end
    end
end

function AirDribble.Start()
    if AirDribble.Connection then AirDribble.Connection:Disconnect() end
    if AirDribble.InputConnection then AirDribble.InputConnection:Disconnect() AirDribble.InputConnection = nil end
    if AirDribble.InputEndConnection then AirDribble.InputEndConnection:Disconnect() AirDribble.InputEndConnection = nil end
    AirDribble.Enabled = true
    AirDribble.IsPlayingAnimation = false
    AirDribble.JumpAfterKick = true
    AirDribble.IsKeyHeld = false
    AirDribble.Connection = Services.RunService.Heartbeat:Connect(function() end)
    AirDribble.InputConnection = Services.UIS.InputBegan:Connect(AD_HandleInput)
    AirDribble.InputEndConnection = Services.UIS.InputEnded:Connect(AD_HandleInput)
    SafeNotify("<font color='#A6BAFF'>[ Air Dribble ]</font> Activated! HOLD " .. tostring(AirDribble.CurrentKey):gsub("Enum.KeyCode.", ""), 2)
end

function AirDribble.Stop()
    AirDribble.Enabled = false
    AirDribble.IsActive = false
    AirDribble.IsPlayingAnimation = false
    AirDribble.JumpAfterKick = false
    AirDribble.IsKeyHeld = false
    if AirDribble.Connection then AirDribble.Connection:Disconnect() AirDribble.Connection = nil end
    if AirDribble.InputConnection then AirDribble.InputConnection:Disconnect() AirDribble.InputConnection = nil end
    if AirDribble.InputEndConnection then AirDribble.InputEndConnection:Disconnect() AirDribble.InputEndConnection = nil end
    AirDribble.StopAnim()
    SafeNotify("<font color='#A6BAFF'>[ Air Dribble ]</font> Deactivated!", 2)
end



