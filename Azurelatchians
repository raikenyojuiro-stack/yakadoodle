function CreateHeightBuff(name, style, animationId, defaultHeight, heightMultiplier)
    local buff = {
        Enabled = false,
        Height = defaultHeight or 10,
        HeightMultiplier = heightMultiplier or 3,
        Connections = {},
        AnimationConnection = nil,
        RiseConnection = nil,
        IsRising = false,
        TargetAnimationId = tostring(animationId),
        Style = style,
        Name = name
    }
    
    local function startRising()
        if buff.IsRising or not buff.Enabled or not Player.Character then return end
        local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        buff.IsRising = true
        local startPosition = hrp.Position
        local startCFrame = hrp.CFrame
        local startTime = tick()
        local lookVector = startCFrame.LookVector
        local forwardVector = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
        local actualHeight = buff.Height * buff.HeightMultiplier
        local targetPosition = startPosition + Vector3.new(0, actualHeight, 0) + (forwardVector * 19)
        local riseDuration = 0.35
        
        if buff.RiseConnection then buff.RiseConnection:Disconnect() end
        
        buff.RiseConnection = Services.RunService.Heartbeat:Connect(function()
            if not buff.Enabled or not buff.IsRising then
                if buff.RiseConnection then buff.RiseConnection:Disconnect() buff.RiseConnection = nil end
                return
            end
            local elapsed = tick() - startTime
            local alpha = math.min(elapsed / riseDuration, 1)
            local smoothAlpha = 1 - (1 - alpha) * (1 - alpha)
            local newPosition = startPosition:Lerp(targetPosition, smoothAlpha)
            hrp.CFrame = CFrame.new(newPosition, newPosition + lookVector)
            if alpha >= 1 then
                buff.IsRising = false
                if buff.RiseConnection then buff.RiseConnection:Disconnect() buff.RiseConnection = nil end
            end
        end)
    end
    
    local function onAnimationPlayed(track)
        if not buff.Enabled or not track.Animation then return end
        local animId = tostring(track.Animation.AnimationId)
        if animId:find(buff.TargetAnimationId) then
            startRising()
        end
    end
    
    local function setupListener()
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        if not buff.Enabled or not Player.Character then return end
        local humanoid = Player.Character:FindFirstChild("Humanoid")
        if not humanoid then return end
        buff.AnimationConnection = humanoid.AnimationPlayed:Connect(onAnimationPlayed)
    end
    
    function buff.Start()
        if buff.Enabled then return end
        buff.Enabled = true
        local charConn = Player.CharacterAdded:Connect(function(char)
            buff.IsRising = false
            char:WaitForChild("Humanoid")
            task.wait(0.5)
            if buff.Enabled then setupListener() end
        end)
        table.insert(buff.Connections, charConn)
        if Player.Character then setupListener() end
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Activated!", 2)
    end
    
    function buff.Stop()
        buff.Enabled = false
        buff.IsRising = false
        if buff.RiseConnection then buff.RiseConnection:Disconnect() buff.RiseConnection = nil end
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        for _, conn in ipairs(buff.Connections) do pcall(function() conn:Disconnect() end) end
        buff.Connections = {}
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Deactivated!", 2)
    end
    
    return buff
end


function CreateSmoothForwardBuff(name, style, animationId, defaultDistance, distanceMultiplier, delayBefore)
    local buff = {
        Enabled = false,
        Distance = defaultDistance or 5,
        DistanceMultiplier = distanceMultiplier or 6,
        DelayBefore = delayBefore or 0.3,
        Connections = {},
        AnimationConnection = nil,
        TeleportConnection = nil,
        IsTeleporting = false,
        TargetAnimationId = tostring(animationId),
        Style = style,
        Name = name
    }
    
    local function smoothTeleportForward()
        if buff.IsTeleporting or not buff.Enabled or not Player.Character then return end
        local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        buff.IsTeleporting = true
        local startPos = hrp.Position
        local tpDistance = buff.Distance * buff.DistanceMultiplier
        
        local camera = Services.Workspace.CurrentCamera
        local lookVector = camera.CFrame.LookVector
        lookVector = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
        
        
        local ignoreList = {Player.Character}
        for _, plr in ipairs(Services.Players:GetPlayers()) do
            if plr.Character then
                table.insert(ignoreList, plr.Character)
            end
        end
        
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = ignoreList
        params.IgnoreWater = true
        
        local rayResult = Services.Workspace:Raycast(startPos, lookVector * tpDistance, params)
        
        local finalPos
        if rayResult then
            finalPos = rayResult.Position - lookVector * 1
        else
            finalPos = startPos + lookVector * tpDistance
        end
        
        
        local duration = 0.55
        local startTime = tick()
        
        if buff.TeleportConnection then buff.TeleportConnection:Disconnect() end
        
        buff.TeleportConnection = Services.RunService.Heartbeat:Connect(function()
            local alpha = (tick() - startTime) / duration
            
            if alpha >= 1 then
                hrp.CFrame = CFrame.new(finalPos, finalPos + lookVector)
