function AutoCounter.UpdateSkillSwapFlowState()
    local style = Player:GetAttribute("style")
    if style ~= "kaiser" and style ~= "nelisagi" then return end
    
    local flowObj = AutoCounter.FindFlow()
    if not flowObj then 
        AutoCounter.ResetSkillSwapStates()
        return 
    end
    
    local value = flowObj.Value
    if value >= 100 then
        AutoCounter.SkillSwapHasReached100 = true
        AutoCounter.SkillSwapWasAbove100 = true
        
        AutoCounter.UsedSkillsThisFlow = {kaiser = {}}
    elseif value < 100 and AutoCounter.SkillSwapWasAbove100 then
        AutoCounter.SkillSwapHasReached100 = true
    else
        AutoCounter.SkillSwapHasReached100 = false
    end
    
    
    if style == "kaiser" then
        for skill, animId in pairs(AutoCounter.KaiserSkillAnimations) do
            if AutoCounter.IsKaiserAnimationPlaying(animId) then
                AutoCounter.UsedSkillsThisFlow.kaiser[skill] = true
            end
        end
    end
    
    if value <= 0 then 
        AutoCounter.SkillSwapWasAbove100 = false 
        AutoCounter.SkillSwapHasReached100 = false
        
        local currentIndex = AutoCounter.CurrentSkillIndex[style] or 1
        if currentIndex ~= 1 then
            AutoCounter.ResetSkillToDefault(style)
        end
        
        AutoCounter.UsedSkillsThisFlow = {kaiser = {}}
    end
    
    AutoCounter.SkillSwapLastFlowValue = value
end


function AutoCounter.UpdateRinFlowSkill()
    local style = Player:GetAttribute("style")
    if style ~= "rin" then 
        
        if AutoCounter.RinFlowSkillActive then
            AutoCounter.RinFlowSkillActive = false
            AutoCounter.CharacterCounterSkills.rin = "skill2"
        end
        return 
    end
    
    local flowObj = AutoCounter.FindFlow()
    if not flowObj then
        if AutoCounter.RinFlowSkillActive then
            AutoCounter.RinFlowSkillActive = false
            AutoCounter.CharacterCounterSkills.rin = "skill2"
            SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Rin → Skill 2 (flow ended)", 2)
        end
        return
    end
    
    local value = flowObj.Value
    
    
    local flowActive = value > 0 and value < 100 and AutoCounter.SkillSwapWasAbove100
    
    
    if value >= 100 then
        AutoCounter.SkillSwapWasAbove100 = true
    end
    
    if flowActive and not AutoCounter.RinFlowSkillActive then
        
        AutoCounter.RinFlowSkillActive = true
        AutoCounter.CharacterCounterSkills.rin = "skill5"
        SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Rin → Skill 5 (flow active)", 2)
    elseif not flowActive and AutoCounter.RinFlowSkillActive then
        
        AutoCounter.RinFlowSkillActive = false
        AutoCounter.CharacterCounterSkills.rin = "skill2"
        SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Rin → Skill 2 (flow ended)", 2)
    end
    
    
    if value <= 0 then
        AutoCounter.SkillSwapWasAbove100 = false
        if AutoCounter.RinFlowSkillActive then
            AutoCounter.RinFlowSkillActive = false
            AutoCounter.CharacterCounterSkills.rin = "skill2"
            SafeNotify("<font color='#A6BAFF'>[ Auto Counter ]</font> Rin → Skill 2 (flow ended)", 2)
        end
    end
end

function AutoCounter.GetAvailableSkills(style)
    local skillOrder = AutoCounter.SkillSwapOrder[style]
    if not skillOrder then return {} end
    
    local available = {}
    
    if style == "kaiser" then
        
        local usedSkills = AutoCounter.UsedSkillsThisFlow.kaiser or {}
        for _, skill in ipairs(skillOrder) do
            if not usedSkills[skill] and not IsSkillOnCooldown(skill) then
                table.insert(available, skill)
            end
        end
    elseif style == "nelisagi" then
        
        for _, skill in ipairs(skillOrder) do
            if not IsSkillOnCooldown(skill) then
                table.insert(available, skill)
            end
        end
    end
    
    return available
end

function AutoCounter.MarkSkillAsUsed(style, skill)
    
    if style == "kaiser" then
        if not AutoCounter.UsedSkillsThisFlow.kaiser then
            AutoCounter.UsedSkillsThisFlow.kaiser = {}
        end
        AutoCounter.UsedSkillsThisFlow.kaiser[skill] = true
    end
    
end

function AutoCounter.CanSwapSkills()
    local style = Player:GetAttribute("style")
    if style ~= "kaiser" and style ~= "nelisagi" then return false end
    
    local flowObj = AutoCounter.FindFlow()
    if not flowObj then return false end
    local flow = flowObj.Value
    if not (AutoCounter.SkillSwapHasReached100 and flow < 100) then return false end
    
    
    local available = AutoCounter.GetAvailableSkills(style)
    return #available > 1 
end

function AutoCounter.SwapSkill()
    local style = Player:GetAttribute("style")
    if not style then return end
    
    local skillOrder = AutoCounter.SkillSwapOrder[style]
    if not skillOrder then return end
    
    
    local flowObj = AutoCounter.FindFlow()
    if not flowObj then return end
    local flow = flowObj.Value
    if not (AutoCounter.SkillSwapHasReached100 and flow < 100) then return end
    
    
    local available = AutoCounter.GetAvailableSkills(style)
    
    
    if #available <= 1 then
        if #available == 1 then
            
            AutoCounter.CharacterCounterSkills[style] = available[1]
            local skillName = available[1]:gsub("skill", "Skill ")
            SafeNotify("<font color='#A6BAFF'>[ Skill Swap ]</font> " .. style:sub(1,1):upper() .. style:sub(2) .. " → " .. skillName .. " (only available)", 2)
        else
            
            AutoCounter.ResetSkillToDefault(style)
            SafeNotify("<font color='#A6BAFF'>[ Skill Swap ]</font> No skills available, reset to default", 2)
        end
        return
    end
    
    
    local currentSkill = AutoCounter.CharacterCounterSkills[style]
    local currentAvailableIndex = 1
    
    for i, skill in ipairs(available) do
        if skill == currentSkill then
            currentAvailableIndex = i
            break
        end
    end
    
    
    local nextIndex = currentAvailableIndex + 1
    if nextIndex > #available then nextIndex = 1 end
    
    local newSkill = available[nextIndex]
    AutoCounter.CharacterCounterSkills[style] = newSkill
    
    
    for i, skill in ipairs(skillOrder) do
        if skill == newSkill then
            AutoCounter.CurrentSkillIndex[style] = i
            break
        end
    end
    
    local skillName = newSkill:gsub("skill", "Skill ")
    SafeNotify("<font color='#A6BAFF'>[ Skill Swap ]</font> " .. style:sub(1,1):upper() .. style:sub(2) .. " → " .. skillName, 2)
end

function AutoCounter.ResetSkillToDefault(style)
    if not style then return end
    local skillOrder = AutoCounter.SkillSwapOrder[style]
    if not skillOrder then return end
    
    AutoCounter.CurrentSkillIndex[style] = 1
    AutoCounter.CharacterCounterSkills[style] = skillOrder[1]
end

