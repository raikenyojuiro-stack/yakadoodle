local TackleDistanceBuff = (function()
    local buff = {
        Enabled = false,
        Distance = 4,
        Duration = 0.33,
        Connections = {},
        AnimationConnection = nil,
        TeleportThread = nil,
        TeleportTimer = nil,
        IsActive = false,
        TargetAnimationId = "109744655458082",
        Name = "Tackle Distance Increase",
        BallCache = nil,
        LastBallCheck = 0,
        Camera = nil
    }
    
    local function isBallNearby()
        if not buff.Enabled then return false end
        local now = tick()
        if now - buff.LastBallCheck >= 0.2 then
            buff.LastBallCheck = now
            buff.BallCache = Services.Workspace:FindFirstChild("Ball") or Services.Workspace.Terrain:FindFirstChild("Ball")
            if not buff.BallCache or not Player.Character then
                buff.BallCache = nil
                return false
            end
            local rootPart = Player.Character:FindFirstChild("HumanoidRootPart")
            if not rootPart then
                buff.BallCache = nil
                return false
            end
            local distance = (rootPart.Position - buff.BallCache.Position).Magnitude
            if distance > 17 then
                buff.BallCache = nil
                return false
            end
        end
        return buff.BallCache ~= nil
    end
    
    local function getCameraBasedDirection()
        if not Player or not Player.Character then return Vector3.new(0, 0, 1) end
        local rootPart = Player.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return Vector3.new(0, 0, 1) end
        local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return Vector3.new(0, 0, 1) end
        
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude < 0.1 then
            if buff.Camera then
                return buff.Camera.CFrame.LookVector
            else
                return rootPart.CFrame.LookVector
            end
        end
        
        if buff.Camera then
            local cameraLookVector = buff.Camera.CFrame.LookVector
            local cameraRightVector = buff.Camera.CFrame.RightVector
            local forwardDot = moveDirection:Dot(cameraLookVector)
            local rightDot = moveDirection:Dot(cameraRightVector)
            
            if math.abs(forwardDot) > math.abs(rightDot) then
                return forwardDot > 0 and cameraLookVector or -cameraLookVector
            else
                return rightDot > 0 and cameraRightVector or -cameraRightVector
            end
        end
        return moveDirection.Unit
    end
    
    local function teleportInDirection()
        if not buff.Enabled or not Player.Character then return false end
        if isBallNearby() then return false end
        local rootPart = Player.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return false end
        
        local moveDirection = getCameraBasedDirection()
        moveDirection = Vector3.new(moveDirection.X, 0, moveDirection.Z).Unit
        local newPosition = rootPart.Position + (moveDirection * buff.Distance)
        local lookVector = rootPart.CFrame.LookVector
        rootPart.CFrame = CFrame.new(newPosition, newPosition + lookVector)
        return true
    end
    
    local function stopTeleportation()
        buff.IsActive = false
        if buff.TeleportThread then pcall(function() task.cancel(buff.TeleportThread) end) buff.TeleportThread = nil end
        if buff.TeleportTimer then pcall(function() task.cancel(buff.TeleportTimer) end) buff.TeleportTimer = nil end
    end
    
    local function startTeleportation()
        if buff.IsActive or not buff.Enabled then return end
        if isBallNearby() then return end
        
        stopTeleportation()
        buff.IsActive = true
        
        buff.TeleportThread = task.spawn(function()
            while buff.IsActive and buff.Enabled do
                if isBallNearby() then stopTeleportation() break end
                teleportInDirection()
                task.wait(0.08)
            end
            buff.IsActive = false
        end)
        
        
        buff.TeleportTimer = task.spawn(function()
            task.wait(buff.Duration)
            stopTeleportation()
        end)
    end
    
    local function onAnimationPlayed(track)
        if not buff.Enabled or not track.Animation then return end
        local animId = tostring(track.Animation.AnimationId)
        if animId:find(buff.TargetAnimationId) then
            if isBallNearby() then return end
            startTeleportation()
            local stoppedConn
            stoppedConn = track.Stopped:Connect(function()
                stopTeleportation()
                if stoppedConn then stoppedConn:Disconnect() end
            end)
            table.insert(buff.Connections, stoppedConn)
        end
    end
    
    local function setupListener()
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        if not buff.Enabled or not Player.Character then return end
        local humanoid = Player.Character:FindFirstChild("Humanoid")
        if not humanoid then return end
        buff.AnimationConnection = humanoid.AnimationPlayed:Connect(onAnimationPlayed)
    end
    
    function buff.Start()
        if buff.Enabled then return end
        buff.Enabled = true
        buff.Camera = Services.Workspace.CurrentCamera
        local charConn = Player.CharacterAdded:Connect(function(char)
            stopTeleportation()
            char:WaitForChild("Humanoid")
            task.wait(0.5)
            if buff.Enabled then setupListener() end
        end)
        table.insert(buff.Connections, charConn)
        if Player.Character then setupListener() end
        SafeNotify("<font color='#A6BAFF'>[ " .. buff.Name .. " ]</font> Activated!", 2)
    end
    
    function buff.Stop()
        buff.Enabled = false
        stopTeleportation()
        if buff.AnimationConnection then buff.AnimationConnection:Disconnect() buff.AnimationConnection = nil end
        for _, conn in ipairs(buff.Connections) do pcall(function() conn:Disconnect() end) end
        buff.Connections = {}
        buff.BallCache = nil
