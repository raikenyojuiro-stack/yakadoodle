local AutoFinalMatchup = {
    Enabled = false,
    Connection = nil,
    ByteNetReliable = nil,
    IsSpamming = false,
    SpamDuration = 1.3
}

function AutoFinalMatchup.IsRin()
    return Player:GetAttribute("style") == "rin"
end

function AutoFinalMatchup.GetFlow()
    local chars = Services.Workspace:FindFirstChild("characters")
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return 0 end
    local state = myChar:FindFirstChild("state")
    return state and state:FindFirstChild("flow") and tonumber(state.flow.Value) or 0
end

function AutoFinalMatchup.GetMyTeam()
    local chars = Services.Workspace:FindFirstChild("characters")
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return nil end
    local state = myChar:FindFirstChild("state")
    return state and state:FindFirstChild("team") and state.team.Value
end

function AutoFinalMatchup.IsOvertime()
    local timerGui = Player:FindFirstChild("PlayerGui")
    timerGui = timerGui and timerGui:FindFirstChild("Timer")
    timerGui = timerGui and timerGui:FindFirstChild("Timer")
    if timerGui and timerGui:IsA("TextLabel") then
        return timerGui.Text == "00:00"
    end
    return false
end

function AutoFinalMatchup.HasFlowLock()
    local hotbar = Player:FindFirstChild("PlayerGui")
    hotbar = hotbar and hotbar:FindFirstChild("Hotbar")
    hotbar = hotbar and hotbar:FindFirstChild("MagicHealth")
    local flowLock = hotbar and hotbar:FindFirstChild("FlowLock")
    return flowLock and flowLock.Visible
end

function AutoFinalMatchup.FindEnemySaeWithBall()
    local myTeam = AutoFinalMatchup.GetMyTeam()
    if not myTeam or myTeam == "lobby" then return false end
    local chars = Services.Workspace:FindFirstChild("characters")
    if not chars then return false end
    for _, character in pairs(chars:GetChildren()) do
        if character.Name ~= Player.Name and character:FindFirstChild("Ball") then
            local state = character:FindFirstChild("state")
            if state then
                local teamValue = state:FindFirstChild("team")
                if teamValue and teamValue.Value ~= "lobby" and teamValue.Value ~= myTeam then
                    local targetPlayer = Services.Players:FindFirstChild(character.Name)
                    if targetPlayer and targetPlayer:GetAttribute("style") == "sae" then
                        return true
                    end
                end
            end
        end
    end
    return false
end

function AutoFinalMatchup.SpamBaseAwaken()
    if AutoFinalMatchup.IsSpamming then return end
    AutoFinalMatchup.IsSpamming = true
    local startTime = tick()
    while tick() - startTime < AutoFinalMatchup.SpamDuration and AutoFinalMatchup.Enabled do
        if AutoFinalMatchup.ByteNetReliable then
            pcall(function()
                AutoFinalMatchup.ByteNetReliable:FireServer(BN_UseBuffer(), {{"baseAwaken", false}})
            end)
        end
        task.wait(0.1)
    end
    AutoFinalMatchup.IsSpamming = false
end

function AutoFinalMatchup.Process()
    if not AutoFinalMatchup.Enabled then return end
    if not AutoFinalMatchup.IsRin() then return end
    if not AutoFinalMatchup.IsOvertime() then return end
    if AutoFinalMatchup.GetFlow() ~= 100 then return end
    if not AutoFinalMatchup.FindEnemySaeWithBall() then return end
    if AutoFinalMatchup.HasFlowLock() then return end
    task.spawn(AutoFinalMatchup.SpamBaseAwaken)
end

function AutoFinalMatchup.Start()
    AutoFinalMatchup.ByteNetReliable = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not AutoFinalMatchup.ByteNetReliable then
        SafeNotify("<font color='#A6BAFF'>[ Auto Final Matchup ]</font> ByteNetReliable not found!", 5)
        return
    end
    AutoFinalMatchup.Enabled = true
    AutoFinalMatchup.Connection = Services.RunService.Heartbeat:Connect(AutoFinalMatchup.Process)
    SafeNotify("<font color='#A6BAFF'>[ Auto Final Matchup ]</font> Activated!", 2)
end

function AutoFinalMatchup.Stop()
    AutoFinalMatchup.Enabled = false
    if AutoFinalMatchup.Connection then
        AutoFinalMatchup.Connection:Disconnect()
        AutoFinalMatchup.Connection = nil
    end
    AutoFinalMatchup.IsSpamming = false
    SafeNotify("<font color='#A6BAFF'>[ Auto Final Matchup ]</font> Deactivated!", 2)
end


