    if not localRoot then return nil end
    
    local myTeam = GetPlayerTeam(Player.Name)
    if not myTeam or myTeam == "lobby" then return nil end
    
    for _, player in pairs(Services.Players:GetPlayers()) do
        if player ~= Player and player.Character then
            local enemyTeam = GetPlayerTeam(player.Name)
            if enemyTeam and enemyTeam ~= myTeam and enemyTeam ~= "lobby" then
                local humanoid = player.Character:FindFirstChild("Humanoid")
                local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                if humanoid and humanoid.Health > 0 and rootPart then
                    local distance = (rootPart.Position - localRoot.Position).Magnitude
                    if distance < RabonaNutmegAimbot.MAX_DISTANCE and distance < shortestDistance then
                        shortestDistance = distance
                        closestPlayer = player
