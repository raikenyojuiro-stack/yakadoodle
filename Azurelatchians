    local myLookVector = myHRP.CFrame.LookVector
    local toEnemyVector = (enemyHRP.Position - myHRP.Position).Unit
    local dotProduct = myLookVector:Dot(toEnemyVector)
    local angle = math.acos(math.clamp(dotProduct, -1, 1))
    
    return angle < math.rad(45)
end

function AntiCounter.FlickBack()
    local character = Player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    humanoid.AutoRotate = false
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(180), 0)
    
    local camera = workspace.CurrentCamera
    local camType = camera.CameraType
    local camSubject = camera.CameraSubject
    camera.CameraType = Enum.CameraType.Scriptable
    camera.CFrame = hrp.CFrame + Vector3.new(0, 2, 0)
    
    task.delay(0.1, function()
        if Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") then
            camera.CameraSubject = Player.Character:FindFirstChildOfClass("Humanoid")
            camera.CameraType = Enum.CameraType.Custom
        else
            camera.CameraSubject = camSubject
            camera.CameraType = camType
        end
        if humanoid then humanoid.AutoRotate = true end
    end)
end

function AntiCounter.TeleportBack()
    local character = Player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    
    local backVector = -hrp.CFrame.LookVector
    local newPos = hrp.Position + backVector * AntiCounter.BlatantTeleportDistance
    hrp.CFrame = CFrame.new(newPos, newPos + hrp.CFrame.LookVector)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

function AntiCounter.Check()
    if not AntiCounter.Enabled then return end
    
    local now = tick()
    
    if AntiCounter.Mode ~= "Blatant (Best)" then
        if now - AntiCounter.LastFlickTime < AntiCounter.FlickCooldown then return end
    end
    
    
    if not AntiCounter.IsOurTackleAnimationPlaying() then return end
    
    
    local myTeam = AC_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    
    local myChar = Player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local myPos = myHRP.Position
    
    local chars = Services.Workspace:FindFirstChild("characters")
    if not chars then return end
    
    
    for _, targetPlayer in ipairs(Services.Players:GetPlayers()) do
        if targetPlayer ~= Player then
            local targetTeam = AC_GetPlayerTeamByName(targetPlayer.Name)
            if targetTeam and targetTeam ~= "lobby" and targetTeam ~= myTeam then
                local targetChar = chars:FindFirstChild(targetPlayer.Name)
                if targetChar then
                    
                    if targetChar:FindFirstChild("Ball") then
                        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
                        if targetHRP then
                            local distance = (targetHRP.Position - myPos).Magnitude
                            if distance <= AntiCounter.CheckDistance then
                                if AntiCounter.IsLookingAtEnemy(targetHRP) then
                                    if AntiCounter.IsEnemyCountering(targetChar) then
                                        if AntiCounter.Mode == "Blatant (Best)" then
                                            AntiCounter.TeleportBack()
                                        else
                                            AntiCounter.LastFlickTime = now
                                            SafeNotify("<font color='#A6BAFF'>[ Anti Counter ]</font> Dodged!", 1)
                                            AntiCounter.FlickBack()
                                        end
                                        return
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

function AntiCounter.Start()
    if AntiCounter.Connection then AntiCounter.Connection:Disconnect() end
    AntiCounter.Connection = Services.RunService.Heartbeat:Connect(AntiCounter.Check)
    SafeNotify("<font color='#A6BAFF'>[ Anti Counter ]</font> Enabled", 2)
end

function AntiCounter.Stop()
    if AntiCounter.Connection then AntiCounter.Connection:Disconnect() AntiCounter.Connection = nil end
    SafeNotify("<font color='#A6BAFF'>[ Anti Counter ]</font> Disabled", 2)
end


