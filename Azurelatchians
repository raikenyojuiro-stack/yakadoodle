function AV_HasBall()
    local chars = AV_GetChars()
    local char = chars and chars:FindFirstChild(Player.Name)
    return char and char:FindFirstChild("Ball")
end
function AV_GetPlayerTeam()
    if not Player.Character then return nil end
    local state = Player.Character:FindFirstChild("state")
    if not state then return nil end
    local teamValue = state:FindFirstChild("team")
    return teamValue and teamValue.Value or nil
end
function AV_GetPlayerTeamByName(playerName)
    local chars = AV_GetChars()
    local playerChar = chars and chars:FindFirstChild(playerName)
    if playerChar then
        local state = playerChar:FindFirstChild("state")
        if state then
            local team = state:FindFirstChild("team")
            if team then return team.Value end
        end
    end
    return nil
end
function AV_FindBallOwnerTeam()
    local chars = AV_GetChars()
    if not chars then return nil end
    for _, playerFolder in ipairs(chars:GetChildren()) do
        if playerFolder:FindFirstChild("Ball") then
            local state = playerFolder:FindFirstChild("state")
            if state then
                local teamValue = state:FindFirstChild("team")
                if teamValue then return teamValue.Value end
            end
        end
    end
    return nil
end
function AV_IsInEnemyGoalbox(position, myTeam)
    local enemyGoalbox = AutoVolley.Goalboxes[myTeam == "A" and "B" or "A"]
    if not enemyGoalbox then return false end
    return position.X >= enemyGoalbox.minX and position.X <= enemyGoalbox.maxX and
           position.Z >= enemyGoalbox.minZ and position.Z <= enemyGoalbox.maxZ
end
function AV_IsBallComingTowardsPlayer(ball, ballVelocity, playerPosition)
    if not ball or ballVelocity.Magnitude == 0 then return false end
    local ballDirection = ballVelocity.Unit
    local toPlayerVector = (playerPosition - ball.Position).Unit
    local dotProduct = ballDirection:Dot(toPlayerVector)
    local angle = math.acos(math.clamp(dotProduct, -1, 1))
    return angle <= math.rad(45)
end
function AV_CanReachBall(ball, playerPosition, ballVelocity)
    if not ball then return false end
    local horizontalDistance = (Vector3.new(playerPosition.X, 0, playerPosition.Z) - 
                               Vector3.new(ball.Position.X, 0, ball.Position.Z)).Magnitude
    local verticalDistance = math.abs(playerPosition.Y - ball.Position.Y)
    if horizontalDistance > AutoVolley.MAX_BALL_DISTANCE then return false end
    if verticalDistance > AutoVolley.MAX_VERTICAL_DISTANCE then return false end
    return true
end
function AV_IsPlayerFacingTarget(targetHRP, myPos)
    if not targetHRP then return false end
    local targetLookVector = targetHRP.CFrame.LookVector
    local toPlayerVector = (myPos - targetHRP.Position).Unit
    local dotProduct = targetLookVector:Dot(toPlayerVector)
    local angle = math.acos(math.clamp(dotProduct, -1, 1))
    return angle <= math.rad(20)
end
function AV_CheckAnimation(animator, animationId)
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.Animation.AnimationId == animationId and track.IsPlaying then return true, track end
    end
    return false, nil
end

function AutoVolley.ProcessAnimationPredict()
    if not AutoVolley.Enabled or not Player.Character then return end
    if AutoVolley.IsWaitingForStyle then return end
    if not AV_IsNelIsagi() then return end
    local myTeam = AV_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    local myChar = Player.Character
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local myPos = myHRP.Position
    local shouldDefend = not AutoVolley.GoalboxOnly or AV_IsInEnemyGoalbox(myPos, myTeam)
    if not shouldDefend then return end
    local chars = AV_GetChars()
    if not chars then return end
    for _, targetPlayer in ipairs(Services.Players:GetPlayers()) do
        if targetPlayer ~= Player then
            local targetTeam = AV_GetPlayerTeamByName(targetPlayer.Name)
            local targetChar = chars:FindFirstChild(targetPlayer.Name)
            if targetTeam and targetTeam ~= "lobby" and targetChar and targetChar:FindFirstChild("Ball") then
                local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetChar:FindFirstChild("Humanoid")
                local animator = targetHumanoid and targetHumanoid:FindFirstChildOfClass("Animator")
                if targetHRP and animator then
                    local distance = (targetHRP.Position - myPos).Magnitude
                    if AV_IsPlayerFacingTarget(targetHRP, myPos) then
                        for animationId, animationData in pairs(AutoVolley.Animations) do
                            if distance <= animationData.maxDistance then
                                local hasAnimation, track = AV_CheckAnimation(animator, animationId)
                                if hasAnimation then
                                    local currentTime = tick()
                                    local trackingKey = targetPlayer.UserId.."_"..animationId
                                    if not AutoVolley.AnimationTracking[trackingKey] then
                                        AutoVolley.AnimationTracking[trackingKey] = {
                                            detectedTime = currentTime, hasTriggered = false,
                                            animationId = animationId, player = targetPlayer, delay = animationData.delay
                                        }
                                    end
                                    local animData = AutoVolley.AnimationTracking[trackingKey]
                                    if not animData.hasTriggered and (currentTime - animData.detectedTime) >= animData.delay then
                                        if tick() - AutoVolley.LastDefenseTime > 2 and not IsSkillOnCooldown("skill1") then
                                            local targetBall = targetChar:FindFirstChild("Ball")
                                            local needsJump = false
                                            if targetBall then
                                                local ballHeightDifference = targetBall.Position.Y - myPos.Y
                                                needsJump = ballHeightDifference > 10
                                            end
                                            AutoVolley.LastDefenseTime = tick()
                                            AutoVolley.PerformVolley(needsJump)
                                            animData.hasTriggered = true
                                        end
                                    end
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    local currentTime = tick()
    for trackingKey, data in pairs(AutoVolley.AnimationTracking) do
        if currentTime - data.detectedTime > 5 then AutoVolley.AnimationTracking[trackingKey] = nil end
    end
end

function AutoVolley.ProcessDefense()
    if not AutoVolley.Enabled or not Player.Character then return end
    if AutoVolley.IsWaitingForStyle then return end
    if not AV_IsNelIsagi() then return end
    local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local currentOwnerTeam = AV_FindBallOwnerTeam()
    if currentOwnerTeam then AutoVolley.lastBallOwnerTeam = currentOwnerTeam end
    if not AV_HasBall() and AutoVolley.lastBallOwnerTeam then
        local ball = Services.Workspace.Terrain:FindFirstChild("Ball") or Services.Workspace:FindFirstChild("Ball")
        if ball then
            local cfBall = AV_GetCFBall()
            local velocity = cfBall and cfBall:FindFirstChild("velocity")
            if velocity then
                local ballVelocity = velocity.Value
                local realSpeed = ballVelocity.Magnitude
                if realSpeed >= 150 then
                    local playerPos = hrp.Position
                    local distanceToBall = (ball.Position - playerPos).Magnitude
                    local timeToImpact = distanceToBall / realSpeed
                    if AV_IsBallComingTowardsPlayer(ball, ballVelocity, playerPos) and timeToImpact <= 0.3 then
                        if AV_CanReachBall(ball, playerPos, ballVelocity) then
                            local myTeam = AV_GetPlayerTeam()
                            if AutoVolley.lastBallOwnerTeam and myTeam and AutoVolley.lastBallOwnerTeam ~= "lobby" and myTeam ~= "lobby" then
                                local shouldDefend = not AutoVolley.GoalboxOnly or AV_IsInEnemyGoalbox(playerPos, myTeam)
                                if shouldDefend and tick() - AutoVolley.LastDefenseTime > 2 and not IsSkillOnCooldown("skill1") then
                                    local heightDifference = ball.Position.Y - playerPos.Y
                                    local needsJump = heightDifference > 10
                                    AutoVolley.LastDefenseTime = tick()
                                    AutoVolley.PerformVolley(needsJump)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

function AV_Update()
    AutoVolley.ProcessDefense()
    AutoVolley.ProcessAnimationPredict()
end

function AutoVolley.OnStyleChanged()
    if not AutoVolley.Enabled then return end
    if AV_IsNelIsagi() then
        AutoVolley.IsWaitingForStyle = false
        if AutoVolley.DefenseConnection then AutoVolley.DefenseConnection:Disconnect() end
        AutoVolley.DefenseConnection = Services.RunService.Heartbeat:Connect(AV_Update)
    else
        AutoVolley.IsWaitingForStyle = true
        if AutoVolley.DefenseConnection then AutoVolley.DefenseConnection:Disconnect() AutoVolley.DefenseConnection = nil end
    end
end

function AutoVolley.Start()
    AutoVolley.ByteNetReliable = AV_FindByte()
    if not AutoVolley.ByteNetReliable then
        SafeNotify("<font color='#A6BAFF'>[ Auto Volley ]</font> ByteNetReliable not found!", 5)
        return
    end
    AutoVolley.Enabled = true
    AutoVolley.Connections = {
        Player:GetAttributeChangedSignal("style"):Connect(AutoVolley.OnStyleChanged),
        Player.CharacterAdded:Connect(function(newChar)
            if not AutoVolley.Enabled then return end
            task.wait(1)
            if newChar and newChar.Parent and AutoVolley.Enabled and AV_IsNelIsagi() then
                AutoVolley.IsWaitingForStyle = false
                if AutoVolley.DefenseConnection then AutoVolley.DefenseConnection:Disconnect() end
                AutoVolley.DefenseConnection = Services.RunService.Heartbeat:Connect(AV_Update)
            end
        end)
    }
    if AV_IsNelIsagi() then
        AutoVolley.IsWaitingForStyle = false
        AutoVolley.DefenseConnection = Services.RunService.Heartbeat:Connect(AV_Update)
        SafeNotify("<font color='#A6BAFF'>[ Auto Volley ]</font> Activated!", 2)
    else
        AutoVolley.IsWaitingForStyle = true
    end
end

function AutoVolley.Stop()
    AutoVolley.Enabled = false
    AutoVolley.IsWaitingForStyle = false
    if AutoVolley.DefenseConnection then AutoVolley.DefenseConnection:Disconnect() AutoVolley.DefenseConnection = nil end
    if AutoVolley.AnimationConnection then AutoVolley.AnimationConnection:Disconnect() AutoVolley.AnimationConnection = nil end
    for _, c in pairs(AutoVolley.Connections) do pcall(function() c:Disconnect() end) end
    AutoVolley.Connections = {}
    AutoVolley.AnimationTracking = {}
    SafeNotify("<font color='#A6BAFF'>[ Auto Volley ]</font> Deactivated!", 2)
end


