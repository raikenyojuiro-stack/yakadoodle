    local ownerName = HIA_FindBallOwner()
    if ownerName then
        HorrificInterceptAimbot.lastBallOwnerTeam = ownerName
    end
    
    local playing = HorrificInterceptAimbot.Animator:GetPlayingAnimationTracks()
    local found = false
    
    for _, track in ipairs(playing) do
        local animId = tostring(track.Animation.AnimationId)
        if animId:find(HorrificInterceptAimbot.ANIMATION_ID) then
            found = true
            break
        end
