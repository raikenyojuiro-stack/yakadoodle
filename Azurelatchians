function LineUpCreator.OnShotDetected(styleName, savedPosition, savedMouseTarget)
    local playerPos = savedPosition
    local mouseTarget = savedMouseTarget
    local team = AutoLineUps.GetTeam()
    local hasFlow = LineUpCreator.HasFlow()
    local styleAlreadyHasFlow = string.find(styleName, "_flow$") ~= nil
    
    if not playerPos or not mouseTarget or not team then return end
    if LineUpCreator.IsNearExistingLineup(playerPos, styleName, team) then return end
    
    LineUpCreator.LastShotData = {
        style = styleName,
        team = team,
        isFlow = (not styleAlreadyHasFlow) and hasFlow,
        targetPosition = {X = math.floor(playerPos.X * 100) / 100, Y = 3, Z = math.floor(playerPos.Z * 100) / 100},
        mouseTargetPosition = {X = math.floor(mouseTarget.X * 100) / 100, Y = math.floor(mouseTarget.Y * 100) / 100, Z = math.floor(mouseTarget.Z * 100) / 100}
    }
    
    LineUpCreator.WaitingForGoal = true
    LineUpCreator.ShotTime = tick()
    
    task.spawn(function()
        for i = 1, 12 do
            task.wait(0.5)
            if not LineUpCreator.WaitingForGoal or not LineUpCreator.LastShotData then return end
            if LineUpCreator.CheckGoalScored() then
                LineUpCreator.LatestLineUp = LineUpCreator.LastShotData
                LineUpCreator.WaitingForGoal = false
                SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Goal detected! LineUp saved. Press 'Save Latest' to keep it.", 3)
                return
            end
        end
        LineUpCreator.WaitingForGoal = false
    end)
end

function LineUpCreator.SaveLatest()
    if not LineUpCreator.LatestLineUp then
        SafeNotify("<font color='#FF6B6B'>[ LineUp Creator ]</font> No lineup to save!", 2)
        return
    end
    
    table.insert(LineUpCreator.CustomLineUps, LineUpCreator.LatestLineUp)
    LineUpCreator.SaveConfig()
    
    local lineup = LineUpCreator.LatestLineUp
    local styleName = lineup.style
    
    local cfg = AutoLineUps.StylesConfig[styleName]
    if cfg and cfg.points[lineup.team] then
        local point = {
            targetPosition = Vector3.new(lineup.targetPosition.X, lineup.targetPosition.Y, lineup.targetPosition.Z),
            mouseTargetPosition = Vector3.new(lineup.mouseTargetPosition.X, lineup.mouseTargetPosition.Y, lineup.mouseTargetPosition.Z),
            lookAtHeight = lineup.mouseTargetPosition.Y,
            isCustom = true
        }
        table.insert(cfg.points[lineup.team], point)
    end
    
    SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> LineUp saved! Style: " .. lineup.style .. ", Team: " .. lineup.team, 3)
    
    if AutoLineUps.Enabled then
        AutoLineUps.CreateMarkers()
    end
    
    LineUpCreator.LatestLineUp = nil
    
    
    if LineUpCreator.RefreshDropdown then
        LineUpCreator.RefreshDropdown()
    end
end

function LineUpCreator.DeleteLatest()
    if LineUpCreator.LatestLineUp then
        LineUpCreator.LatestLineUp = nil
        SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Unsaved lineup deleted!", 2)
        return
    end
    
    if #LineUpCreator.CustomLineUps > 0 then
        local removed = table.remove(LineUpCreator.CustomLineUps)
        LineUpCreator.SaveConfig()
        
        local styleName = removed.style
        if removed.isFlow and not string.find(styleName, "_flow$") then 
            styleName = styleName .. "_flow" 
        end
        
        local cfg = AutoLineUps.StylesConfig[styleName]
        if cfg and cfg.points[removed.team] then
            for i = #cfg.points[removed.team], 1, -1 do
                local point = cfg.points[removed.team][i]
                if point.isCustom then
                    local posMatch = math.abs(point.targetPosition.X - removed.targetPosition.X) < 2 and
                                     math.abs(point.targetPosition.Z - removed.targetPosition.Z) < 2
                    if posMatch then
                        table.remove(cfg.points[removed.team], i)
                        break
                    end
                end
            end
        end
        
        AutoLineUps.CreateMarkers()
        SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Last saved lineup deleted! (" .. removed.style .. " " .. removed.team .. ")", 2)
        return
    end
    
    SafeNotify("<font color='#FF6B6B'>[ LineUp Creator ]</font> No lineups to delete!", 2)
end

function LineUpCreator.Start()
    if LineUpCreator.Connection then LineUpCreator.Connection:Disconnect() end
    LineUpCreator.Enabled = true
    
    local hadBall = LineUpCreator.HasBall()
    local lastAnimId = nil
    local lastAnimStyle = nil
    local savedPosition = nil
    local savedMouseTarget = nil
    local animStartTime = 0
    local coordsSaved = false
    
    LineUpCreator.Connection = Services.RunService.Heartbeat:Connect(function()
        if not LineUpCreator.Enabled then return end
        
        local hasBall = LineUpCreator.HasBall()
        local animId, animStyle = LineUpCreator.GetCurrentAnimationId()
        
        if animId and animStyle then
            if animId ~= lastAnimId then
                lastAnimId = animId
                lastAnimStyle = animStyle
                animStartTime = tick()
                coordsSaved = false
                
                local delay = LineUpCreator.AnimationDelays[animId] or 0
                
                if delay == 0 then
                    savedPosition = LineUpCreator.GetPlayerPosition()
                    savedMouseTarget = LineUpCreator.GetMouseTarget()
                    coordsSaved = true
                end
            end
            
            if not coordsSaved and lastAnimId then
                local delay = LineUpCreator.AnimationDelays[lastAnimId] or 0
                if delay > 0 and (tick() - animStartTime) >= delay then
                    savedPosition = LineUpCreator.GetPlayerPosition()
                    savedMouseTarget = LineUpCreator.GetMouseTarget()
                    coordsSaved = true
                end
            end
        end
        
        if hadBall and not hasBall then
            if lastAnimStyle and savedPosition and savedMouseTarget then
                LineUpCreator.OnShotDetected(lastAnimStyle, savedPosition, savedMouseTarget)
            end
            lastAnimStyle = nil
            lastAnimId = nil
            savedPosition = nil
            savedMouseTarget = nil
            coordsSaved = false
        end
        
        hadBall = hasBall
    end)
    
    SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Activated! Score goals to record lineups.", 3)
end

function LineUpCreator.Stop()
    LineUpCreator.Enabled = false
    if LineUpCreator.Connection then LineUpCreator.Connection:Disconnect() LineUpCreator.Connection = nil end
    SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Deactivated!", 2)
end


