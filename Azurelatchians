                    local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                    if rootPart then
                        local distance = (rootPart.Position - localRoot.Position).Magnitude
                        if distance <= AutoDive.MaxDistance and distance < shortestDistance then
                            shortestDistance = distance
                            closestPlayer = player
                        end
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

function AD_AimAtTarget(targetPart)
    if not targetPart or not targetPart:IsA("BasePart") then return end
    
    local camera = workspace.CurrentCamera
    local cameraPosition = camera.CFrame.Position
    local targetPosition = targetPart.Position
    local direction = (targetPosition - cameraPosition).Unit
    
    camera.CFrame = camera.CFrame:Lerp(
        CFrame.new(cameraPosition, cameraPosition + direction),
        AutoDive.SMOOTHNESS
    )
end

function AD_AimTick()
    if not AutoDive.Aiming then
        if AutoDive.AimConnection then
            AutoDive.AimConnection:Disconnect()
            AutoDive.AimConnection = nil
        end
        return
    end
    
    if not AutoDive.CurrentTarget or not AutoDive.CurrentTarget.Character then
        AutoDive.CurrentTarget = AD_GetClosestEnemyWithBall()
    end
    
    if AutoDive.CurrentTarget and AutoDive.CurrentTarget.Character then
        local targetPart = AutoDive.CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetPart then
            AD_AimAtTarget(targetPart)
        end
    end
end

function AD_StartAiming()
    if AutoDive.Aiming then return end
    
    AutoDive.Aiming = true
    AutoDive.CurrentTarget = AD_GetClosestEnemyWithBall()
    
    if AutoDive.AimConnection then
        AutoDive.AimConnection:Disconnect()
    end
    
    AutoDive.AimConnection = Services.RunService.RenderStepped:Connect(AD_AimTick)
end

function AD_StopAiming()
    AutoDive.Aiming = false
    AutoDive.CurrentTarget = nil
    
    if AutoDive.AimConnection then
        AutoDive.AimConnection:Disconnect()
        AutoDive.AimConnection = nil
    end
end

function AD_AnimatorUpdate()
    if not AutoDive.Enabled or not AD_IsGK() or not AutoDive.Animator then return end
    
    local playing = AutoDive.Animator:GetPlayingAnimationTracks()
    local found = false
    
    for _, track in ipairs(playing) do
        local animId = tostring(track.Animation.AnimationId)
        if animId:find(AutoDive.ANIMATION_ID) then
            found = true
            break
        end
    end
    
    if found and not AutoDive.Aiming then
        AD_StartAiming()
    elseif not found and AutoDive.Aiming then
        AD_StopAiming()
    end
end

function AD_CheckAndTackle()
    if not AutoDive.Enabled or not AD_IsGK() then return end
    if not Player.Character then return end
    
    local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local myTeam = AD_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    
    local myPos = hrp.Position
    if not AD_IsInGKGoalbox(myPos, myTeam) then return end
    
    local closestEnemy = AD_GetClosestEnemyWithBall()
    if closestEnemy then
        local now = tick()
        if now - AutoDive.LastTackleTime > 1 then
            pcall(function() 
                Services.ReplicatedStorage.ByteNetReliable:FireServer(BN_UseBuffer(), {{"tackle"}}) 
            end)
            AutoDive.LastTackleTime = now
        end
    end
end

function AD_SetupCharacter(char)
    if not AutoDive.Enabled then return end
    
    local humanoid = char:WaitForChild("Humanoid")
    local animator = humanoid:WaitForChild("Animator")
    AutoDive.Animator = animator
    
    if AutoDive.AnimatorConnection then
        AutoDive.AnimatorConnection:Disconnect()
    end
    
    AutoDive.AnimatorConnection = Services.RunService.Heartbeat:Connect(AD_AnimatorUpdate)
end

function AD_OnCharacterAdded(char)
    task.wait(1)
    if AutoDive.Enabled then
        AD_SetupCharacter(char)
    end
end

function AutoDive.Start()
    if AutoDive.Enabled then return end
    
    AutoDive.Enabled = true
    AutoDive.Connection = Services.RunService.Heartbeat:Connect(AD_CheckAndTackle)
    
    if Player.Character then
        AD_SetupCharacter(Player.Character)
    end
    
    Player.CharacterAdded:Connect(AD_OnCharacterAdded)
    
    SafeNotify("<font color='#A6BAFF'>[ Auto Dive ]</font> Activated!", 2)
end

function AutoDive.Stop()
    AutoDive.Enabled = false
    
    AD_StopAiming()
    
    if AutoDive.Connection then
        AutoDive.Connection:Disconnect()
        AutoDive.Connection = nil
    end
    
    if AutoDive.AnimatorConnection then
        AutoDive.AnimatorConnection:Disconnect()
        AutoDive.AnimatorConnection = nil
    end
    
    SafeNotify("<font color='#A6BAFF'>[ Auto Dive ]</font> Deactivated!", 2)
end



local AutoPosition = {
    CF = {Enabled = false, Connection = nil, LoopThread = nil},
    GK = {Enabled = false, Connection = nil, LoopThread = nil}
}

function AP_FindByte() return Services.ReplicatedStorage:FindFirstChild("ByteNetReliable") end

function AP_GetMyTeam()
    local chars = workspace:FindFirstChild("characters") if not chars then return nil end
    local myChar = chars:FindFirstChild(Player.Name) if not myChar then return nil end
    local state = myChar:FindFirstChild("state") if not state then return nil end
    local team = state:FindFirstChild("team")
    return team and team.Value or nil
end

function AP_GetMyRole()
    local chars = workspace:FindFirstChild("characters") if not chars then return nil end
    local myChar = chars:FindFirstChild(Player.Name) if not myChar then return nil end
    local state = myChar:FindFirstChild("state") if not state then return nil end
    local role = state:FindFirstChild("role")
    return role and role.Value or ""
end

function AP_CountPlayersWithRole(targetRole)
    local count = 0
    local chars = workspace:FindFirstChild("characters") if not chars then return 0 end
    for _, charFolder in pairs(chars:GetChildren()) do
        if charFolder.Name ~= Player.Name then 
            local state = charFolder:FindFirstChild("state")
            if state then
                local role = state:FindFirstChild("role")
                if role and tostring(role.Value) == tostring(targetRole) then 
                    count = count + 1 
                end
            end
        end
    end
    return count
end

function AP_FireCFPackets()
    local byteNet = AP_FindByte() if not byteNet then return end
    pcall(function() byteNet:FireServer(BN_SelectRoleBuffer(1, "A")) end)
    pcall(function() byteNet:FireServer(BN_SelectRoleBuffer(1, "B")) end)
end

function AP_FireGKPackets()
    local byteNet = AP_FindByte() if not byteNet then return end
    pcall(function() byteNet:FireServer(BN_SelectRoleBuffer(5, "B")) end)
    pcall(function() byteNet:FireServer(BN_SelectRoleBuffer(5, "A")) end)
end

function AP_CheckAndGetRole(targetRole, firePackets)
    
    local myRole = AP_GetMyRole()
    if myRole and myRole ~= "" then
        
        return false
    end
    
    
    local myTeam = AP_GetMyTeam()
    if myTeam and myTeam ~= "" then
        
        return false
    end
    
    
    local playersWithRole = AP_CountPlayersWithRole(targetRole)
    if playersWithRole >= 2 then
        
        return false
    end
    
    
    firePackets()
    task.wait(0.1)
    
    
    local newRole = AP_GetMyRole()
    return newRole == targetRole
end

function AP_StartLoop(mode, targetRole, firePackets)
    local data = mode == "CF" and AutoPosition.CF or AutoPosition.GK
    if data.LoopThread then task.cancel(data.LoopThread) data.LoopThread = nil end
    data.LoopThread = task.spawn(function()
        while data.Enabled do
            local myRole = AP_GetMyRole()
            
            if myRole and myRole ~= "" then
                task.wait(0.5)
            else
                
                local playersWithRole = AP_CountPlayersWithRole(targetRole)
                if playersWithRole < 2 then
                    AP_CheckAndGetRole(targetRole, firePackets)
                end
                task.wait(0.5)
            end
        end
    end)
end

function AutoPosition.StartCF()
    if AutoPosition.CF.Enabled then return end
    AutoPosition.CF.Enabled = true
    AutoPosition.CF.Connection = Player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if AutoPosition.CF.Enabled then AP_CheckAndGetRole("CF", AP_FireCFPackets) end
    end)
    AP_StartLoop("CF", "CF", AP_FireCFPackets)
    SafeNotify("<font color='#A6BAFF'>[ Auto CF ]</font> Enabled!", 2)
end

function AutoPosition.StopCF()
    AutoPosition.CF.Enabled = false
    if AutoPosition.CF.Connection then AutoPosition.CF.Connection:Disconnect() AutoPosition.CF.Connection = nil end
    if AutoPosition.CF.LoopThread then task.cancel(AutoPosition.CF.LoopThread) AutoPosition.CF.LoopThread = nil end
    SafeNotify("<font color='#A6BAFF'>[ Auto CF ]</font> Disabled!", 2)
end

function AutoPosition.StartGK()
