    if not VenomTrap.CachedCFBall or not VenomTrap.CachedCFBall.Parent then
        VenomTrap.CachedCFBall = Services.ReplicatedStorage:FindFirstChild("CFBall")
    end
    return VenomTrap.CachedCFBall
end
function VT_HasBall(playerName)
    local chars = VT_GetChars()
    local char = chars and chars:FindFirstChild(playerName or Player.Name)
    return char and char:FindFirstChild("Ball")
end
function VT_GetPlayerTeam()
    if not Player.Character then return nil end
    local state = Player.Character:FindFirstChild("state")
    if not state then return nil end
    local teamValue = state:FindFirstChild("team")
    return teamValue and teamValue.Value or nil
end
function VT_IsInGoalbox(position, team)
    local goalbox = VenomTrap.Goalboxes[team]
    if not goalbox then return false end
    return position.X >= goalbox.minX and position.X <= goalbox.maxX and
           position.Z >= goalbox.minZ and position.Z <= goalbox.maxZ
end
function VT_FindBallOwnerTeam()
    local chars = VT_GetChars()
    if not chars then return nil end
    for _, playerFolder in ipairs(chars:GetChildren()) do
        if playerFolder:FindFirstChild("Ball") then
            local state = playerFolder:FindFirstChild("state")
            if state then
                local teamValue = state:FindFirstChild("team")
                if teamValue then return teamValue.Value end
            end
        end
    end
    return nil
end
function VT_IsBallComingTowardsPlayer(ball, ballVelocity, playerPosition)
    if not ball or ballVelocity.Magnitude == 0 then return false end
    local ballDirection = ballVelocity.Unit
    local toPlayerVector = (playerPosition - ball.Position).Unit
    local dotProduct = ballDirection:Dot(toPlayerVector)
    return math.acos(math.clamp(dotProduct, -1, 1)) <= 0.7854
end
function VT_CanReachBall(ball, playerPosition)
    if not ball then return false end
    local bPos = ball.Position
    local horizontalDistance = (Vector3.new(playerPosition.X, 0, playerPosition.Z) - Vector3.new(bPos.X, 0, bPos.Z)).Magnitude
    if horizontalDistance > VenomTrap.MAX_BALL_DISTANCE then return false end
    if math.abs(playerPosition.Y - bPos.Y) > VenomTrap.MAX_VERTICAL_DISTANCE then return false end
    return true
end
function VT_IsEnemyFacingPlayer(enemyHRP, playerPosition)
    if not enemyHRP then return false end
    local dotProduct = enemyHRP.CFrame.LookVector:Dot((playerPosition - enemyHRP.Position).Unit)
    return math.acos(math.clamp(dotProduct, -1, 1)) <= 0.349
end

function VenomTrap.PerformDefense()
    if IsSkillOnCooldown("skill3") then return false end
    pcall(function() VenomTrap.ByteNetReliable:FireServer(BN_UseBuffer(), {{"skill3"}}) end)
    return true
end

function VenomTrap.ProcessAnimationPredict(myTeam, myPos)
    local chars = VT_GetChars()
    if not chars then return end
    local shouldDefend = not VenomTrap.GoalboxOnly or VT_IsInGoalbox(myPos, myTeam)
    if not shouldDefend then return end
    local currentTime = tick()
    for _, targetChar in ipairs(chars:GetChildren()) do
        if targetChar.Name ~= Player.Name and targetChar:FindFirstChild("Ball") then
            local state = targetChar:FindFirstChild("state")
            local targetTeam = state and state:FindFirstChild("team")
            targetTeam = targetTeam and targetTeam.Value
            if targetTeam and targetTeam ~= "lobby" and targetTeam ~= myTeam then
                local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetChar:FindFirstChild("Humanoid")
                local animator = targetHumanoid and targetHumanoid:FindFirstChildOfClass("Animator")
                if targetHRP and animator then
                    local distance = (targetHRP.Position - myPos).Magnitude
                    if distance <= 87 and VT_IsEnemyFacingPlayer(targetHRP, myPos) then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            local animId = track.Animation and track.Animation.AnimationId
                            if animId and track.IsPlaying and VenomTrap.AnimationSet[animId] then
                                local animationDelay = VenomTrap.Animations[animId]
                                local targetPlayer = Services.Players:FindFirstChild(targetChar.Name)
                                if targetPlayer then
                                    local trackingKey = targetPlayer.UserId.."_"..animId
                                    if not VenomTrap.AnimationTracking[trackingKey] then
                                        VenomTrap.AnimationTracking[trackingKey] = {
                                            detectedTime = currentTime, hasTriggered = false, delay = animationDelay
                                        }
                                    end
                                    local animData = VenomTrap.AnimationTracking[trackingKey]
                                    if not animData.hasTriggered and (currentTime - animData.detectedTime) >= animData.delay then
                                        if currentTime - VenomTrap.LastDefenseTime > 2 and not IsSkillOnCooldown("skill3") then
                                            VenomTrap.LastDefenseTime = currentTime
                                            VenomTrap.PerformDefense()
                                            animData.hasTriggered = true
                                        end
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    for trackingKey, data in pairs(VenomTrap.AnimationTracking) do
        if currentTime - data.detectedTime > 5 then VenomTrap.AnimationTracking[trackingKey] = nil end
    end
end

function VenomTrap.ProcessDefense(myTeam, playerPos)
    local currentOwnerTeam = VT_FindBallOwnerTeam()
    if currentOwnerTeam then VenomTrap.lastBallOwnerTeam = currentOwnerTeam end
    if VT_HasBall(Player.Name) then return end
    local ball = Services.Workspace.Terrain:FindFirstChild("Ball") or Services.Workspace:FindFirstChild("Ball")
    if not ball then return end
    local cfBall = VT_GetCFBall()
    local velocity = cfBall and cfBall:FindFirstChild("velocity")
    if not velocity then return end
    local ballVelocity = velocity.Value
    local realSpeed = ballVelocity.Magnitude
    if realSpeed < 200 then return end
    local distanceToBall = (ball.Position - playerPos).Magnitude
    local timeToImpact = distanceToBall / realSpeed
    if timeToImpact > 0.3 then return end
    if not VT_IsBallComingTowardsPlayer(ball, ballVelocity, playerPos) then return end
    if not VT_CanReachBall(ball, playerPos) then return end
    if not VenomTrap.lastBallOwnerTeam or not myTeam then return end
    if VenomTrap.lastBallOwnerTeam == "lobby" or myTeam == "lobby" then return end
    if VenomTrap.lastBallOwnerTeam == myTeam then return end
    local shouldDefend = not VenomTrap.GoalboxOnly or VT_IsInGoalbox(playerPos, myTeam)
    local currentTime = tick()
    if shouldDefend and currentTime - VenomTrap.LastDefenseTime > 2 and not IsSkillOnCooldown("skill3") then
        VenomTrap.LastDefenseTime = currentTime
        VenomTrap.PerformDefense()
    end
end

function VT_Update()
    if not VenomTrap.Enabled or not Player.Character then return end
    if not VT_IsAiku() then return end
    local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local myTeam = VT_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    local myPos = hrp.Position
    VenomTrap.ProcessDefense(myTeam, myPos)
    VenomTrap.ProcessAnimationPredict(myTeam, myPos)
end

