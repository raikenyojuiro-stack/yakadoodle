    SafeNotify("<font color='#A6BAFF'>[ Auto GK ]</font> Enabled!", 2)
end

function AutoPosition.StopGK()
    AutoPosition.GK.Enabled = false
    if AutoPosition.GK.Connection then AutoPosition.GK.Connection:Disconnect() AutoPosition.GK.Connection = nil end
    if AutoPosition.GK.LoopThread then task.cancel(AutoPosition.GK.LoopThread) AutoPosition.GK.LoopThread = nil end
    SafeNotify("<font color='#A6BAFF'>[ Auto GK ]</font> Disabled!", 2)
end


local BallMagnet = {
    Enabled = false, GKAndGoalboxOnly = false, RequireHoldKey = false,
    HoldKeyDown = false, HoldKey = "MouseButton2", MouseConnections = {},
    ByteNetReliable = nil, MagnetRange = 25.47, Ball = nil,
    CachedChars = nil
}

BallMagnet.Goalboxes = {
    GK_A = {minX = -668.15, maxX = -407.51, minZ = 1611.19, maxZ = 1706.13},
    GK_B = {minX = -668.01, maxX = -407.68, minZ = 841.70, maxZ = 935.59}
}

function BM_FindBall()
    if BallMagnet.Ball and BallMagnet.Ball.Parent then return BallMagnet.Ball end
    local ball = Services.Workspace:FindFirstChild("Ball") or Services.Workspace.Terrain:FindFirstChild("Ball")
    if ball then BallMagnet.Ball = ball return ball end
    return nil
end

function BM_GetChars()
    if not BallMagnet.CachedChars or not BallMagnet.CachedChars.Parent then
        BallMagnet.CachedChars = Services.Workspace:FindFirstChild("characters")
    end
    return BallMagnet.CachedChars
end

function BM_IsGK()
    if not BallMagnet.GKAndGoalboxOnly then return true end
    local chars = BM_GetChars()
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return false end
    local state = myChar:FindFirstChild("state")
    local role = state and state:FindFirstChild("role")
    return role and role.Value == "GK"
end

function BM_GetPlayerTeam()
    if not Player.Character then return nil end
    local state = Player.Character:FindFirstChild("state")
    return state and state:FindFirstChild("team") and state.team.Value or nil
end

function BM_IsInGKGoalbox(pos, team)
    if not BallMagnet.GKAndGoalboxOnly then return true end
    local g = BallMagnet.Goalboxes["GK_"..team] if not g then return false end
    return pos.X >= g.minX and pos.X <= g.maxX and pos.Z >= g.minZ and pos.Z <= g.maxZ
end

function BallMagnet.Process()
    if not BallMagnet.Enabled then return end
    if BallMagnet.RequireHoldKey and not BallMagnet.HoldKeyDown then return end
    if not BM_IsGK() then return end
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local team = BM_GetPlayerTeam() if not team then return end
    if not BM_IsInGKGoalbox(hrp.Position, team) then return end
    local ball = BM_FindBall() if not ball then return end
    if (hrp.Position - ball.Position).Magnitude > BallMagnet.MagnetRange then return end
    pcall(function() BallMagnet.ByteNetReliable:FireServer(BN_FindBallBuffer()) end)
end

function BM_SetupHoldKey()
    for _, c in ipairs(BallMagnet.MouseConnections) do if c then c:Disconnect() end end
    BallMagnet.MouseConnections = {}
    BallMagnet.HoldKeyDown = false
    if not BallMagnet.RequireHoldKey then return end
    local function isTargetKey(input)
        local targetKey = BallMagnet.HoldKey
        if targetKey:find("MouseButton") then
            return input.UserInputType and input.UserInputType.Name == targetKey
        else
            if input.KeyCode then
                local currentKey = tostring(input.KeyCode):match("%.([^%.]+)$") or tostring(input.KeyCode)
                return currentKey == targetKey
            end
        end
        return false
    end
    local down = Services.UIS.InputBegan:Connect(function(input, gp)
        if gp then return end
        if isTargetKey(input) then BallMagnet.HoldKeyDown = true end
    end)
    local up = Services.UIS.InputEnded:Connect(function(input)
        if isTargetKey(input) then BallMagnet.HoldKeyDown = false end
    end)
    table.insert(BallMagnet.MouseConnections, down)
    table.insert(BallMagnet.MouseConnections, up)
end

function BallMagnet.Start()
    BallMagnet.ByteNetReliable = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not BallMagnet.ByteNetReliable then
        SafeNotify("<font color='#A6BAFF'>[ Ball Magnet ]</font> ByteNetReliable not found!", 5)
        return
    end
    BallMagnet.CachedChars = Services.Workspace:FindFirstChild("characters")
    BallMagnet.Enabled = true
    BM_SetupHoldKey()
    BM_FindBall()
    BallMagnet.Connection = Services.RunService.Heartbeat:Connect(BallMagnet.Process)
    SafeNotify("<font color='#A6BAFF'>[ Ball Magnet ]</font> Activated!", 2)
end

function BallMagnet.Stop()
    BallMagnet.Enabled = false
    if BallMagnet.Connection then BallMagnet.Connection:Disconnect() BallMagnet.Connection = nil end
    for _, c in ipairs(BallMagnet.MouseConnections) do if c then c:Disconnect() end end
    BallMagnet.MouseConnections = {}
    BallMagnet.Ball = nil
    BallMagnet.CachedChars = nil
    SafeNotify("<font color='#A6BAFF'>[ Ball Magnet ]</font> Deactivated!", 2)
end

function BallMagnet.SetGKGoalboxOnly(v) BallMagnet.GKAndGoalboxOnly = v end
function BallMagnet.SetRequireHoldKey(v) BallMagnet.RequireHoldKey = v BM_SetupHoldKey() end
function BallMagnet.SetHoldKey(newKey) BallMagnet.HoldKey = newKey if BallMagnet.RequireHoldKey then BM_SetupHoldKey() end end
function BallMagnet.SetMagnetRange(v) BallMagnet.MagnetRange = v end


