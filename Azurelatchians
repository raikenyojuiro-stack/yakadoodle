function AutoOffBallAwk.IsInGoalbox(pos, team) local g = AutoOffBallAwk.Goalboxes[team] return g and pos.X >= g.minX and pos.X <= g.maxX and pos.Z >= g.minZ and pos.Z <= g.maxZ end
function AutoOffBallAwk.IsBallComing(ball, vel, pPos) if not ball or vel.Magnitude == 0 then return false end return vel.Unit:Dot((pPos - ball.Position).Unit) > math.cos(math.rad(45)) end
function AutoOffBallAwk.CanReach(ball, pPos) if not ball then return false end local hd = (Vector3.new(pPos.X, 0, pPos.Z) - Vector3.new(ball.Position.X, 0, ball.Position.Z)).Magnitude return hd <= AutoOffBallAwk.MAX_BALL_DISTANCE and math.abs(pPos.Y - ball.Position.Y) <= AutoOffBallAwk.MAX_VERTICAL_DISTANCE end
function AutoOffBallAwk.SpamBaseAwaken()
    if AutoOffBallAwk.IsSpammingG then return end AutoOffBallAwk.IsSpammingG = true local st = tick()
    while tick() - st < AutoOffBallAwk.SpamDuration and AutoOffBallAwk.Enabled do if AutoOffBallAwk.ByteNetReliable then pcall(function() AutoOffBallAwk.ByteNetReliable:FireServer(BN_UseBuffer(), {{"baseAwaken", false}}) end) end task.wait(0.1) end
    AutoOffBallAwk.IsSpammingG = false
end
function AutoOffBallAwk.ProcessDefense()
    if not AutoOffBallAwk.Enabled or not Player.Character or AutoOffBallAwk.GetFlow() ~= 100 or not AutoOffBallAwk.IsSupportedStyle() then return end
    local hrp = Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local ownerTeam = AutoOffBallAwk.FindBallOwnerTeam() if ownerTeam then AutoOffBallAwk.lastBallOwnerTeam = ownerTeam end
    if not AutoOffBallAwk.HasBall() then
        local ball = Services.Workspace.Terrain:FindFirstChild("Ball") or Services.Workspace:FindFirstChild("Ball")
        local cfBall = ball and Services.ReplicatedStorage:FindFirstChild("CFBall")
        if cfBall and cfBall:FindFirstChild("velocity") then
            local vel, spd = cfBall.velocity.Value, cfBall.velocity.Value.Magnitude
            
            local minSpeed = AutoOffBallAwk.WorksOnHeelFlicks and 5 or 100
            if spd >= minSpeed and AutoOffBallAwk.IsBallComing(ball, vel, hrp.Position) and (ball.Position - hrp.Position).Magnitude / spd <= 0.3 and AutoOffBallAwk.CanReach(ball, hrp.Position) then
                local myTeam = AutoOffBallAwk.GetPlayerTeam()
                
                if AutoOffBallAwk.lastBallOwnerTeam and myTeam and AutoOffBallAwk.lastBallOwnerTeam ~= "lobby" and myTeam ~= "lobby" and AutoOffBallAwk.lastBallOwnerTeam ~= myTeam then
                    if (not AutoOffBallAwk.GoalboxOnly or AutoOffBallAwk.IsInGoalbox(hrp.Position, myTeam)) and tick() - AutoOffBallAwk.LastDefenseTime > 2 then
                        AutoOffBallAwk.LastDefenseTime = tick() task.spawn(AutoOffBallAwk.SpamBaseAwaken)
                    end
                end
            end
        end
    end
end
function AutoOffBallAwk.Start()
    AutoOffBallAwk.ByteNetReliable = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not AutoOffBallAwk.ByteNetReliable then SafeNotify("<font color='#A6BAFF'>[ Off Ball Awk ]</font> ByteNetReliable not found!", 5) return end
