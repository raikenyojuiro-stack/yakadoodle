        buff.IsTeleporting = true
        local startPos, startCFrame, startTime = hrp.Position, hrp.CFrame, tick()
        local dirVec = direction == "right" and startCFrame.RightVector or -startCFrame.RightVector
        local lookVec = startCFrame.LookVector
