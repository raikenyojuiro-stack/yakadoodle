function LineUpCreator.GetMouseTarget()
    local camera = workspace.CurrentCamera
    if not camera then return nil end
    
    local char = Player.Character
    
    local MAX_DIST = 1000
    local MIN_VALID_DIST = 35
    local MAX_SKIPS = 40
    
    
    local vps = camera.ViewportSize
    local ray = camera:ViewportPointToRay(vps.X * 0.5, vps.Y * 0.5)
    local origin = ray.Origin
    local dir = ray.Direction.Unit
    
    
    local blacklist = {}
    if char then table.insert(blacklist, char) end
    table.insert(blacklist, camera)
    
    for _ = 1, MAX_SKIPS do
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = blacklist
        params.IgnoreWater = true
        
        local result = workspace:Raycast(origin, dir * MAX_DIST, params)
        
        if not result then
            return origin + dir * MAX_DIST
        end
        
        local hitPos = result.Position
        local dist = (hitPos - origin).Magnitude
        
        
        if dist < MIN_VALID_DIST then
            table.insert(blacklist, result.Instance)
        else
            return hitPos
        end
    end
    
    return origin + dir * MIN_VALID_DIST
end

