function AutoCounter.StartGlobalFlowTracking()
    if AutoCounter.GlobalFlowConnection then return end
    
    
    local flowObj = AutoCounter.FindFlow()
    if flowObj then
        local value = flowObj.Value
        if value >= 100 then
            AutoCounter.SkillSwapHasReached100 = true
            AutoCounter.SkillSwapWasAbove100 = true
        elseif value > 0 and value < 100 and AutoCounter.SkillSwapWasAbove100 then
            AutoCounter.SkillSwapHasReached100 = true
        end
        AutoCounter.SkillSwapLastFlowValue = value
    else
        AutoCounter.ResetSkillSwapStates()
    end
    
    
    AutoCounter.LastFlowCheck = 0
    AutoCounter.GlobalFlowConnection = Services.RunService.Heartbeat:Connect(function()
        local now = tick()
        if now - AutoCounter.LastFlowCheck < 0.1 then return end
        AutoCounter.LastFlowCheck = now
        AutoCounter.UpdateSkillSwapFlowState()
        AutoCounter.UpdateRinFlowSkill()
    end)
    
    
    AutoCounter.GlobalCharacterConnection = Player.CharacterAdded:Connect(function()
        task.wait(1)
        AutoCounter.ResetSkillSwapStates()
        AutoCounter.ResetSkillToDefault("kaiser")
        AutoCounter.ResetSkillToDefault("nelisagi")
        
