function VSCD_IsEnemyPlayingAnimation(enemyChar, animationIds)
    local humanoid = enemyChar:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false, nil end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return false, nil end
    
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.IsPlaying and track.Animation then
            local animId = tostring(track.Animation.AnimationId):match("%d+")
            if animId then
                for checkId, _ in pairs(animationIds) do
                    if animId == checkId then
                        return true, animId
                    end
                end
            end
        end
    end
    return false, nil
end

function VSCD_UpdateFlowState(enemyData, flowValue)
    if flowValue >= 100 then
        enemyData.flowWasAbove100 = true
        enemyData.flowActive = false
    elseif flowValue < 100 and enemyData.flowWasAbove100 then
        
        if enemyData.style == "reo" then
            if enemyData.reoSpecialAnimPlayed then
                enemyData.flowActive = true
            else
                enemyData.flowActive = false
            end
        else
            enemyData.flowActive = true
        end
    end
    
    if flowValue <= 0 then
        enemyData.flowWasAbove100 = false
        enemyData.flowActive = false
        if enemyData.style == "reo" then
            enemyData.reoSpecialAnimPlayed = false 
        end
    end
    
    enemyData.lastFlowValue = flowValue
end

function VSCD_ProcessEnemy(enemyPlayer)
    local myTeam = VSCD_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    
    local enemyTeam = VSCD_GetEnemyTeam(enemyPlayer.Name)
    if not enemyTeam or enemyTeam == "lobby" or enemyTeam == myTeam then return end
    
    local enemyStyle = VSCD_GetEnemyStyle(enemyPlayer)
    if not enemyStyle or not VariantStealCD.TrackedStyles[enemyStyle] then return end
    
    local enemyChar = VSCD_GetEnemyCharacter(enemyPlayer.Name)
    if not enemyChar then return end
    
    
    if not VariantStealCD.TrackedEnemies[enemyPlayer.Name] then
        VariantStealCD.TrackedEnemies[enemyPlayer.Name] = {
            player = enemyPlayer,
            character = enemyChar,
            style = enemyStyle,
            flowActive = false,
            flowWasAbove100 = false,
            lastFlowValue = 0,
            hasPredictAnimation = false,
            cooldownEndTime = 0,
            isCooldownActive = false,
            cooldownPausedAt = 0,
            cooldownPausedRemaining = 0,
            isPaused = false,
            isOneTime = false,
            reoSpecialAnimPlayed = false 
        }
    end
    
    local enemyData = VariantStealCD.TrackedEnemies[enemyPlayer.Name]
    enemyData.character = enemyChar
    enemyData.style = enemyStyle
    
    
    if enemyStyle == "reo" and not enemyData.reoSpecialAnimPlayed then
        local humanoid = enemyChar:FindFirstChildOfClass("Humanoid")
        if humanoid then
            for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                if track.Animation and track.IsPlaying then
                    local animId = tostring(track.Animation.AnimationId)
                    if animId:find(VariantStealCD.ReoSpecialAnimation) then
                        enemyData.reoSpecialAnimPlayed = true
                        break
                    end
                end
            end
        end
    end
    
    
    local flowObj = VSCD_GetEnemyFlow(enemyPlayer.Name)
    if flowObj then
        VSCD_UpdateFlowState(enemyData, flowObj.Value)
    else
        enemyData.flowActive = false
        enemyData.flowWasAbove100 = false
    end
    
    
    local hasPredictAnim, predictAnimId = VSCD_IsEnemyPlayingAnimation(enemyChar, VariantStealCD.PredictAnimations)
    if hasPredictAnim and not enemyData.hasPredictAnimation and not enemyData.isCooldownActive then
        local predictData = VariantStealCD.PredictAnimations[predictAnimId]
        if predictData then
            enemyData.hasPredictAnimation = true
            
            
            enemyData.isCooldownActive = true
            enemyData.cooldownEndTime = tick() + predictData.cooldown
            enemyData.isOneTime = false
            enemyData.isPaused = false
        end
    end
    
    
    local hasStealAnim, stealAnimId = VSCD_IsEnemyPlayingAnimation(enemyChar, VariantStealCD.StealAnimations)
    if hasStealAnim and not enemyData.isCooldownActive then
        local stealData = VariantStealCD.StealAnimations[stealAnimId]
        if stealData then
            
            enemyData.isCooldownActive = true
            enemyData.cooldownEndTime = tick() + stealData.cooldown
            enemyData.isOneTime = stealData.oneTime
            enemyData.isPaused = false
            
            
            VSCD_UpdateGlowColor(enemyChar, Color3.fromRGB(255, 0, 0))
        end
    end
    
    
    local isCutscene = AD_IsCutsceneActive()
    if enemyData.isCooldownActive and not enemyData.isOneTime then
        if isCutscene and not enemyData.isPaused then
            
            enemyData.isPaused = true
            enemyData.cooldownPausedAt = tick()
            enemyData.cooldownPausedRemaining = enemyData.cooldownEndTime - tick()
        elseif not isCutscene and enemyData.isPaused then
            
            enemyData.isPaused = false
            enemyData.cooldownEndTime = tick() + enemyData.cooldownPausedRemaining
        end
    end
    
    
    local now = tick()
    
    
    if not enemyData.flowActive and enemyData.lastFlowValue <= 0 then
        VSCD_RemoveGlow(enemyChar)
        enemyData.isCooldownActive = false
        enemyData.isOneTime = false
        enemyData.isPaused = false
        enemyData.hasPredictAnimation = false
        return
    end
    
    
    if enemyData.isCooldownActive then
        
        if not enemyData.isPaused and now >= enemyData.cooldownEndTime then
            enemyData.isCooldownActive = false
            enemyData.isOneTime = false
            enemyData.hasPredictAnimation = false
            
            
            if enemyData.flowActive then
                VSCD_UpdateGlowColor(enemyChar, Color3.fromRGB(0, 255, 0))
            else
                VSCD_RemoveGlow(enemyChar)
            end
        elseif enemyData.isOneTime then
            
            if not hasStealAnim then
                enemyData.isCooldownActive = false
                enemyData.isOneTime = false
                
                if enemyData.flowActive then
                    VSCD_UpdateGlowColor(enemyChar, Color3.fromRGB(0, 255, 0))
                else
                    VSCD_RemoveGlow(enemyChar)
                end
            end
        else
            
            if enemyData.flowActive then
                VSCD_UpdateGlowColor(enemyChar, Color3.fromRGB(255, 0, 0))
            else
                
                VSCD_RemoveGlow(enemyChar)
            end
        end
    
    elseif enemyData.flowActive then
        
        VSCD_UpdateGlowColor(enemyChar, Color3.fromRGB(0, 255, 0))
    
    else
        VSCD_RemoveGlow(enemyChar)
        enemyData.hasPredictAnimation = false
    end
end

function VSCD_Update()
    if not VariantStealCD.Enabled then return end
    
    
    for _, enemyPlayer in ipairs(Services.Players:GetPlayers()) do
        if enemyPlayer ~= Player then
