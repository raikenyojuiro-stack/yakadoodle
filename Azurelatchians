end

function Core.StartMoving()
    if Core.IsMoving then return end
    Core.IsMoving = true
    
    
    Core.MoveThread = task.spawn(function()
        while Core.IsMoving do
            if Player.Character then
                local h = Player.Character:FindFirstChildOfClass("Humanoid")
                local r = Player.Character:FindFirstChild("HumanoidRootPart")
                if h and r then
                    local lookDir = r.CFrame.LookVector
                    h:Move(Vector3.new(lookDir.X, 0, lookDir.Z), false)
                end
            end
            task.wait(0.01)
        end
    end)
end

function Core.StopMoving()
    Core.IsMoving = false
    if Core.MoveThread then
        pcall(function() task.cancel(Core.MoveThread) end)
        Core.MoveThread = nil
    end
    if Player.Character then
        local h = Player.Character:FindFirstChildOfClass("Humanoid")
        if h then h:Move(Vector3.new(0, 0, 0), false) end
    end
end

function Core.Combo()
    if not Core.Enabled or Core.Debounce then return end
    
    if AD_IsCutsceneActive() then return end
    
    
    local isShidou = CheckStyle("shidou")
    local isReoWithFormless = Core.IsReoWithFormless()
    
    if not isShidou and not isReoWithFormless then return end
    if not HasBall() then return end
    
    
    local skillToUse = isShidou and "skill1" or "skill4"
    
    if Core.SkillOnCooldown(skillToUse) then
        SafeNotify("<font color='#A6BAFF'>[ Formless ]</font> Ability on cooldown!", 2)
        return
    end

    Core.Debounce = true
    local char = Player.Character
    if not char then Core.Debounce = false return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then Core.Debounce = false return end

    local byteNet = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not byteNet then Core.Debounce = false return end

    
    Core.IsMoving = true
    Core.MoveThread = task.spawn(function()
        while Core.IsMoving do
            pcall(function()
                if Player.Character then
                    local r = Player.Character:FindFirstChild("HumanoidRootPart")
                    if r then
                        
                        local lookDir = r.CFrame.LookVector
                        local flatDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
                        r.CFrame = r.CFrame + flatDir * 0.3
                    end
                end
            end)
            task.wait(0.02)
        end
    end)

    
    humanoid.AutoRotate = false
    
    
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(180), 0)
    
    
    local camera = workspace.CurrentCamera
    local camType = camera.CameraType
    local camSubject = camera.CameraSubject
    camera.CameraType = Enum.CameraType.Scriptable
    camera.CFrame = hrp.CFrame + Vector3.new(0, 2, 0)
    
    task.delay(0.1, function()
        if Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") then
            camera.CameraSubject = Player.Character:FindFirstChildOfClass("Humanoid")
            camera.CameraType = Enum.CameraType.Custom
        else
            camera.CameraSubject = camSubject
            camera.CameraType = camType
        end
        if humanoid then humanoid.AutoRotate = true end
    end)
    
    
    Core.PlayKickAnimation()
    task.wait(0.05)
    
    
    local kickVec = hrp.CFrame.LookVector + Vector3.new(0, 1, 0) * 50
    pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"kick", 45, false, kickVec}}) end)
    
    task.wait(0.1)
    
    
    pcall(function() byteNet:FireServer(BN_UseBuffer(), {{skillToUse}}) end)
    
    
    task.wait(1.0)
    Core.StopMoving()
    
    Core.StopKickAnimation()
    Core.Debounce = false
end

