function UIUpgrade.RevertAll()
    UIUpgrade.TextAnimationRunning = false
    for _, iconObj in pairs(UIUpgrade.CreatedIcons) do
        if iconObj and iconObj.Parent then iconObj:Destroy() end
    end
    UIUpgrade.CreatedIcons = {}
    for _, cornerObj in pairs(UIUpgrade.CreatedCorners) do
        if cornerObj and cornerObj.Parent then cornerObj:Destroy() end
    end
    UIUpgrade.CreatedCorners = {}
    for _, data in pairs(UIUpgrade.OriginalValues) do
        if data.obj and data.obj.Parent then
            pcall(function() data.obj[data.property] = data.value end)
        end
    end
    UIUpgrade.OriginalValues = {}
    for _, conn in pairs(UIUpgrade.Connections) do
        if conn then conn:Disconnect() end
    end
    UIUpgrade.Connections = {}
end


