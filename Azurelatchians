function HideShotAnimation.GetMyTeam()
    local chars = Services.Workspace:FindFirstChild("characters")
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return nil end
    local state = myChar:FindFirstChild("state")
    return state and state:FindFirstChild("team") and state.team.Value or nil
end

function HideShotAnimation.IsInEnemyGoalbox(position, myTeam)
    local enemyGoalbox = HideShotAnimation.Goalboxes[myTeam == "A" and "B" or "A"]
    if not enemyGoalbox then return false end
    return position.X >= enemyGoalbox.minX and position.X <= enemyGoalbox.maxX and
           position.Z >= enemyGoalbox.minZ and position.Z <= enemyGoalbox.maxZ
end

function HideShotAnimation.EnemyTeamHasGK(myTeam)
    local enemyTeam = myTeam == "A" and "B" or "A"
    local chars = Services.Workspace:FindFirstChild("characters")
    if not chars then return false end
    for _, charFolder in pairs(chars:GetChildren()) do
        if charFolder.Name ~= Player.Name then
            local state = charFolder:FindFirstChild("state")
            if state then
                local teamValue = state:FindFirstChild("team")
                local roleValue = state:FindFirstChild("role")
                if teamValue and roleValue and teamValue.Value == enemyTeam and roleValue.Value == "GK" then
                    return true
                end
            end
        end
    end
    return false
end

function HideShotAnimation.GetCurrentAnimationId()
    if not Player.Character then return nil end
    local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return nil end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.IsPlaying then
            local animId = tostring(track.Animation.AnimationId)
            local num = string.match(animId, "(%d+)$") or string.match(animId, "://(%d+)")
            if num and HideShotAnimation.SkillAnimations[num] then
                return num
            end
        end
    end
    return nil
end

function HideShotAnimation.StopAllAnimations()
    if HideShotAnimation.CurrentFastTrack then
        HideShotAnimation.CurrentFastTrack:Stop()
        HideShotAnimation.CurrentFastTrack = nil
    end
    if HideShotAnimation.CurrentNormalTrack then
        HideShotAnimation.CurrentNormalTrack:Stop()
        HideShotAnimation.CurrentNormalTrack = nil
    end
end

function HideShotAnimation.PlayBothAnimationsOnce()
    HideShotAnimation.StopAllAnimations()
    if not Player.Character then return end
    local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local FastAnim = Instance.new("Animation")
    FastAnim.AnimationId = "rbxassetid://" .. HideShotAnimation.FastAnimationId
    HideShotAnimation.CurrentFastTrack = humanoid:LoadAnimation(FastAnim)
    HideShotAnimation.CurrentFastTrack.Looped = false
    HideShotAnimation.CurrentFastTrack:Play(0.1, 1, HideShotAnimation.FastAnimationSpeed)
    HideShotAnimation.CurrentFastTrack.Stopped:Connect(function()
        HideShotAnimation.CurrentFastTrack = nil
    end)
    
    local NormalAnim = Instance.new("Animation")
    NormalAnim.AnimationId = "rbxassetid://" .. HideShotAnimation.NormalAnimationId
    HideShotAnimation.CurrentNormalTrack = humanoid:LoadAnimation(NormalAnim)
    HideShotAnimation.CurrentNormalTrack.Looped = false
    HideShotAnimation.CurrentNormalTrack:Play(0.1, 1, HideShotAnimation.NormalAnimationSpeed)
    HideShotAnimation.CurrentNormalTrack.Stopped:Connect(function()
        HideShotAnimation.CurrentNormalTrack = nil
    end)
end

function HideShotAnimation.ShouldActivate()
    if not HideShotAnimation.OnlyWhenGKNearGoalbox then return true end
    local myTeam = HideShotAnimation.GetMyTeam()
    if not myTeam or myTeam == "lobby" then return false end
    if not HideShotAnimation.EnemyTeamHasGK(myTeam) then return false end
    local chars = Services.Workspace:FindFirstChild("characters")
    local myChar = chars and chars:FindFirstChild(Player.Name)
    if not myChar then return false end
    local hrp = myChar:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return HideShotAnimation.IsInEnemyGoalbox(hrp.Position, myTeam)
end

function HideShotAnimation.Start()
    if HideShotAnimation.Connection then return end
    HideShotAnimation.Enabled = true
    HideShotAnimation.LastAnimId = nil
    HideShotAnimation.LastDetectionTime = 0
    
    HideShotAnimation.Connection = Services.RunService.Heartbeat:Connect(function()
        if not HideShotAnimation.Enabled then return end
        local currentTime = tick()
        local currentAnimId = HideShotAnimation.GetCurrentAnimationId()
        
        if currentAnimId and currentAnimId ~= HideShotAnimation.LastAnimId and 
           (currentTime - HideShotAnimation.LastDetectionTime) > HideShotAnimation.Cooldown then
            if HideShotAnimation.ShouldActivate() then
