local LineUpIndexMap = {} 

local function GetLineUpOptions()
    local options = {"None"}
    LineUpIndexMap = {}
    local currentStyle = Player:GetAttribute("style")
    if LineUpCreator.CustomLineUps and currentStyle then
        local displayIndex = 1
        for i, lineup in ipairs(LineUpCreator.CustomLineUps) do
            
            local lineupStyle = lineup.style
            
            local baseStyle = lineupStyle:gsub("_flow%d?$", "")
            
            if baseStyle == currentStyle then
                local flowText = lineup.isFlow and " (flow)" or ""
                table.insert(options, displayIndex .. ". " .. lineup.team .. flowText)
                LineUpIndexMap[displayIndex] = i
                displayIndex = displayIndex + 1
            end
        end
    end
    return options
end

local SelectedLineUpIndex = nil
local LineUpDropdown = Menu.ComboBox("Main", "Auto Line Ups", "Select LineUp", "None", GetLineUpOptions(), function(v)
    if v == "None" then
        SelectedLineUpIndex = nil
        return
    end
    
    local displayIdx = tonumber(string.match(v, "^(%d+)%."))
    local realIdx = displayIdx and LineUpIndexMap[displayIdx]
    SelectedLineUpIndex = realIdx
    
    
    if realIdx and LineUpCreator.CustomLineUps[realIdx] then
        local lineup = LineUpCreator.CustomLineUps[realIdx]
        
        for _, marker in pairs(AutoLineUps.Markers) do
            if marker and marker.Parent then
                local markerPos = marker.Position
                local lineupPos = Vector3.new(lineup.targetPosition.X, lineup.targetPosition.Y, lineup.targetPosition.Z)
                if (Vector3.new(markerPos.X, 3, markerPos.Z) - lineupPos).Magnitude < 2 then
                    
                    local originalColor = marker.BrickColor
                    marker.BrickColor = BrickColor.new(Color3.fromRGB(0, 255, 0))
                    task.delay(0.3, function()
                        if marker and marker.Parent then
                            marker.BrickColor = BrickColor.new(Color3.fromRGB(0, 255, 0))
                        end
                    end)
                    task.delay(0.6, function()
                        if marker and marker.Parent then
                            marker.BrickColor = originalColor
                        end
                    end)
                    break
                end
            end
        end
    end
end)


LineUpCreator.RefreshDropdown = function()
    SelectedLineUpIndex = nil
    LineUpDropdown:SetValue("None", GetLineUpOptions())
end


Player:GetAttributeChangedSignal("style"):Connect(function()
    if LineUpCreator.RefreshDropdown then
        LineUpCreator.RefreshDropdown()
    end
end)

Menu.Button("Main", "Auto Line Ups", "Delete Selected LineUp", function()
    if not SelectedLineUpIndex then
        SafeNotify("<font color='#FF6B6B'>[ LineUp Creator ]</font> No lineup selected!", 2)
        return
    end
    
    if not LineUpCreator.CustomLineUps[SelectedLineUpIndex] then
        SafeNotify("<font color='#FF6B6B'>[ LineUp Creator ]</font> Invalid lineup!", 2)
        SelectedLineUpIndex = nil
        return
    end
    
    local removed = LineUpCreator.CustomLineUps[SelectedLineUpIndex]
    
    
    local styleName = removed.style
    if removed.isFlow and not string.find(styleName, "_flow$") then 
        styleName = styleName .. "_flow" 
    end
    
    local cfg = AutoLineUps.StylesConfig[styleName]
    if cfg and cfg.points[removed.team] then
        for i = #cfg.points[removed.team], 1, -1 do
            local point = cfg.points[removed.team][i]
            if point.isCustom then
                local posMatch = math.abs(point.targetPosition.X - removed.targetPosition.X) < 2 and
                                 math.abs(point.targetPosition.Z - removed.targetPosition.Z) < 2
                if posMatch then
                    table.remove(cfg.points[removed.team], i)
                    break
                end
            end
        end
    end
    
    
    table.remove(LineUpCreator.CustomLineUps, SelectedLineUpIndex)
    LineUpCreator.SaveConfig()
    
    
    if AutoLineUps.Enabled then
        AutoLineUps.CreateMarkers()
    end
    
    SafeNotify("<font color='#A6BAFF'>[ LineUp Creator ]</font> Deleted: " .. removed.style .. " " .. removed.team, 2)
    
    
    SelectedLineUpIndex = nil
    if LineUpCreator.RefreshDropdown then
        LineUpCreator.RefreshDropdown()
    end
end)


