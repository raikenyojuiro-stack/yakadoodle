function VSR_CreateRadiusCircle(character, radius, color)
    
    local existingCircle = character:FindFirstChild("VariantStealRadiusCircle")
    if existingCircle then existingCircle:Destroy() end
    
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    
    local circle = Instance.new("Part")
    circle.Name = "VariantStealRadiusCircle"
    circle.Size = Vector3.new(radius * 2, 0.1, radius * 2)
    circle.Anchored = true
    circle.CanCollide = false
    circle.Transparency = 0.9
    circle.Material = Enum.Material.Neon
    circle.Color = color
    circle.CastShadow = false
    circle.CFrame = CFrame.new(hrp.Position + Vector3.new(0, -2.5, 0))
    
    
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.Sphere
    mesh.Scale = Vector3.new(1, 0.01, 1)
    mesh.Parent = circle
    
    circle.Parent = workspace
    
    return circle
end

function VSR_UpdateRadiusCircle(circle, character, radius, color)
    if not circle or not circle.Parent then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    
    circle.CFrame = CFrame.new(hrp.Position + Vector3.new(0, -2.5, 0)) * hrp.CFrame.Rotation
    circle.Size = Vector3.new(radius * 2, 0.1, radius * 2)
    circle.Color = color
    circle.Transparency = 0.9
    
    return true
end

function VSR_RemoveRadiusCircle(character)
    local circle = character:FindFirstChild("VariantStealRadiusCircle")
    if circle then circle:Destroy() end
end

function VSR_RemoveRadiusCircleByName(enemyName)
    
    if VariantStealRadius.RadiusCircles[enemyName] then
        if VariantStealRadius.RadiusCircles[enemyName].Parent then
            VariantStealRadius.RadiusCircles[enemyName]:Destroy()
        end
        VariantStealRadius.RadiusCircles[enemyName] = nil
    end
    
    
    local enemyChar = VSR_GetEnemyCharacter(enemyName)
    if enemyChar then
        VSR_RemoveRadiusCircle(enemyChar)
    end
end

function VSR_GetGlowColor(enemyName)
    
    if VariantStealCD.TrackedEnemies[enemyName] then
        local enemyData = VariantStealCD.TrackedEnemies[enemyName]
        local character = enemyData.character
        if character then
            local glow = character:FindFirstChild("VariantStealGlow")
            if glow then
                return glow.FillColor
            end
        end
    end
    
    return Color3.fromRGB(0, 255, 0)
end

function VSR_ProcessEnemy(enemyPlayer)
    local myTeam = VSR_GetPlayerTeam()
    if not myTeam or myTeam == "lobby" then return end
    
    local enemyTeam = VSR_GetEnemyTeam(enemyPlayer.Name)
    if not enemyTeam or enemyTeam == "lobby" or enemyTeam == myTeam then return end
    
    local enemyStyle = VSR_GetEnemyStyle(enemyPlayer)
    if not enemyStyle or not VariantStealRadius.StyleRadius[enemyStyle] then 
        
        VSR_RemoveRadiusCircleByName(enemyPlayer.Name)
        return 
    end
    
    local enemyChar = VSR_GetEnemyCharacter(enemyPlayer.Name)
    if not enemyChar then 
        
        VSR_RemoveRadiusCircleByName(enemyPlayer.Name)
        return 
    end
    
    local radius = VariantStealRadius.StyleRadius[enemyStyle]
    
    
    local color = VSR_GetGlowColor(enemyPlayer.Name)
    
    
    local shouldShow = false
    if VariantStealCD.Enabled and VariantStealCD.TrackedEnemies[enemyPlayer.Name] then
        local enemyData = VariantStealCD.TrackedEnemies[enemyPlayer.Name]
        
        shouldShow = enemyData.flowActive
    end
    
    if shouldShow then
        
        if not VariantStealRadius.RadiusCircles[enemyPlayer.Name] then
            VariantStealRadius.RadiusCircles[enemyPlayer.Name] = VSR_CreateRadiusCircle(enemyChar, radius, color)
        else
            local success = VSR_UpdateRadiusCircle(VariantStealRadius.RadiusCircles[enemyPlayer.Name], enemyChar, radius, color)
            if not success then
                
                VariantStealRadius.RadiusCircles[enemyPlayer.Name] = VSR_CreateRadiusCircle(enemyChar, radius, color)
            end
        end
    else
        
        VSR_RemoveRadiusCircleByName(enemyPlayer.Name)
    end
end

function VSR_Update()
    if not VariantStealRadius.Enabled then return end
    
    
    for _, enemyPlayer in ipairs(Services.Players:GetPlayers()) do
        if enemyPlayer ~= Player then
            pcall(function()
                VSR_ProcessEnemy(enemyPlayer)
            end)
        end
    end
    
    
    for enemyName, circle in pairs(VariantStealRadius.RadiusCircles) do
        if not Services.Players:FindFirstChild(enemyName) then
            VSR_RemoveRadiusCircleByName(enemyName)
        end
    end
end

