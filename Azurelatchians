    ReflexTackle.LastPressTime = now return true
end

function ReflexTackle.ProcessTackle()
    if not ReflexTackle.Enabled or not CheckStyle("aiku") then return end
    local now = tick() local currentEnemies = {} local myTeam = GetPlayerTeam(Player.Name) if myTeam == "lobby" then return end
    local myCharacter = Player.Character if not myCharacter then return end
    local myHumanoid = myCharacter:FindFirstChildOfClass("Humanoid") if not myHumanoid or myHumanoid.Health <= 0 then return end

    for _, otherPlayer in ipairs(Services.Players:GetPlayers()) do
        if otherPlayer ~= Player then
            local otherTeam = GetPlayerTeam(otherPlayer.Name)
            if otherTeam ~= "lobby" and otherTeam ~= myTeam and HasBall(otherPlayer.Name) then
                local otherCharacter = Services.Workspace.characters:FindFirstChild(otherPlayer.Name)
                if otherCharacter then
                    local otherHumanoid = otherCharacter:FindFirstChildOfClass("Humanoid")
                    if otherHumanoid and otherHumanoid.Health > 0 and ReflexTackle.ShouldPressSkill(otherCharacter) then
                        currentEnemies[otherPlayer.Name] = true
                        
                        
                        if ReflexTackle.CheckNoQAnimation(otherCharacter) then
                            
                        elseif ReflexTackle.CheckImmediateAnimation(otherCharacter) then
                            ReflexTackle.PressSkill2()
                        else
                            if not ReflexTackle.PlayerStates[otherPlayer.Name] then
                                ReflexTackle.PlayerStates[otherPlayer.Name] = {
                                    state = "waiting", startTime = now, lastDribbleTime = 0, hasDribbled = false,
                                    isCurrentlyDribbling = false, dribbleEnded = false, dribbleEndTime = 0
                                }
                            end
                            local state = ReflexTackle.PlayerStates[otherPlayer.Name]
                            local isDribbling = ReflexTackle.CheckDribbleAnimation(otherCharacter)
                            if isDribbling and not state.isCurrentlyDribbling then
                                state.isCurrentlyDribbling = true state.hasDribbled = true state.lastDribbleTime = now state.state = "dribbling"
                            elseif not isDribbling and state.isCurrentlyDribbling then
                                state.isCurrentlyDribbling = false state.dribbleEnded = true state.dribbleEndTime = now
                            end
                            if state.hasDribbled and (now - state.lastDribbleTime) < 2.7 then state.state = "cooldown"
                            elseif state.hasDribbled and (now - state.lastDribbleTime) >= 2.7 then state.hasDribbled = false state.state = "waiting" end
                            if state.state == "dribbling" then
                                if state.dribbleEnded and (now - state.dribbleEndTime) >= 0.08 then
                                    if ReflexTackle.PressSkill2() then state.state = "cooldown" state.dribbleEnded = false end
                                end
                            elseif state.state == "cooldown" then ReflexTackle.PressSkill2()
                            elseif state.state == "waiting" then
                                if (now - state.startTime) >= 0.15 then
                                    if ReflexTackle.PressSkill2() then state.startTime = now end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    for playerName in pairs(ReflexTackle.PlayerStates) do if not currentEnemies[playerName] then ReflexTackle.PlayerStates[playerName] = nil end end
end

function ReflexTackle.Start()
    if ReflexTackle.Connection then ReflexTackle.Connection:Disconnect() end
    ReflexTackle.Enabled = true
    ReflexTackle.Connection = Services.RunService.Heartbeat:Connect(ReflexTackle.ProcessTackle)
