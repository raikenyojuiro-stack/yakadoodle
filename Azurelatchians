local FlowIndicator = {Enabled = false, TeamCheck = false, Connections = {}, Thread = nil, DrawingCache = {}}

function FlowIndicator.CreateIndicator(player, character)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    FlowIndicator.RemoveIndicator(player)
    local flowTag = Drawing.new("Text")
    flowTag.Text = "Flow: 0"
    flowTag.Size = 16
    flowTag.Center = true
    flowTag.Outline = true
    flowTag.Font = 0
    flowTag.Color = Color3.fromRGB(255, 0, 0)
    flowTag.Visible = false
    FlowIndicator.DrawingCache[player.UserId] = {flowTag = flowTag, character = character, player = player, flowValue = 0}
    FlowIndicator.StartFlowTracking(player, character)
end

function FlowIndicator.StartFlowTracking(player, character)
    task.spawn(function()
        for attempt = 1, 10 do
            if not FlowIndicator.Enabled then return end
            local charactersFolder = workspace:FindFirstChild("characters")
            local characterModel = charactersFolder and charactersFolder:FindFirstChild(player.Name)
            local stateFolder = characterModel and characterModel:FindFirstChild("state")
            local flowValue = stateFolder and stateFolder:FindFirstChild("flow")
            if flowValue then
                local connection = flowValue:GetPropertyChangedSignal("Value"):Connect(function()
                    local cache = FlowIndicator.DrawingCache[player.UserId]
                    if cache then cache.flowValue = flowValue.Value end
                end)
                table.insert(FlowIndicator.Connections, connection)
                local cache = FlowIndicator.DrawingCache[player.UserId]
                if cache then cache.flowValue = flowValue.Value end
                return
            end
            task.wait(0.5)
        end
    end)
end

function FlowIndicator.UpdateIndicator(player)
    local cache = FlowIndicator.DrawingCache[player.UserId]
    if not cache or not cache.character or not cache.character.Parent then FlowIndicator.RemoveIndicator(player) return end
    if FlowIndicator.TeamCheck and IsSameTeam(player) then cache.flowTag.Visible = false return end
    local character = cache.character
    local rootPart = character:FindFirstChild("HumanoidRootPart") if not rootPart then return end
    local camera = workspace.CurrentCamera
    local distance = (camera.CFrame.Position - rootPart.Position).Magnitude
    if distance > IndicatorsMaxDistance then cache.flowTag.Visible = false return end
    local flowPosition = rootPart.Position + Vector3.new(0, -3.0, 0)
    local flowVector, flowOnScreen = camera:WorldToViewportPoint(flowPosition)
    if flowOnScreen then
        cache.flowTag.Position = Vector2.new(flowVector.X, flowVector.Y)
        cache.flowTag.Visible = true
        local roundedValue = math.floor(cache.flowValue)
        cache.flowTag.Text = "Flow: " .. tostring(roundedValue)
        if cache.flowValue >= 100 then cache.flowTag.Color = Color3.fromRGB(0, 255, 0)
        elseif cache.flowValue >= 70 then cache.flowTag.Color = Color3.fromRGB(255, 200, 0)
        else cache.flowTag.Color = Color3.fromRGB(255, 0, 0) end
    else
        cache.flowTag.Visible = false
    end
end

function FlowIndicator.RemoveIndicator(player)
    local cache = FlowIndicator.DrawingCache[player.UserId]
    if cache then
        if cache.flowTag then cache.flowTag.Visible = false cache.flowTag:Remove() end
        FlowIndicator.DrawingCache[player.UserId] = nil
    end
end

function FlowIndicator.SetupPlayerTracking(player)
    FlowIndicator.RemoveIndicator(player)
    
    task.spawn(function()
        for attempt = 1, 10 do
            if not FlowIndicator.Enabled then return end
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                FlowIndicator.CreateIndicator(player, player.Character)
                break
            end
            task.wait(0.5)
        end
    end)
    local charAddedConn = player.CharacterAdded:Connect(function(character)
        task.spawn(function()
            for attempt = 1, 10 do
                if not FlowIndicator.Enabled then return end
                if character and character:FindFirstChild("HumanoidRootPart") then
                    FlowIndicator.CreateIndicator(player, character)
