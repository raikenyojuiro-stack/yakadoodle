function KTH_IsPlayingTargetAnimation()
    local char = Player.Character if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid") if not humanoid then return false end
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(KiyoraTrapHelper.ANIMATION_ID) then return true end
    end
    return false
end

function KTH_CanActivateMagnet(ball)
    if not ball then return false end
    local char = Player.Character if not char then return false end
    if char:FindFirstChild("Ball") then return false end
    if ball.Position.Y < KiyoraTrapHelper.MIN_BALL_HEIGHT then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return false end
    local distance = (hrp.Position - ball.Position).Magnitude
    return distance <= KiyoraTrapHelper.MagnetRadius
end

function KTH_SmoothMagnetToBall()
    local ball = KTH_GetBall()
    if not ball or not KTH_CanActivateMagnet(ball) then return false end
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local targetPosition = ball.Position + Vector3.new(0, KiyoraTrapHelper.VERTICAL_OFFSET, 0)
    local currentPosition = hrp.Position
    local distance = (currentPosition - targetPosition).Magnitude
    if distance < 2 then return true end
    local newPosition = currentPosition:Lerp(targetPosition, KiyoraTrapHelper.MagnetSpeed)
    local playerHeight = currentPosition.Y
    if playerHeight > 10 then newPosition = Vector3.new(newPosition.X, playerHeight, newPosition.Z) end
    hrp.CFrame = CFrame.new(newPosition)
    return true
end

function KiyoraTrapHelper.StartMagnet()
    if KiyoraTrapHelper.IsActive then return end
    KiyoraTrapHelper.StartTime = tick()
    KiyoraTrapHelper.IsActive = true
    local char = Player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then KiyoraTrapHelper.LastPosition = hrp.Position end
    end
    KiyoraTrapHelper.Connection = Services.RunService.Heartbeat:Connect(function()
        if not KiyoraTrapHelper.IsActive or not KTH_IsPlayingTargetAnimation() then
            KiyoraTrapHelper.StopMagnet()
            return
        end
        local timeSinceStart = tick() - KiyoraTrapHelper.StartTime
        if timeSinceStart < KiyoraTrapHelper.ACTIVATION_DELAY then return end
        if timeSinceStart > KiyoraTrapHelper.MAGNET_DURATION then
            KiyoraTrapHelper.StopMagnet()
            return
        end
        KTH_SmoothMagnetToBall()
        local char = Player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then KiyoraTrapHelper.LastPosition = hrp.Position end
        end
    end)
    task.delay(KiyoraTrapHelper.MAGNET_DURATION + 0.1, function() KiyoraTrapHelper.StopMagnet() end)
end

function KiyoraTrapHelper.StopMagnet()
    if KiyoraTrapHelper.IsActive then
        KiyoraTrapHelper.IsActive = false
        if KiyoraTrapHelper.Connection then KiyoraTrapHelper.Connection:Disconnect() KiyoraTrapHelper.Connection = nil end
    end
end

function KiyoraTrapHelper.SetupAnimationMonitor()
    local char = Player.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then
        char.ChildAdded:Connect(function(child)
            if child:IsA("Humanoid") then task.wait(0.5) KiyoraTrapHelper.SetupAnimationMonitor() end
        end)
        return
    end
    KiyoraTrapHelper.AnimationConnection = humanoid.AnimationPlayed:Connect(function(animationTrack)
        if not KiyoraTrapHelper.Enabled then return end
        if animationTrack.Animation then
            local animId = tostring(animationTrack.Animation.AnimationId)
            if animId:find(KiyoraTrapHelper.ANIMATION_ID) then
                task.delay(KiyoraTrapHelper.ACTIVATION_DELAY, function()
                    if KTH_IsPlayingTargetAnimation() then
                        local ball = KTH_GetBall()
                        if KTH_CanActivateMagnet(ball) then KiyoraTrapHelper.StartMagnet() end
                    end
                end)
            end
        end
    end)
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(KiyoraTrapHelper.ANIMATION_ID) then
            task.delay(0.3, function()
