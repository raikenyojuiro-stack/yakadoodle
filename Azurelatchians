function LineUpCreator.IsNearExistingLineup(position, styleName, team)
    if not position or not styleName or not team then return true end
    
    local tolerance = 5
    
    local cfg = AutoLineUps.StylesConfig[styleName]
    if cfg and cfg.points[team] then
        for _, point in ipairs(cfg.points[team]) do
            local dist = (position - point.targetPosition).Magnitude
            if dist < tolerance then return true end
        end
    end
    
    local flowStyleName = styleName .. "_flow"
    local flowCfg = AutoLineUps.StylesConfig[flowStyleName]
    if flowCfg and flowCfg.points[team] then
        for _, point in ipairs(flowCfg.points[team]) do
            local dist = (position - point.targetPosition).Magnitude
            if dist < tolerance then return true end
        end
    end
    
    return false
end

