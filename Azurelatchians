function EasySkill3Sae.ResetStates()
    EasySkill3Sae.HasReached100 = false
    EasySkill3Sae.WasAbove100 = false
    EasySkill3Sae.LastFlowValue = 0
    EasySkill3Sae.CanUseSkill = false
    EasySkill3Sae.AnimationPlayedInCycle = false
end

function ES3_Heartbeat()
    if not EasySkill3Sae.Enabled then return end
    local flowObj = ES3_FindFlow()
    if not flowObj then EasySkill3Sae.ResetStates() return end
    local value = flowObj.Value
    if value >= 100 then
        EasySkill3Sae.HasReached100 = true
        EasySkill3Sae.WasAbove100 = true
        EasySkill3Sae.CanUseSkill = false
        EasySkill3Sae.AnimationPlayedInCycle = false
    elseif value < 100 and EasySkill3Sae.WasAbove100 then
        EasySkill3Sae.HasReached100 = true
        EasySkill3Sae.CanUseSkill = true
    else
        EasySkill3Sae.HasReached100 = false
        EasySkill3Sae.CanUseSkill = false
    end
    if value <= 0 then EasySkill3Sae.WasAbove100 = false EasySkill3Sae.HasReached100 = false end
    EasySkill3Sae.LastFlowValue = value
    if ES3_IsAnimationPlaying("83477287588669") then EasySkill3Sae.AnimationPlayedInCycle = true end
end

function EasySkill3Sae.ExecuteSkill3Variant()
    if EasySkill3Sae.IsExecuting then return false end
    if not EasySkill3Sae.Enabled or not ES3_IsSae() or not HasBall() then return false end
    local flowObj = ES3_FindFlow() if not flowObj then return false end
    local flow = flowObj.Value
    
    local shouldActivate = EasySkill3Sae.HasReached100 and flow < 100 and EasySkill3Sae.CanUseSkill
    local byteNet = ES3_FindByte() if not byteNet then return false end
    if shouldActivate and not IsSkillOnCooldown("skill3") then
        EasySkill3Sae.IsExecuting = true
        EasySkill3Sae.PlayAnim("76587445975710")
        task.wait(0.1)
        pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"kick", 24, false, vector.create(0,1,0)}}) end)
        pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"skill3"}}) end)
        SafeNotify("<font color='#A6BAFF'>[ Easy Skill3 Sae ]</font> Executed!", 1)
        
        EasySkill3Sae.AnimationPlayedInCycle = true
        EasySkill3Sae.IsExecuting = false
        return true
    end
    return false
end

function EasySkill3Sae.Start()
    EasySkill3Sae.Enabled = true
    EasySkill3Sae.ResetStates()
    EasySkill3Sae.Connections.flow = Services.RunService.Heartbeat:Connect(ES3_Heartbeat)
    EasySkill3Sae.Connections.key = Services.UIS.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode == EasySkill3Sae.CurrentKey then EasySkill3Sae.ExecuteSkill3Variant() end
    end)
    EasySkill3Sae.Connections.character = Player.CharacterAdded:Connect(function() task.wait(1) EasySkill3Sae.ResetStates() end)
    SafeNotify("<font color='#A6BAFF'>[ Easy Skill3 Sae ]</font> Activated!", 2)
end

function EasySkill3Sae.Stop()
    EasySkill3Sae.Enabled = false
    EasySkill3Sae.StopAnim()
    EasySkill3Sae.ResetStates()
    for _, c in pairs(EasySkill3Sae.Connections) do if c then c:Disconnect() end end
    EasySkill3Sae.Connections = {}
    SafeNotify("<font color='#A6BAFF'>[ Easy Skill3 Sae ]</font> Deactivated!", 2)
end


