function BallMetavision.GetPartFromPool()
    local part
    if #BallMetavision.PartPool > 0 then 
        part = table.remove(BallMetavision.PartPool)
    else 
        part = Instance.new("Part") 
        part.Anchored = true 
        part.CanCollide = false 
        part.CastShadow = false 
        part.Material = Enum.Material.Neon
        part.TopSurface = Enum.SurfaceType.Smooth
        part.BottomSurface = Enum.SurfaceType.Smooth
    end
    part.Parent = workspace
    return part
end
function BallMetavision.ReturnPartToPool(part)
    if part then
        part.Transparency = 1
        part.Parent = nil
        table.insert(BallMetavision.PartPool, part)
    end
end
function BallMetavision.ClearAllIndicators()
    
    for _, part in ipairs(BallMetavision.BlueArcParts) do 
        if part and part.Parent then 
            BallMetavision.ReturnPartToPool(part) 
        end 
    end
    for _, part in ipairs(BallMetavision.GrayArcParts) do 
        if part and part.Parent then 
            BallMetavision.ReturnPartToPool(part) 
        end 
    end
    BallMetavision.BlueArcParts = {}
    BallMetavision.GrayArcParts = {}
    BallMetavision.PositionHistory = {}
    BallMetavision.VelocityHistory = {}
    BallMetavision.LastBallPosition = nil
    BallMetavision.SmoothedVelocity = Vector3.new(0, 0, 0)
end
BallMetavision.DRAG_FACTOR = 0.9737
BallMetavision.BOUNCE_RESTITUTION = 0.82
BallMetavision.GROUND_LEVEL = 1.5
function BallMetavision.CalculateTrajectory(startPosition, velocity, gravity, time)
    
    local steps = math.max(1, math.floor(time * 60)) 
    local dt = time / steps
    
    local pos = startPosition
    local vel = velocity
    
    for i = 1, steps do
        
        vel = Vector3.new(
            vel.X * BallMetavision.DRAG_FACTOR,
            vel.Y - gravity * dt,
            vel.Z * BallMetavision.DRAG_FACTOR
        )
        
        
        pos = pos + vel * dt
    end
    
    return pos
end
function BallMetavision.UpdateBlueArc()
    local neededParts = math.max(#BallMetavision.PositionHistory - 1, 0)
    
    
    for i = #BallMetavision.BlueArcParts, neededParts + 1, -1 do 
        BallMetavision.ReturnPartToPool(BallMetavision.BlueArcParts[i])
        BallMetavision.BlueArcParts[i] = nil
    end
    
    
    for i = 1, neededParts do
        local part = BallMetavision.BlueArcParts[i]
        if not part or not part.Parent then 
            part = BallMetavision.GetPartFromPool() 
            part.Parent = BallMetavision.BlueArcContainer
            BallMetavision.BlueArcParts[i] = part
        end
        
        local startPoint = BallMetavision.PositionHistory[i]
        local endPoint = BallMetavision.PositionHistory[i + 1]
        local distance = (endPoint - startPoint).Magnitude
        
        if distance > 0.01 then
            part.Size = Vector3.new(BallMetavision.BLUE_ARC_WIDTH, BallMetavision.BLUE_ARC_WIDTH, distance)
            part.CFrame = CFrame.new(startPoint, endPoint) * CFrame.new(0, 0, -distance / 2)
            part.Color = BallMetavision.BLUE_ARC_COLOR
            part.Transparency = BallMetavision.ArcsVisible and BallMetavision.ARC_TRANSPARENCY or 1
        else 
            part.Transparency = 1 
        end
    end
end
function BallMetavision.UpdateGrayArc(startPosition, velocity)
    local gravity = workspace.Gravity
    
    
    local currentPos = startPosition
    local currentVel = velocity
    local dt = BallMetavision.PREDICTION_TIME / BallMetavision.PREDICTION_STEPS

    
    for i = #BallMetavision.GrayArcParts, BallMetavision.PREDICTION_STEPS + 1, -1 do 
        BallMetavision.ReturnPartToPool(BallMetavision.GrayArcParts[i])
        BallMetavision.GrayArcParts[i] = nil
    end

    for i = 1, BallMetavision.PREDICTION_STEPS do
        local part = BallMetavision.GrayArcParts[i]
        if not part or not part.Parent then 
            part = BallMetavision.GetPartFromPool() 
            part.Parent = BallMetavision.GrayArcContainer
            BallMetavision.GrayArcParts[i] = part
        end

        local prevPosition = currentPos

        
        currentVel = Vector3.new(
            currentVel.X * BallMetavision.DRAG_FACTOR,
            currentVel.Y - gravity * dt,
            currentVel.Z * BallMetavision.DRAG_FACTOR
        )

        
        currentPos = currentPos + currentVel * dt

        
        if currentPos.Y <= BallMetavision.GROUND_LEVEL then
            currentPos = Vector3.new(currentPos.X, BallMetavision.GROUND_LEVEL, currentPos.Z)
            
            currentVel = Vector3.new(currentVel.X * 0.85, 0, currentVel.Z * 0.85)
        end

        local distance = (currentPos - prevPosition).Magnitude
        if distance > 0.05 then
            part.Size = Vector3.new(BallMetavision.GRAY_ARC_WIDTH, BallMetavision.GRAY_ARC_WIDTH, distance)
            part.CFrame = CFrame.new(prevPosition, currentPos) * CFrame.new(0, 0, -distance / 2)
            part.Color = BallMetavision.GRAY_ARC_COLOR
            part.Transparency = BallMetavision.ArcsVisible and BallMetavision.ARC_TRANSPARENCY or 1
        else
            part.Transparency = 1
        end
    end
end
function BallMetavision.CheckSaeMode()
    local playerGui = Player:FindFirstChild("PlayerGui") if not playerGui then return "LOGIC" end
    local hotbar = playerGui:FindFirstChild("Hotbar") if not hotbar then return "LOGIC" end
    local magicHealth = hotbar:FindFirstChild("MagicHealth") if not magicHealth then return "LOGIC" end
    local saeText = magicHealth:FindFirstChild("saeText")
    if not saeText or not saeText:IsA("TextLabel") then return "LOGIC" end
    return saeText.Text
end
function BallMetavision.GetIsagiFlow()
    local character = workspace.characters and workspace.characters:FindFirstChild(Player.Name)
    if not character then return 0 end
    local state = character:FindFirstChild("state") if not state then return 0 end
    local flow = state:FindFirstChild("flow")
    if not flow or not flow:IsA("NumberValue") then return 0 end
    return flow.Value
end
function BallMetavision.CheckStyleConditions()
    local style = Player:GetAttribute("style")
    local isIsagiStyle = style == "isagi"
    local isSaeStyle = style == "sae"
    local currentArcsVisible = true
    
    if isIsagiStyle then
        local currentFlow = BallMetavision.GetIsagiFlow()
        if BallMetavision.LastIsagiFlow >= 100 and currentFlow < BallMetavision.LastIsagiFlow then 
            BallMetavision.IsagiFlowFalling = true 
        end
        if currentFlow <= 0 then 
            BallMetavision.IsagiFlowFalling = false 
        end
        currentArcsVisible = not BallMetavision.IsagiFlowFalling
        BallMetavision.LastIsagiFlow = currentFlow
    end
    
    if isSaeStyle then
        local currentSaeMode = BallMetavision.CheckSaeMode()
        if currentSaeMode ~= BallMetavision.LastSaeMode then 
            BallMetavision.LastSaeMode = currentSaeMode 
        end
        currentArcsVisible = currentArcsVisible and (currentSaeMode == "LOGIC")
    end
    
    if not isIsagiStyle and not isSaeStyle then 
        currentArcsVisible = true 
    end
    
    if currentArcsVisible ~= BallMetavision.ArcsVisible then
        BallMetavision.ArcsVisible = currentArcsVisible
        BallMetavision.UpdateArcsTransparency()
    end
end

function BallMetavision.SetupStyleConnections()
    
    if BallMetavision.StyleCheckConnection then 
        BallMetavision.StyleCheckConnection:Disconnect() 
    end
    if BallMetavision.FlowConnection then 
        BallMetavision.FlowConnection:Disconnect() 
    end
    if BallMetavision.SaeConnection then 
        BallMetavision.SaeConnection:Disconnect() 
    end
    
    
    BallMetavision.StyleCheckConnection = Player:GetAttributeChangedSignal("style"):Connect(function()
        BallMetavision.CheckStyleConditions()
    end)
    
    
    task.spawn(function()
        local character = workspace.characters and workspace.characters:FindFirstChild(Player.Name)
        if character then
            local state = character:FindFirstChild("state")
            if state then
                local flow = state:FindFirstChild("flow")
                if flow then
                    BallMetavision.FlowConnection = flow:GetPropertyChangedSignal("Value"):Connect(function()
                        if Player:GetAttribute("style") == "isagi" then
                            BallMetavision.CheckStyleConditions()
                        end
                    end)
                end
            end
        end
    end)
    
    
    BallMetavision.CheckStyleConditions()
end
function BallMetavision.UpdateArcsTransparency()
    
    local transparency = BallMetavision.ArcsVisible and BallMetavision.ARC_TRANSPARENCY or 1
    
    for _, part in ipairs(BallMetavision.BlueArcParts) do 
        if part and part.Parent then 
            part.Transparency = transparency 
        end 
    end
    
    for _, part in ipairs(BallMetavision.GrayArcParts) do 
        if part and part.Parent then 
            part.Transparency = transparency 
        end 
    end
end
function BallMetavision.FindBall()
    if not BallMetavision.BallInstance or not BallMetavision.BallInstance.Parent then
        local foundBall = workspace:FindFirstChild("Ball") or (workspace.Terrain and workspace.Terrain:FindFirstChild("Ball"))
        if foundBall and foundBall:IsA("BasePart") then BallMetavision.BallInstance = foundBall BallMetavision.ClearAllIndicators()
        else BallMetavision.ClearAllIndicators() return false end
    end
    return true
end
function BallMetavision.UpdatePositionHistory()
    local currentPosition = BallMetavision.BallInstance.Position
    local lastPos = BallMetavision.PositionHistory[#BallMetavision.PositionHistory]
    
    if not lastPos then
        
        BallMetavision.PositionHistory = {currentPosition}
        BallMetavision.UpdateBlueArc()
        return
    end
    
    local currentMagnitude = (currentPosition - lastPos).Magnitude
    
    if currentMagnitude > BallMetavision.MIN_MOVEMENT_THRESHOLD then
        table.insert(BallMetavision.PositionHistory, currentPosition)
        
        if #BallMetavision.PositionHistory > BallMetavision.MAX_HISTORY_POINTS then
            table.remove(BallMetavision.PositionHistory, 1)
        end
        
        BallMetavision.UpdateBlueArc()
    end
end
function BallMetavision.UpdateVelocityPrediction()
    local currentTime = tick()
    local currentPosition = BallMetavision.BallInstance.Position
    
    if BallMetavision.LastBallPosition then
        local timeDelta = currentTime - (BallMetavision.LastUpdateTime or currentTime)
        
        if timeDelta > 0 and timeDelta < 0.1 then 
            local newVelocity = (currentPosition - BallMetavision.LastBallPosition) / timeDelta
            
            
            table.insert(BallMetavision.VelocityHistory, newVelocity)
            if #BallMetavision.VelocityHistory > BallMetavision.VELOCITY_HISTORY_SIZE then
                table.remove(BallMetavision.VelocityHistory, 1)
            end
            
            
            if #BallMetavision.VelocityHistory >= 5 then
                local avgVelocity = Vector3.new(0, 0, 0)
                local totalWeight = 0
                local historySize = #BallMetavision.VelocityHistory
                
                for i, vel in ipairs(BallMetavision.VelocityHistory) do
                    local weight = i / historySize 
                    avgVelocity = avgVelocity + vel * weight
                    totalWeight = totalWeight + weight
                end
                
                avgVelocity = avgVelocity / totalWeight
                
                
                BallMetavision.SmoothedVelocity = BallMetavision.SmoothedVelocity:Lerp(avgVelocity, BallMetavision.SMOOTHING_FACTOR)
            else
                
                BallMetavision.SmoothedVelocity = BallMetavision.SmoothedVelocity:Lerp(newVelocity, BallMetavision.SMOOTHING_FACTOR * 0.5)
            end
            
            BallMetavision.UpdateGrayArc(currentPosition, BallMetavision.SmoothedVelocity)
        end
    end
    
    BallMetavision.LastBallPosition = currentPosition
    BallMetavision.LastUpdateTime = currentTime
end
function BallMetavision.OnStepped()
    
    BallMetavision.FrameSkipCounter = BallMetavision.FrameSkipCounter + 1
    if BallMetavision.FrameSkipCounter < BallMetavision.FrameSkipInterval then
        return
    end
    BallMetavision.FrameSkipCounter = 0
    
    
    if not BallMetavision.ArcsVisible then 
        return 
    end
    
    
    if not BallMetavision.FindBall() then 
        return 
    end
    
    
    BallMetavision.UpdatePositionHistory()
    BallMetavision.UpdateVelocityPrediction()
end
function BallMetavision.Start()
    if BallMetavision.Connection then 
        BallMetavision.Connection:Disconnect() 
    end
    
    BallMetavision.BlueArcContainer = Instance.new("Folder") 
    BallMetavision.BlueArcContainer.Name = "BlueTrajectoryArc" 
    BallMetavision.BlueArcContainer.Parent = workspace
    
    BallMetavision.GrayArcContainer = Instance.new("Folder") 
    BallMetavision.GrayArcContainer.Name = "GrayPredictionArc" 
    BallMetavision.GrayArcContainer.Parent = workspace
    
    
    BallMetavision.SetupStyleConnections()
    
    
    BallMetavision.Connection = Services.RunService.Heartbeat:Connect(BallMetavision.OnStepped)
    BallMetavision.Enabled = true
    BallMetavision.FrameSkipCounter = 0
    
    SafeNotify("<font color='#A6BAFF'>[ Ball Metavision ]</font> Activated!", 2)
end
function BallMetavision.Stop()
    BallMetavision.Enabled = false
    
    
    if BallMetavision.Connection then 
        BallMetavision.Connection:Disconnect() 
        BallMetavision.Connection = nil 
    end
    if BallMetavision.StyleCheckConnection then 
        BallMetavision.StyleCheckConnection:Disconnect() 
        BallMetavision.StyleCheckConnection = nil 
    end
    if BallMetavision.FlowConnection then 
        BallMetavision.FlowConnection:Disconnect() 
        BallMetavision.FlowConnection = nil 
    end
    if BallMetavision.SaeConnection then 
        BallMetavision.SaeConnection:Disconnect() 
        BallMetavision.SaeConnection = nil 
    end
    
    BallMetavision.ClearAllIndicators()
    
    
    if BallMetavision.BlueArcContainer then
        for _, part in ipairs(BallMetavision.BlueArcContainer:GetChildren()) do 
            if part then 
                part:Destroy() 
            end 
        end
        BallMetavision.BlueArcContainer:Destroy() 
        BallMetavision.BlueArcContainer = nil
    end
    
    if BallMetavision.GrayArcContainer then
        for _, part in ipairs(BallMetavision.GrayArcContainer:GetChildren()) do 
            if part then 
                part:Destroy() 
            end 
        end
        BallMetavision.GrayArcContainer:Destroy() 
        BallMetavision.GrayArcContainer = nil
    end
    
    
    for _, part in ipairs(BallMetavision.PartPool) do 
        if part then 
            part:Destroy() 
        end 
    end
    BallMetavision.PartPool = {}
    
    
    BallMetavision.BlueArcParts = {}
    BallMetavision.GrayArcParts = {}
    
    SafeNotify("<font color='#A6BAFF'>[ Ball Metavision ]</font> Deactivated!", 2)
end


PlayerAimBeam = {
    Enabled = false, Connection = nil, Beam = nil, LastUpdate = 0, UpdateInterval = 0.05,
    CachedBallOwner = nil, CachedCharacter = nil, LastHeadPosition = Vector3.new(),
    LastLookDirection = Vector3.new(0, 0, -1), BeamConnections = {}, PlayerConnections = {},
    LocalPlayerRole = nil, RoleCheckAttempts = 0, MaxRoleCheckAttempts = 30
}

function PlayerAimBeam.GetLocalPlayerRole()
    local character = workspace.characters:FindFirstChild(Player.Name)
    if not character then return nil end
    local state = character:FindFirstChild("state") if not state then return nil end
    local roleValue = state:FindFirstChild("role")
    if roleValue and roleValue:IsA("StringValue") then return roleValue.Value end
    return nil
end
function PlayerAimBeam.CheckAndWaitForRole()
    PlayerAimBeam.LocalPlayerRole = PlayerAimBeam.GetLocalPlayerRole()
    if not PlayerAimBeam.LocalPlayerRole then
        PlayerAimBeam.RoleCheckAttempts = PlayerAimBeam.RoleCheckAttempts + 1
        if PlayerAimBeam.RoleCheckAttempts <= PlayerAimBeam.MaxRoleCheckAttempts then return false else return true end
    end
    return true
end
function PlayerAimBeam.FindBallAndOwner()
    if not PlayerAimBeam.CheckAndWaitForRole() then return nil, nil end
    if PlayerAimBeam.CachedBallOwner and PlayerAimBeam.CachedCharacter and PlayerAimBeam.CachedCharacter.Parent and PlayerAimBeam.CachedCharacter:FindFirstChild("Ball") then
        return PlayerAimBeam.CachedBallOwner, PlayerAimBeam.CachedCharacter
    end
    for _, player in ipairs(Services.Players:GetPlayers()) do
        if player ~= Player and player.Character and player.Character.Parent then
            local ball = player.Character:FindFirstChild("Ball")
            if ball then PlayerAimBeam.CachedBallOwner = player PlayerAimBeam.CachedCharacter = player.Character return player, player.Character end
        end
    end
    PlayerAimBeam.CachedBallOwner = nil
    PlayerAimBeam.CachedCharacter = nil
    return nil, nil
end
function PlayerAimBeam.GetHorizontalLookDirection(character)
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart then
        local lookVector = humanoidRootPart.CFrame.LookVector
        return Vector3.new(lookVector.X, 0, lookVector.Z).Unit
    end
    return Vector3.new(0, 0, -1)
end
function PlayerAimBeam.UpdateBeam()
    if not PlayerAimBeam.CheckAndWaitForRole() then PlayerAimBeam.Beam.Position = Vector3.new(0, -1000, 0) return end
    local ballOwner, character = PlayerAimBeam.FindBallAndOwner()
    if ballOwner and character and character:FindFirstChild("Humanoid") then
        local head = character:FindFirstChild("Head") if not head then return end
        local lookDirection = PlayerAimBeam.GetHorizontalLookDirection(character)
        PlayerAimBeam.LastLookDirection = lookDirection
        PlayerAimBeam.LastHeadPosition = head.Position
        local endPos = head.Position + lookDirection * 50
        PlayerAimBeam.Beam.Position = (head.Position + endPos) / 2
        PlayerAimBeam.Beam.Size = Vector3.new(0.2, 0.2, (head.Position - endPos).Magnitude)
        PlayerAimBeam.Beam.CFrame = CFrame.new(PlayerAimBeam.Beam.Position, endPos)
    else PlayerAimBeam.Beam.Position = Vector3.new(0, -1000, 0) end
end
function PlayerAimBeam.TrackRoleChanges()
    local character = workspace.characters:FindFirstChild(Player.Name) if not character then return end
    local state = character:FindFirstChild("state") if not state then return end
    local roleValue = state:FindFirstChild("role")
    if roleValue and roleValue:IsA("StringValue") then
        local roleChangedConnection = roleValue.Changed:Connect(function(newValue) PlayerAimBeam.LocalPlayerRole = newValue PlayerAimBeam.RoleCheckAttempts = 0 end)
        table.insert(PlayerAimBeam.BeamConnections, roleChangedConnection)
    end
end
function PlayerAimBeam.TrackCharacterChanges()
    local characterAddedConnection = Player.CharacterAdded:Connect(function(character)
        task.wait(1)
        PlayerAimBeam.RoleCheckAttempts = 0
        PlayerAimBeam.LocalPlayerRole = nil
        PlayerAimBeam.TrackRoleChanges()
    end)
    table.insert(PlayerAimBeam.BeamConnections, characterAddedConnection)
    if Player.Character then PlayerAimBeam.TrackRoleChanges() end
end
function PlayerAimBeam.SetupPlayerTracking(player)
    if player == Player then return end
    local charAddedConn = player.CharacterAdded:Connect(function(character)
        PlayerAimBeam.CachedBallOwner = nil
        PlayerAimBeam.CachedCharacter = nil
    end)
    table.insert(PlayerAimBeam.BeamConnections, charAddedConn)
    if player.Character then
        local childAddedConn = player.Character.ChildAdded:Connect(function(child)
            if child.Name == "Ball" then PlayerAimBeam.CachedBallOwner = player PlayerAimBeam.CachedCharacter = player.Character end
        end)
        local childRemovedConn = player.Character.ChildRemoved:Connect(function(child)
            if child.Name == "Ball" then PlayerAimBeam.CachedBallOwner = nil PlayerAimBeam.CachedCharacter = nil end
        end)
        table.insert(PlayerAimBeam.BeamConnections, childAddedConn)
        table.insert(PlayerAimBeam.BeamConnections, childRemovedConn)
    end
end
function PlayerAimBeam.InitializePlayerTracking()
    for _, player in ipairs(Services.Players:GetPlayers()) do PlayerAimBeam.SetupPlayerTracking(player) end
    local playerAddedConnection = Services.Players.PlayerAdded:Connect(PlayerAimBeam.SetupPlayerTracking)
    table.insert(PlayerAimBeam.BeamConnections, playerAddedConnection)
end
function PlayerAimBeam.OnHeartbeat()
    local currentTime = tick()
    if currentTime - PlayerAimBeam.LastUpdate >= PlayerAimBeam.UpdateInterval then
        PlayerAimBeam.LastUpdate = currentTime
        PlayerAimBeam.UpdateBeam()
    else
        if PlayerAimBeam.CheckAndWaitForRole() then
            local ballOwner, character = PlayerAimBeam.FindBallAndOwner()
            if ballOwner and character and character:FindFirstChild("Humanoid") then
                local head = character:FindFirstChild("Head")
                if head then PlayerAimBeam.Beam.Position = PlayerAimBeam.Beam.Position:Lerp((head.Position + (head.Position + PlayerAimBeam.LastLookDirection * 50)) / 2, 0.3) end
            end
        else PlayerAimBeam.Beam.Position = Vector3.new(0, -1000, 0) end
    end
end
function PlayerAimBeam.CleanupOrphanedBeams()
    
    pcall(function()
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Part") and obj.Material == Enum.Material.Neon and obj.Color == Color3.fromRGB(128, 128, 128) and obj.Transparency == 0.7 then
                if obj ~= PlayerAimBeam.Beam then obj:Destroy() end
            end
        end
        if workspace.Terrain then
            for _, obj in ipairs(workspace.Terrain:GetChildren()) do
                if obj:IsA("Part") and obj.Material == Enum.Material.Neon and obj.Color == Color3.fromRGB(128, 128, 128) then
                    if obj ~= PlayerAimBeam.Beam then obj:Destroy() end
                end
            end
        end
    end)
end
function PlayerAimBeam.Start()
    if PlayerAimBeam.Connection then PlayerAimBeam.Connection:Disconnect() end
    
    if PlayerAimBeam.Beam then
        pcall(function() PlayerAimBeam.Beam:Destroy() end)
        PlayerAimBeam.Beam = nil
    end
    
    PlayerAimBeam.CleanupOrphanedBeams()
    PlayerAimBeam.Beam = Instance.new("Part")
    PlayerAimBeam.Beam.Name = "PlayerAimBeamPart"
    PlayerAimBeam.Beam.Material = Enum.Material.Neon
    PlayerAimBeam.Beam.Color = Color3.fromRGB(128, 128, 128)
    PlayerAimBeam.Beam.Transparency = 0.7
    PlayerAimBeam.Beam.Anchored = true
    PlayerAimBeam.Beam.CanCollide = false
    PlayerAimBeam.Beam.Size = Vector3.new(0.2, 0.2, 100)
    PlayerAimBeam.Beam.Parent = workspace.Terrain
    PlayerAimBeam.Beam.Position = Vector3.new(0, -1000, 0)
    PlayerAimBeam.TrackCharacterChanges()
    PlayerAimBeam.InitializePlayerTracking()
    PlayerAimBeam.LastCleanup = tick()
    PlayerAimBeam.Connection = Services.RunService.Heartbeat:Connect(function()
        PlayerAimBeam.OnHeartbeat()
        
        if tick() - (PlayerAimBeam.LastCleanup or 0) > 5 then
            PlayerAimBeam.LastCleanup = tick()
            PlayerAimBeam.CleanupOrphanedBeams()
        end
    end)
    PlayerAimBeam.Enabled = true
    SafeNotify("<font color='#A6BAFF'>[ Player Aim Beam ]</font> Activated!", 2)
end
function PlayerAimBeam.Stop()
    PlayerAimBeam.Enabled = false
    if PlayerAimBeam.Connection then PlayerAimBeam.Connection:Disconnect() PlayerAimBeam.Connection = nil end
    for _, connection in ipairs(PlayerAimBeam.BeamConnections) do pcall(function() connection:Disconnect() end) end
    PlayerAimBeam.BeamConnections = {}
    for _, connection in ipairs(PlayerAimBeam.PlayerConnections) do pcall(function() connection:Disconnect() end) end
    PlayerAimBeam.PlayerConnections = {}
    
    if PlayerAimBeam.Beam then
        pcall(function() PlayerAimBeam.Beam:Destroy() end)
        PlayerAimBeam.Beam = nil
    end
    
    pcall(function()
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Part") and obj.Material == Enum.Material.Neon and obj.Color == Color3.fromRGB(128, 128, 128) then
                obj:Destroy()
            end
        end
        if workspace.Terrain then
            for _, obj in ipairs(workspace.Terrain:GetChildren()) do
                if obj:IsA("Part") and obj.Material == Enum.Material.Neon and obj.Color == Color3.fromRGB(128, 128, 128) then
                    obj:Destroy()
                end
            end
        end
    end)
    PlayerAimBeam.CachedBallOwner = nil
    PlayerAimBeam.CachedCharacter = nil
    PlayerAimBeam.LocalPlayerRole = nil
    PlayerAimBeam.RoleCheckAttempts = 0
    SafeNotify("<font color='#A6BAFF'>[ Player Aim Beam ]</font> Deactivated!", 2)
end


local function GetPlayerTeam(player)
    local charactersFolder = workspace:FindFirstChild("characters")
    if not charactersFolder then return nil end
    local characterModel = charactersFolder:FindFirstChild(player.Name)
    if not characterModel then return nil end
    local stateFolder = characterModel:FindFirstChild("state")
    if not stateFolder then return nil end
    local teamValue = stateFolder:FindFirstChild("team")
    return teamValue and teamValue.Value or nil
end

local function IsSameTeam(player)
    local localTeam = GetPlayerTeam(Player)
    local otherTeam = GetPlayerTeam(player)
    if localTeam == nil or otherTeam == nil then return false end
    return localTeam == otherTeam
end


