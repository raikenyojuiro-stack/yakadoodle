function BN_ReadPacketIDs()
    pcall(function()
        local bytenetStorage = Services.ReplicatedStorage:FindFirstChild("BytenetStorage")
        if not bytenetStorage then return end
        local networking = bytenetStorage:FindFirstChild("Networking")
        if not networking or not networking:IsA("StringValue") then return end
        
        local jsonStr = networking.Value
        if not jsonStr or jsonStr == "" then return end
        
        local data = game:GetService("HttpService"):JSONDecode(jsonStr)
        if not data or not data.packets then return end
        
        
        if data.packets["bytenet_use"] then
            ByteNetPackets.use = data.packets["bytenet_use"]
        end
        if data.packets["bytenet_findBall"] then
            ByteNetPackets.findBall = data.packets["bytenet_findBall"]
        end
        if data.packets["bytenet_selectRole"] then
            ByteNetPackets.selectRole = data.packets["bytenet_selectRole"]
        end
        
        warn("[ByteNet] Packet IDs loaded: use=" .. ByteNetPackets.use .. ", findBall=" .. ByteNetPackets.findBall .. ", selectRole=" .. ByteNetPackets.selectRole)
    end)
end


function BN_UseBuffer()
    return buffer.fromstring(string.char(ByteNetPackets.use) .. "\001")
end

function BN_FindBallBuffer()
    return buffer.fromstring(string.char(ByteNetPackets.findBall))
end

function BN_SelectRoleBuffer(roleId, teamLetter)
    return buffer.fromstring(string.char(ByteNetPackets.selectRole) .. string.char(roleId) .. "\001\000" .. teamLetter)
end


BN_ReadPacketIDs()



function SafeNotify(content, delay)
    if Menu.Config and Menu.Config.isLoading and Menu.Config.isLoading() then
        return 
    end
    
    if Menu.Accent then
        local accentHex = "#" .. Menu.Accent:ToHex():upper()
        content = content:gsub("#A6BAFF", accentHex)
        content = content:gsub("#a6baff", accentHex)
    end
    Menu.Notify(content, delay)
end



local KuronaHook = {
    OriginalFireServer = nil,
    IsHooked = false
}

local function SetupKuronaHook()
    if KuronaHook.IsHooked then return end
    local ByteNetReliable = Services.ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not ByteNetReliable then return end
    
    if hookfunction then
        KuronaHook.OriginalFireServer = hookfunction(ByteNetReliable.FireServer, function(self, buf, packetTable)
            
            if packetTable and type(packetTable) == "table" and packetTable[1] then
                local packetData = packetTable[1]
                if type(packetData) == "table" and packetData[1] then
                    local packetName = packetData[1]
                    
                    if packetName == "baseAwaken" and KFR_OnBaseAwaken then
                        KFR_OnBaseAwaken()
                    end
                    
                    if packetName == "skill5" and KOR_OnSkill5 then
                        KOR_OnSkill5()
                    end
                end
            end
            return KuronaHook.OriginalFireServer(self, buf, packetTable)
        end)
        KuronaHook.IsHooked = true
    end
end


