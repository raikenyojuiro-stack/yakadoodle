    if distance > ReflexTackle.GetRange() then return false end
    local lookVector = myRoot.CFrame.LookVector local toTarget = (targetRoot.Position - myRoot.Position).Unit
    return lookVector:Dot(toTarget) > 0.5
end

function ReflexTackle.PressSkill2()
