local EasySkill4Shidou = {
    Enabled = false, HasReached100 = false, WasAbove100 = false, LastFlowValue = 0,
    Connections = {}, CurrentTrack = nil, CurrentKey = Enum.KeyCode.V,
    CanUseSkill = false, AnimationPlayedInCycle = false, IsExecuting = false
}

function ES4_IsShidou() return Player:GetAttribute("style") == "shidou" end
function ES4_FindByte() return Services.ReplicatedStorage:FindFirstChild("ByteNetReliable") end
function ES4_FindFlow()
    local chars = Services.Workspace:WaitForChild("characters")
    local my = chars:FindFirstChild(Player.Name)
    if not my then return end
    local st = my:FindFirstChild("state")
    return st and st:FindFirstChild("flow")
end

function ES4_IsAnimationPlaying(animationId)
    if not Player.Character then return false end
    local humanoid = Player.Character:FindFirstChild("Humanoid") if not humanoid then return false end
    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(tostring(animationId)) then return true end
    end
    return false
end

function EasySkill4Shidou.PlayAnim(id)
    if EasySkill4Shidou.CurrentTrack then EasySkill4Shidou.CurrentTrack:Stop() end
    local char = Player.Character if not char then return end
    local humanoid = char:FindFirstChild("Humanoid") if not humanoid then return end
    local Anim = Instance.new("Animation")
    Anim.AnimationId = "rbxassetid://" .. id
    EasySkill4Shidou.CurrentTrack = humanoid:LoadAnimation(Anim)
    EasySkill4Shidou.CurrentTrack:Play()
end

function EasySkill4Shidou.StopAnim()
    if EasySkill4Shidou.CurrentTrack then EasySkill4Shidou.CurrentTrack:Stop() EasySkill4Shidou.CurrentTrack = nil end
end

function EasySkill4Shidou.ResetStates()
    EasySkill4Shidou.HasReached100 = false
    EasySkill4Shidou.WasAbove100 = false
    EasySkill4Shidou.LastFlowValue = 0
    EasySkill4Shidou.CanUseSkill = false
    EasySkill4Shidou.AnimationPlayedInCycle = false
end

function ES4_Heartbeat()
    if not EasySkill4Shidou.Enabled then return end
    local flowObj = ES4_FindFlow()
    if not flowObj then EasySkill4Shidou.ResetStates() return end
    local value = flowObj.Value
    if value >= 100 then
        EasySkill4Shidou.HasReached100 = true
        EasySkill4Shidou.WasAbove100 = true
        EasySkill4Shidou.CanUseSkill = false
        EasySkill4Shidou.AnimationPlayedInCycle = false
    elseif value < 100 and EasySkill4Shidou.WasAbove100 then
        EasySkill4Shidou.HasReached100 = true
        EasySkill4Shidou.CanUseSkill = true
    else
        EasySkill4Shidou.HasReached100 = false
        EasySkill4Shidou.CanUseSkill = false
    end
    if value <= 0 then EasySkill4Shidou.WasAbove100 = false EasySkill4Shidou.HasReached100 = false end
    EasySkill4Shidou.LastFlowValue = value
    if ES4_IsAnimationPlaying("132876424584395") then EasySkill4Shidou.AnimationPlayedInCycle = true end
end

function EasySkill4Shidou.ExecuteSkill4Variant()
    if EasySkill4Shidou.IsExecuting then return false end
    if not EasySkill4Shidou.Enabled or not ES4_IsShidou() or not HasBall() then return false end
    local flowObj = ES4_FindFlow() if not flowObj then return false end
    local flow = flowObj.Value
    local shouldActivate = EasySkill4Shidou.HasReached100 and flow < 100 and EasySkill4Shidou.CanUseSkill and not EasySkill4Shidou.AnimationPlayedInCycle
    local byteNet = ES4_FindByte() if not byteNet then return false end
    if shouldActivate and not IsSkillOnCooldown("skill4") then
        EasySkill4Shidou.IsExecuting = true
        EasySkill4Shidou.AnimationPlayedInCycle = true
        EasySkill4Shidou.PlayAnim("76587445975710")
        task.wait(0.1)
        pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"kick", 24, false, vector.create(0,1,0)}}) end)
        pcall(function() byteNet:FireServer(BN_UseBuffer(), {{"skill4"}}) end)
        SafeNotify("<font color='#A6BAFF'>[ Easy Skill4 Shidou ]</font> Executed!", 1)
        EasySkill4Shidou.IsExecuting = false
        return true
    end
    return false
end

function EasySkill4Shidou.Start()
    EasySkill4Shidou.Enabled = true
    EasySkill4Shidou.ResetStates()
    EasySkill4Shidou.Connections.flow = Services.RunService.Heartbeat:Connect(ES4_Heartbeat)
    EasySkill4Shidou.Connections.key = Services.UIS.InputBegan:Connect(function(input, gp)
        if not gp and input.KeyCode == EasySkill4Shidou.CurrentKey then EasySkill4Shidou.ExecuteSkill4Variant() end
    end)
    EasySkill4Shidou.Connections.character = Player.CharacterAdded:Connect(function() task.wait(1) EasySkill4Shidou.ResetStates() end)
    SafeNotify("<font color='#A6BAFF'>[ Easy Skill4 Shidou ]</font> Activated!", 2)
end

function EasySkill4Shidou.Stop()
    EasySkill4Shidou.Enabled = false
    EasySkill4Shidou.StopAnim()
    EasySkill4Shidou.ResetStates()
    for _, c in pairs(EasySkill4Shidou.Connections) do if c then c:Disconnect() end end
    EasySkill4Shidou.Connections = {}
    SafeNotify("<font color='#A6BAFF'>[ Easy Skill4 Shidou ]</font> Deactivated!", 2)
end








local BarouMovementLock = {
    Enabled = false, Connection = nil, CurrentKey = Enum.KeyCode.C,
    IsLocked = false, LastPos = nil, Style = "barou", Name = "Movement Lock",
    LOCK_ANIMATION_ID = "73560885704292", MAX_SPEED = 0.400
}

function BML_IsBarou() return Player:GetAttribute("style") == "barou" end

function BML_GetCurrentAnimationId()
    if not Player.Character then return false end
    local humanoid = Player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return false end
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.IsPlaying and track.Animation then
            local animId = tostring(track.Animation.AnimationId)
            
            if animId:find(BarouMovementLock.LOCK_ANIMATION_ID) then
                return true
            end
        end
    end
    return false
end

function BML_Heartbeat()
    if not BarouMovementLock.Enabled then return end
    if not BML_IsBarou() then return end
    if not Player.Character then return end
    local rootPart = Player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local Camera = Services.Workspace.CurrentCamera
    
    local animPlaying = BML_GetCurrentAnimationId()
    if animPlaying then
        local camLook = Camera.CFrame.LookVector
        local camForward = Vector3.new(camLook.X, 0, camLook.Z).Unit
        if not BarouMovementLock.IsLocked then
            BarouMovementLock.IsLocked = true
            BarouMovementLock.LastPos = rootPart.Position
        end
        local currentPos = rootPart.Position
        local movement = currentPos - BarouMovementLock.LastPos
        local movementXZ = Vector3.new(movement.X, 0, movement.Z)
        local speed = math.min(movementXZ.Magnitude, BarouMovementLock.MAX_SPEED)
        local newPos = BarouMovementLock.LastPos + (camForward * speed)
        newPos = Vector3.new(newPos.X, currentPos.Y, newPos.Z)
        rootPart.CFrame = CFrame.new(newPos, newPos + camForward)
        BarouMovementLock.LastPos = newPos
    elseif BarouMovementLock.IsLocked then
        BarouMovementLock.IsLocked = false
        BarouMovementLock.LastPos = nil
    end
end

function BarouMovementLock.Start()
    if BarouMovementLock.Enabled then return end
    BarouMovementLock.Enabled = true
    BarouMovementLock.Connection = Services.RunService.Heartbeat:Connect(BML_Heartbeat)
    SafeNotify("<font color='#A6BAFF'>[ " .. BarouMovementLock.Name .. " ]</font> Activated!", 2)
end

function BarouMovementLock.Stop()
    BarouMovementLock.Enabled = false
    BarouMovementLock.IsLocked = false
    BarouMovementLock.LastPos = nil
    if BarouMovementLock.Connection then
        BarouMovementLock.Connection:Disconnect()
        BarouMovementLock.Connection = nil
    end
    SafeNotify("<font color='#A6BAFF'>[ " .. BarouMovementLock.Name .. " ]</font> Deactivated!", 2)
end






function CreateDistanceBuff(name, style, animationId, defaultDistance, delayBefore, checkBall)
    
    local styleList = type(style) == "table" and style or {style}
    
    
    local animationIds = {}
    if type(animationId) == "table" then
        for _, id in ipairs(animationId) do
            table.insert(animationIds, tostring(id))
        end
    else
        table.insert(animationIds, tostring(animationId))
    end
    
    
    if checkBall == nil then checkBall = true end
    
    local buff = {
        Enabled = false,
        Distance = defaultDistance or 4,
        DelayBefore = delayBefore or 0,
        CheckBall = checkBall,
        Connections = {},
        AnimationConnection = nil,
        IsTeleporting = false,
        CurrentAnimTrack = nil
    }
    
    function buff.IsStyle()
        local currentStyle = Player:GetAttribute("style")
        for _, s in ipairs(styleList) do
            if currentStyle == s then return true end
        end
        return false
    end
    
    function buff.FindBall()
        local currentTime = tick()
        if currentTime - buff.LastBallCheck < 0.1 and buff.BallCache then
            return buff.BallCache
        end
        buff.LastBallCheck = currentTime
        local ball = Services.Workspace.Terrain:FindFirstChild("Ball") or Services.Workspace:FindFirstChild("Ball")
        buff.BallCache = ball
        return ball
    end
    
    
    if checkBall == nil then checkBall = true end
    
    local buff = {
        Enabled = false,
        Distance = defaultDistance or 4,
        DelayBefore = delayBefore or 0,
        CheckBall = checkBall,
        Connections = {},
        AnimationConnection = nil,
        TeleportThread = nil,
        IsActive = false,
        TargetAnimationIds = animationIds,
        Style = styleList,
        Name = name,
        BallCache = nil,
        LastBallCheck = 0,
        TeleportStartTime = 0,
        MaxDuration = 3.5
    }
    
    
    local function isBallNearby()
        if not buff.Enabled then return false end
        local now = tick()
        if now - buff.LastBallCheck >= 0.2 then
            buff.LastBallCheck = now
            buff.BallCache = Services.Workspace:FindFirstChild("Ball") or Services.Workspace.Terrain:FindFirstChild("Ball")
            if not buff.BallCache or not Player.Character then
                buff.BallCache = nil
                return false
            end
            local rootPart = Player.Character:FindFirstChild("HumanoidRootPart")
            if not rootPart then
                buff.BallCache = nil
                return false
            end
            local distance = (rootPart.Position - buff.BallCache.Position).Magnitude
            if distance > 17 then
                buff.BallCache = nil
                return false
            end
        end
        return buff.BallCache ~= nil
    end
    
    
    local function isPlayerWithBallNearby()
        if not buff.Enabled or not Player.Character then return false end
        local myRootPart = Player.Character:FindFirstChild("HumanoidRootPart")
        if not myRootPart then return false end
        for _, targetPlayer in pairs(Services.Players:GetPlayers()) do
            if targetPlayer ~= Player then
                local targetCharacter = targetPlayer.Character
                if targetCharacter and targetCharacter:FindFirstChild("Ball") then
                    local targetRootPart = targetCharacter:FindFirstChild("HumanoidRootPart")
                    if targetRootPart and (myRootPart.Position - targetRootPart.Position).Magnitude <= 17 then
                        return true
                    end
                end
            end
        end
        return false
    end
    
    
    local function shouldStopTeleport()
        if not buff.CheckBall then return false end
        return isBallNearby() or isPlayerWithBallNearby()
    end
    
    
    local function teleportForward()
        if not buff.Enabled or not Player.Character then return false end
        if shouldStopTeleport() then return false end
        local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        local lookVector = hrp.CFrame.LookVector
        local newPosition = hrp.Position + (lookVector * buff.Distance)
        hrp.CFrame = CFrame.new(newPosition, newPosition + lookVector)
        return true
    end
    
    
    local function stopTeleportation()
        buff.IsActive = false
        if buff.TeleportThread then
            pcall(function() task.cancel(buff.TeleportThread) end)
            buff.TeleportThread = nil
        end
    end
    
    
    local function startTeleportation(track)
        if buff.IsActive or not buff.Enabled then return end
        if shouldStopTeleport() then return end
        
        
        if buff.DelayBefore > 0 then
            task.spawn(function()
                task.wait(buff.DelayBefore)
                if not buff.Enabled or not track.IsPlaying then return end
                if shouldStopTeleport() then return end
                
                buff.IsActive = true
                buff.TeleportStartTime = tick()
                buff.TeleportThread = task.spawn(function()
                    while buff.IsActive and buff.Enabled and track.IsPlaying do
                        if tick() - buff.TeleportStartTime >= buff.MaxDuration then stopTeleportation() break end
                        local success = teleportForward()
                        if not success then
                            stopTeleportation()
                            break
                        end
                        task.wait(0.08)
                    end
                    buff.IsActive = false
                end)
            end)
        else
            buff.IsActive = true
            buff.TeleportStartTime = tick()
            buff.TeleportThread = task.spawn(function()
                while buff.IsActive and buff.Enabled do
                    if tick() - buff.TeleportStartTime >= buff.MaxDuration then stopTeleportation() break end
                    local success = teleportForward()
                    if not success then
                        stopTeleportation()
                        break
                    end
                    task.wait(0.1)
                end
                buff.IsActive = false
            end)
        end
    end
    
    
