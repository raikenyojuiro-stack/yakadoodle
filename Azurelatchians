    for _, player in ipairs(Services.Players:GetPlayers()) do FlowIndicator.SetupPlayerTracking(player) end
    local playerAddedConn = Services.Players.PlayerAdded:Connect(function(player) FlowIndicator.SetupPlayerTracking(player) end)
