local NagiTrapHelper = {
    Enabled = false, Connection = nil, AnimationConnection = nil, CharacterConnection = nil,
    IsActive = false, StartTime = 0, LastPosition = nil,
    ANIMATION_ID = "73387016994281", MIN_BALL_HEIGHT = 5,
    MagnetRadius = 55, MagnetSpeed = 0.07, ACTIVATION_DELAY = 0.01,
    MAGNET_DURATION = 1.5, VERTICAL_OFFSET = 2
}

function NTH_GetBall()
    local ball = Services.Workspace:FindFirstChild("Ball")
    if ball then return ball end
    ball = Services.Workspace.Terrain:FindFirstChild("Ball")
    return ball
end

function NTH_IsNagi() return Player:GetAttribute("style") == "nagi" end

function NTH_IsPlayingTargetAnimation()
    local char = Player.Character if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid") if not humanoid then return false end
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(NagiTrapHelper.ANIMATION_ID) then return true end
    end
    return false
end

function NTH_CanActivateMagnet(ball)
    if not ball then return false end
    local char = Player.Character if not char then return false end
    if char:FindFirstChild("Ball") then return false end
    if ball.Position.Y < NagiTrapHelper.MIN_BALL_HEIGHT then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return false end
    local distance = (hrp.Position - ball.Position).Magnitude
    return distance <= NagiTrapHelper.MagnetRadius
end

function NTH_SmoothMagnetToBall()
    local ball = NTH_GetBall()
    if not ball or not NTH_CanActivateMagnet(ball) then return false end
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local targetPosition = ball.Position + Vector3.new(0, NagiTrapHelper.VERTICAL_OFFSET, 0)
    local currentPosition = hrp.Position
    local distance = (currentPosition - targetPosition).Magnitude
    if distance < 2 then return true end
    local newPosition = currentPosition:Lerp(targetPosition, NagiTrapHelper.MagnetSpeed)
    local playerHeight = currentPosition.Y
    if playerHeight > 10 then newPosition = Vector3.new(newPosition.X, playerHeight, newPosition.Z) end
    hrp.CFrame = CFrame.new(newPosition)
    return true
end

function NagiTrapHelper.StartMagnet()
    if NagiTrapHelper.IsActive then return end
    NagiTrapHelper.StartTime = tick()
    NagiTrapHelper.IsActive = true
    local char = Player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then NagiTrapHelper.LastPosition = hrp.Position end
    end
    NagiTrapHelper.Connection = Services.RunService.Heartbeat:Connect(function()
        if not NagiTrapHelper.IsActive or not NTH_IsPlayingTargetAnimation() then
            NagiTrapHelper.StopMagnet()
            return
        end
        local timeSinceStart = tick() - NagiTrapHelper.StartTime
        if timeSinceStart < NagiTrapHelper.ACTIVATION_DELAY then return end
        if timeSinceStart > NagiTrapHelper.MAGNET_DURATION then
            NagiTrapHelper.StopMagnet()
            return
        end
        NTH_SmoothMagnetToBall()
        local char = Player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then NagiTrapHelper.LastPosition = hrp.Position end
        end
    end)
    task.delay(NagiTrapHelper.MAGNET_DURATION + 0.1, function() NagiTrapHelper.StopMagnet() end)
end

function NagiTrapHelper.StopMagnet()
    if NagiTrapHelper.IsActive then
        NagiTrapHelper.IsActive = false
        if NagiTrapHelper.Connection then NagiTrapHelper.Connection:Disconnect() NagiTrapHelper.Connection = nil end
    end
end

function NagiTrapHelper.SetupAnimationMonitor()
    local char = Player.Character
    if not char then return end
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then
        char.ChildAdded:Connect(function(child)
            if child:IsA("Humanoid") then task.wait(0.5) NagiTrapHelper.SetupAnimationMonitor() end
        end)
        return
    end
    NagiTrapHelper.AnimationConnection = humanoid.AnimationPlayed:Connect(function(animationTrack)
        if not NagiTrapHelper.Enabled then return end
        if animationTrack.Animation then
            local animId = tostring(animationTrack.Animation.AnimationId)
            if animId:find(NagiTrapHelper.ANIMATION_ID) then
                task.delay(NagiTrapHelper.ACTIVATION_DELAY, function()
                    if NTH_IsPlayingTargetAnimation() then
                        local ball = NTH_GetBall()
                        if NTH_CanActivateMagnet(ball) then NagiTrapHelper.StartMagnet() end
                    end
                end)
            end
        end
    end)
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and tostring(track.Animation.AnimationId):find(NagiTrapHelper.ANIMATION_ID) then
            task.delay(0.3, function()
                if NTH_IsPlayingTargetAnimation() then
                    local ball = NTH_GetBall()
                    if NTH_CanActivateMagnet(ball) then NagiTrapHelper.StartMagnet() end
                end
            end)
            break
        end
    end
end

function NagiTrapHelper.Start()
    if not NTH_IsNagi() then
    end
    NagiTrapHelper.Enabled = true
    NagiTrapHelper.SetupAnimationMonitor()
    NagiTrapHelper.CharacterConnection = Player.CharacterAdded:Connect(function(newChar)
        NagiTrapHelper.StopMagnet()
        task.wait(0.5)
        local startTime = tick()
        while not newChar:FindFirstChild("HumanoidRootPart") and tick() - startTime < 3 do task.wait(0.1) end
        if newChar:FindFirstChild("HumanoidRootPart") then
            task.wait(0.5)
